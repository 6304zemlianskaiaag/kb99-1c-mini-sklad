// GRACE:MODULE_START name="УтилитныеОбработки"
// @grace-module: УтилитныеОбработки
// @grace-purpose: Форма установки соответствий между номенклатурой учётной системы и продукцией ВетИС
// @grace-depends: ЯдроВСД, ИнтеграцияВетИС_API, НСИ_ВетИС, РегламентныеЗадания
// @grace-version: 1.0
// @grace-contract-ref: docs/Contracts.xml -> module="УтилитныеОбработки"
// GRACE:DEPENDENCY target="кб99_ВСД"

// @grace-contract: ПредупреждениеПользователю
//   Вход: ТекстПредупреждения (Строка) — текст предупреждения
//   Выход: нет
//   Исключение: нет
//   Инвариант: нет
//   GRACE-лог: нет
// GRACE:CONTRACT function="ПредупреждениеПользователю"

// @grace-contract: ПослеЗакрытияПредупреждение
//   Вход: Параметры (Произвольный) — stub-callback для немодального предупреждения
//   Выход: нет
//   Исключение: нет
//   Инвариант: нет
//   GRACE-лог: нет
// GRACE:CONTRACT function="ПослеЗакрытияПредупреждение"
// LLM_NOTE: ПослеЗакрытияПредупреждение — пустой stub-callback для ПоказатьПредупреждение.
// Платформа требует описание оповещения, но реакция на закрытие не нужна.

// @grace-contract: кнУбратьСоответствияОтвет
//   Вход: Ответ (КодВозвратаДиалога), Парам (Структура) — ответ на подтверждение удаления соответствий
//   Выход: нет
//   Исключение: нет
//   Инвариант: нет
//   GRACE-лог: нет
// GRACE:CONTRACT function="кнУбратьСоответствияОтвет"

// ********* Команды и события Формы
#Область НемодальныеОкна

&НаКлиенте
Процедура ПредупреждениеПользователю(ТекстПредупреждения) Экспорт
	Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияПредупреждение", ЭтаФорма);
	ПоказатьПредупреждение(Оповещение, ТекстПредупреждения, 0, "Предупреждение");
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗакрытияПредупреждение(Параметры) Экспорт
КонецПроцедуры

#КонецОбласти


&НаКлиенте
Процедура кнПрочитать(Команда)

	СзНоменклатура.Очистить();
	Рез = ВетИС_ЯдроСервер.ПолучитьНоменклатуруПоПродукцияЭлемент(ВыбВСДЭлемент);
	СзНоменклатура.ЗагрузитьЗначения(Рез);

КонецПроцедуры

&НаКлиенте
Процедура СзНоменклатураОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)

	СтандартнаяОбработка = Ложь;
	Если СзНоменклатура.НайтиПоЗначению(ВыбранноеЗначение) = Неопределено Тогда
		СзНоменклатура.Добавить(ВыбранноеЗначение);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура кнДобавитьНоменклатуру(Команда)

	ПараметрыПодбора = Новый Структура("ЗакрыватьПриВыборе, РежимВыбора", Ложь, Истина);
	ОткрытьФорму("Справочник.Номенклатура.ФормаВыбора", ПараметрыПодбора, Элементы.СзНоменклатура);

КонецПроцедуры

&НаКлиенте
Процедура кнЗаписатьСоответсвия(Команда)

	Если ВыбВСДЭлемент.Пустая() Тогда
		ПредупреждениеПользователю("Укажите Номенклатуру");
		Возврат;
	КонецЕсли;

	// очистим соответствия
	МассивНоменклатуры = ВетИС_ЯдроСервер.ПолучитьНоменклатуруПоПродукцияЭлемент(ВыбВСДЭлемент);
	СписокНоменклатуры = Новый СписокЗначений;
	СписокНоменклатуры.ЗагрузитьЗначения(МассивНоменклатуры);
	ВетИС_ЯдроСервер.УдалитьСоответствиеСписку_ВСД_Продукция_Элемент(СписокНоменклатуры,ВыбВСДЭлемент);

	ВетИС_ЯдроСервер.УстановитьСоответствиеСписку_ВСД_Продукция_Элемент(СзНоменклатура,ВыбВСДЭлемент);
	ПредупреждениеПользователю("-> Соответсвия для " + ВыбВСДЭлемент + " Установлены");

КонецПроцедуры

&НаКлиенте
Процедура кнУбратьСоответствияОтвет(Ответ,Парам) Экспорт

	Если Ответ = КодВозвратаДиалога.Да Тогда
		ВетИС_ЯдроСервер.УдалитьСоответствиеСписку_ВСД_Продукция_Элемент(Парам.СзНоменклатура,Парам.ВыбВСДЭлемент);
		кнПрочитать("");
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура кнУбратьСоответствия(Команда)

	Если ВыбВСДЭлемент.Пустая() Тогда
		ПредупреждениеПользователю("Выберите продукцию ГИС Меркурий");
		Возврат;
	КонецЕсли;
	Парам = Новый Структура("СзНоменклатура,ВыбВСДЭлемент", СзНоменклатура,ВыбВСДЭлемент);
	Оповещение = Новый ОписаниеОповещения("кнУбратьСоответствияОтвет", ЭтаФорма,Парам);
	ПоказатьВопрос(Оповещение, "Удалить соответствие выбранной номенклатуры 1С Элементу Меркурий?", РежимДиалогаВопрос.ДаНет, 0, КодВозвратаДиалога.Да, "");

КонецПроцедуры

// GRACE:MODULE_END name="УтилитныеОбработки"
