// GRACE:MODULE_START name="ПроизводствоВСД"
// @grace-module: ПроизводствоВСД
// @grace-purpose: Объектный модуль обработки кб99_ЛабИсследования — создание документов лабораторных исследований по партиям
// @grace-depends: ЯдроВСД, ДокументооборотВСД, ИнтеграцияВетИС_API, РегистрыПартий
// @grace-version: 1.0
// @grace-contract-ref: docs/Contracts.xml -> module="ПроизводствоВСД"
// GRACE:DEPENDENCY target="кб99_ВСД"

// @grace-contract: СоздатьЛИ
//   Вход: нет (читает ТЧ Партии из объекта обработки)
//   Выход: нет (создаёт документы ВСД2_ЛабораторныеИсследования и заполняет ссылки в ТЧ)
//   Исключение: нет
//   Инвариант: создаёт ЛИ только для партий с Пометка=Истина и статусом 102 или 103 без существующего ЛИ
//   GRACE-лог: нет
// GRACE:CONTRACT function="СоздатьЛИ"

Процедура СоздатьЛИ() Экспорт

	Для Каждого стрПартия Из Партии Цикл
		Если стрПартия.Пометка Тогда
			Если НЕ ЗначениеЗаполнено(стрПартия.ЛабИсследования)
				 И СокрЛП(стрПартия.СтатусПартии) = "103"
				 ИЛИ СокрЛП(стрПартия.СтатусПартии) = "102" Тогда
				Сообщить(стрПартия.Партия);
				Dok = Документы.ВСД2_ЛабораторныеИсследования.СоздатьДокумент();
				Dok.Дата = ТекущаяДата();
				Dok.Исследования.Загрузить( ВыбШаблон.Исследования.Выгрузить() );
				Dok.Партия = стрПартия.Партия;
				Dok.Организация = ВыбШаблон.Организация;
				Dok.Записать();
				стрПартия.ЛабИсследования = Dok.Ссылка;
			Иначе
				Сообщить("Для Партии: " + стрПартия.Партия + ", невозможно оформить лабораторные Исследования! Пропускаю...");
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

// GRACE:MODULE_END name="ПроизводствоВСД"
