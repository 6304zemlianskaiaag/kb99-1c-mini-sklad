// GRACE:MODULE_START name="УтилитныеОбработки"
// @grace-module: УтилитныеОбработки
// @grace-purpose: Форма списания товаров через ВСД — создание документов списания партий и отправка в ГИС Меркурий
// @grace-depends: ЯдроВСД, ИнтеграцияВетИС_API, НСИ_ВетИС, РегламентныеЗадания
// @grace-version: 1.0
// @grace-contract-ref: docs/Contracts.xml -> module="УтилитныеОбработки"
// GRACE:DEPENDENCY target="кб99_ВСД"
// GRACE:DEPENDENCY target="ВетИС_ПараметрыСервер"
&НаКлиенте
Перем КэшОтмеченныеСтроки;

#Область ОбработчикиСобытий

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Период.ДатаНачала = НачалоДня(ТекущаяДатаСеанса());
	Период.ДатаОкончания = КонецДня(ТекущаяДатаСеанса());
		
	Организация = ВетИС_ПараметрыСервер.ПолучитьОрганизациюПоУмолчанию();
		
	ОбновитьЗаПериодНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ПолучитьПредставлениеПериода();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ОбновитьЗаПериод(Команда)
	
	Если Не ЗначениеЗаполнено(Период) Тогда
		ВетИС_ЯдроСервер.СообщитьПользователю(НСтр("ru = 'Не заполнено поле'"),, "Период", Период);
		Возврат;
	КонецЕсли;
	
	ОбновитьЗаПериодНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура Списать(Команда)
	
	ЗапомнитьОтмеченныеСтроки();
	
	ОформитьДокументСписания();
	ОбновитьЗаПериодНаСервере(Ложь);
	
	ВосстановитьОтмеченныеСтроки();
	
КонецПроцедуры

&НаКлиенте
Процедура СнятьОтметкиСДокументов(Команда)
	
	Для Каждого стр Из Список Цикл
		стр.Отметка = Ложь;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ОтметитьВсеДокументы(Команда)
	УстановитьФлажкиНаВсеДокументы();
КонецПроцедуры

&НаКлиенте
Процедура Отправить(Команда)
	
	СписокДокументовКОтправке = ПодготовитьСписокВСДКОтправке();
	Если СписокДокументовКОтправке.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
		
	Состояние("Выполняем отправку ВСД", , "Ожидайте...", БиблиотекаКартинок.kb99_wrench);
		
	Для Каждого ДокСсылка Из СписокДокументовКОтправке Цикл
		ВетИС_ЯдроСервер.ОтправитьВСДвГИС(ДокСсылка);
	КонецЦикла;
	
	ОбновитьЗаПериодНаСервере(Ложь);
	
	ПоказатьОповещениеПользователя("Выполнено"); 
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьИнтервал(Команда)
	
	Оповещение = Новый ОписаниеОповещения("УстановитьИнтервалЗавершение", ЭтаФорма);
	РедактироватьПериод(Период, , Оповещение);
	
КонецПроцедуры

&НаКлиенте
// @grace-contract: УстановитьИнтервалЗавершение
//   Вход: см. сигнатуру
//   Выход: нет
//   Исключение: нет
//   Инвариант: нет
//   GRACE-лог: нет
// GRACE:CONTRACT function="УстановитьИнтервалЗавершение"
Процедура УстановитьИнтервалЗавершение(ВыбранноеЗначение, ДополнительныеПараметры) Экспорт
	
	Если ВыбранноеЗначение = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ПолучитьПредставлениеПериода();
	Период = ВыбранноеЗначение;
	ОбновитьЗаПериодНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ПолучитьПредставлениеПериода()
	
	НачалоПериода = Период.ДатаНачала;
	КонецПериода = Период.ДатаОкончания;
	ТолькоДаты = Истина;
	
	ТекстПериод = "";
		
	Если ЗначениеЗаполнено(КонецПериода) Тогда 
		Если КонецПериода >= НачалоПериода Тогда
			ТекстПериод = ?(ТолькоДаты, "", " " + НСтр("ru = 'за'")+ " ");
			ТекстПериод = ТекстПериод
				+ ПредставлениеПериода(НачалоДня(НачалоПериода), КонецДня(КонецПериода), "ФП = Истина");
		Иначе
			ТекстПериод = "";
		КонецЕсли;
	ИначеЕсли ЗначениеЗаполнено(НачалоПериода) Тогда

		ТекстПериод = ?(ТолькоДаты, "", " " + НСтр("ru = 'за'")+ " ")
			+ ПредставлениеПериода(НачалоДня(НачалоПериода), КонецДня(Дата(3999, 11, 11)), "ФП = Истина");
		ТекстПериод = СтрЗаменить(ТекстПериод, Сред(ТекстПериод, СтрНайти(ТекстПериод, " - ")), " - ...");

	КонецЕсли;
	
	ТекстПериод = "Период: " + ТекстПериод;
	
КонецПроцедуры

&НаКлиенте
// @grace-contract: РедактироватьПериод
//   Вход: см. сигнатуру
//   Выход: нет
//   Исключение: нет
//   Инвариант: нет
//   GRACE-лог: нет
// GRACE:CONTRACT function="РедактироватьПериод"
Процедура РедактироватьПериод(Объект, ПараметрыПериода = Неопределено, ОповещениеПослеВыбора = Неопределено) Экспорт
	
	Если ПараметрыПериода = Неопределено Тогда
		ПараметрыПериода = Новый Структура("ДатаНачала, ДатаОкончания", "ДатаНачала", "ДатаОкончания");
	КонецЕсли;
	
	Диалог = Новый ДиалогРедактированияСтандартногоПериода();
	Если ПараметрыПериода.Свойство("ДатаНачала") Тогда
		Диалог.Период.ДатаНачала = Объект[ПараметрыПериода.ДатаНачала];
	КонецЕсли; 
	Если ПараметрыПериода.Свойство("ДатаОкончания") Тогда
		Диалог.Период.ДатаОкончания = Объект[ПараметрыПериода.ДатаОкончания];
	КонецЕсли; 
	Если ПараметрыПериода.Свойство("Вариант") Тогда
		Диалог.Период.Вариант = ПараметрыПериода.Вариант;
	КонецЕсли; 
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Объект",           Объект);
	ДополнительныеПараметры.Вставить("ПараметрыПериода", ПараметрыПериода);
	Если ОповещениеПослеВыбора <> Неопределено Тогда
		ДополнительныеПараметры.Вставить("ОповещениеПослеВыбора", ОповещениеПослеВыбора);
	КонецЕсли; 
	
	Оповещение = Новый ОписаниеОповещения(
		"РедактироватьПериодЗавершение", 
		ЭтаФорма, 
		ДополнительныеПараметры);
	
	Диалог.Показать(Оповещение);

КонецПроцедуры

&НаКлиенте
// @grace-contract: РедактироватьПериодЗавершение
//   Вход: см. сигнатуру
//   Выход: нет
//   Исключение: нет
//   Инвариант: нет
//   GRACE-лог: нет
// GRACE:CONTRACT function="РедактироватьПериодЗавершение"
Процедура РедактироватьПериодЗавершение(Период, ДополнительныеПараметры) Экспорт 

	ПараметрыПериода = ДополнительныеПараметры.ПараметрыПериода;
	Объект_           = ДополнительныеПараметры.Объект;
	Если Период <> Неопределено Тогда
		Если ПараметрыПериода.Свойство("ДатаНачала") Тогда
			Объект_[ПараметрыПериода.ДатаНачала]= Период.ДатаНачала;
		КонецЕсли; 
		Если ПараметрыПериода.Свойство("ДатаОкончания") Тогда
			Объект_[ПараметрыПериода.ДатаОкончания]= Период.ДатаОкончания;
		КонецЕсли; 
		Если ПараметрыПериода.Свойство("Вариант") Тогда
			Объект_[ПараметрыПериода.Вариант]= Период.Вариант;
		КонецЕсли;
	КонецЕсли;
	
	Если ДополнительныеПараметры.Свойство("ОповещениеПослеВыбора") Тогда
		ВыполнитьОбработкуОповещения(ДополнительныеПараметры.ОповещениеПослеВыбора, Период);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапомнитьОтмеченныеСтроки()
	
	КэшОтмеченныеСтроки = Новый Массив;
	
	Для Каждого Стр Из Список Цикл
		
		Если Стр.Отметка Тогда	
			КэшОтмеченныеСтроки.Добавить(Стр.ДокументРеализации);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ВосстановитьОтмеченныеСтроки()
	
	Для Каждого Док Из КэшОтмеченныеСтроки Цикл
		
		ОтмеченныеСтроки = Список.НайтиСтроки(Новый Структура("ДокументРеализации", Док));
		Для Каждого Стр Из ОтмеченныеСтроки Цикл
			Стр.Отметка = Истина;
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ОбновитьЗаПериодНаСервере(УстановитьФлажки = Ложь)
	
	ЗаполнитьСтрокиТЧДокументамиРеализаций();
	Если УстановитьФлажки Тогда
		УстановитьФлажкиНаВсеДокументы();
	КонецЕсли;
	
	Элементы.Список.Обновить();
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСтрокиТЧДокументамиРеализаций();
	
	Список.Очистить();
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	ТекстЗапроса = 
		"ВЫБРАТЬ
		|	РеализацияТоваровУслуг.Ссылка КАК ДокументРеализации,
		|	РеализацияТоваровУслуг.Контрагент
		|ПОМЕСТИТЬ ВТ
		|ИЗ
		|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
		|ГДЕ
		|	РеализацияТоваровУслуг.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
		|	И РеализацияТоваровУслуг.Проведен
		|	%ВСД_не_Выписываем%
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	ДокументРеализации
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВЫРАЗИТЬ(ВСД2_ИнвентаризацияДокументыОснования.ДокументОснования.Ссылка КАК Документ.РеализацияТоваровУслуг).Ссылка КАК ДокументОснования,
		|	ВСД2_ИнвентаризацияДокументыОснования.Ссылка КАК ДокументИнвентаризации
		|ПОМЕСТИТЬ ВТ2
		|ИЗ
		|	Документ.ВСД2_Инвентаризация.ДокументыОснования КАК ВСД2_ИнвентаризацияДокументыОснования
		|ГДЕ
		|	НЕ ВСД2_ИнвентаризацияДокументыОснования.Ссылка.ПометкаУдаления
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ.ДокументРеализации КАК ДокументРеализации,
		|	ВТ2.ДокументИнвентаризации КАК ДокументИнвентаризации,
		|	кб99_ЗапросыСрезПоследних.СтатусЗапросаПеречисление КАК СтатусЗапроса,
		|	ВТ.Контрагент
		|ИЗ
		|	ВТ КАК ВТ
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ2 КАК ВТ2
		|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.кб99_Запросы.СрезПоследних(
		|					,
		|					Объект В
		|						(ВЫБРАТЬ
		|							ВТ2.ДокументИнвентаризации КАК ДокументИнвентаризации
		|						ИЗ
		|							ВТ2 КАК ВТ2)) КАК кб99_ЗапросыСрезПоследних
		|			ПО ВТ2.ДокументИнвентаризации = кб99_ЗапросыСрезПоследних.Объект
		|		ПО ВТ.ДокументРеализации = ВТ2.ДокументОснования";
		
	Запрос.УстановитьПараметр("ДатаНачала",		 Период.ДатаНачала);
	Запрос.УстановитьПараметр("ДатаОкончания",	 Период.ДатаОкончания);
	
	Если ВетИС_УтилитыКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Метаданные.Справочники.Партнеры.Реквизиты, "ВСД_не_Выписываем") Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "%ВСД_не_Выписываем%", "И РеализацияТоваровУслуг.Партнер.ВСД_не_Выписываем");
	Иначе
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "%ВСД_не_Выписываем%", "");
	КонецЕсли;
	
	Запрос.Текст = ТекстЗапроса;
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	Список.Загрузить(РезультатЗапроса.Выгрузить());
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

&НаСервере
Процедура ОформитьДокументСписания()
	
	ПараметрыОрганизации = ВетИС_ЯдроСервер.ЗагрузитьПараметры( Организация );
	
	РаспределенныеПартии = ПодготовитьТаблицуПартийКСписанию(ПараметрыОрганизации);
	
	ДокВСД = Документы.ВСД2_Инвентаризация.СоздатьДокумент();
	
	ДокВСД.Дата = ТекущаяДатаСеанса(); 
	ДокВСД.Организация = Организация;
	ДокВСД.Владелец_ХозСубъект = ПараметрыОрганизации.Отправитель_ХозСубъект;
	ДокВСД.Владелец_площадка = ПараметрыОрганизации.Отправитель_Площадка;
	ДокВСД.ПричинаРасхождения = ПараметрыОрганизации["парамПричинаРасхождения"];
	
	ПартииКИнвентаризации = РаспределенныеПартии.Скопировать();
	ПартииКИнвентаризации.Свернуть("Партия, Продукция_Элемент, Остаток", "Количество, КоличествоСписания");
	ДокументыОснование = ВетИС_УтилитыКлиентСервер.СвернутьМассив(РаспределенныеПартии.ВыгрузитьКолонку("Документ"));
	
	Для Каждого СтрПартии Из ПартииКИнвентаризации Цикл
		
		Если Не ЗначениеЗаполнено(СтрПартии.Продукция_Элемент) Тогда
			Продолжить;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(СтрПартии.Партия) Тогда
			ВетИС_ЯдроСервер.СообщитьИнфо("Недостаточно продукции ["+СтрПартии.Продукция_Элемент+"] для списания. Не хватило: " +
				СтрПартии.КоличествоСписания);
			Продолжить;
		КонецЕсли;
		
		Если СтрПартии.Остаток >= СтрПартии.КоличествоСписания Тогда
			Количество = СтрПартии.Остаток - СтрПартии.КоличествоСписания;
		Иначе
			Количество = 0;
		КонецЕсли;
				
		НоваяСтрока = ДокВСД.Продукция.Добавить();
		НоваяСтрока.КлючСтроки = Новый УникальныйИдентификатор();
		НоваяСтрока.КоличествоДоИзменения	= СтрПартии.Остаток;
		НоваяСтрока.Количество 				= Количество;
		НоваяСтрока.КоличествоРазница		= НоваяСтрока.Количество - НоваяСтрока.КоличествоДоИзменения;
		НоваяСтрока.Партия 					= СтрПартии.Партия;
		НоваяСтрока.Продукция_Элемент 		= СтрПартии.Партия.Продукция_Элемент;
		НоваяСтрока.Продукция 				= НоваяСтрока.Партия.Продукция;
		НоваяСтрока.ВидПродукции 			= НоваяСтрока.Партия.ВидПродукции;
		НоваяСтрока.ЕдиницаИзмерения 		= НоваяСтрока.Партия.ЕдиницаИзмерения;
		НоваяСтрока.НаименованиеПродукции	= НоваяСтрока.Продукция_Элемент.Наименование;
		
		Если ЗначениеЗаполнено(НоваяСтрока.Партия.ДатаИзготовления1) Тогда
			НоваяСтрока.ДатаИзготовления1 = ВетИС_APIСервер.СтрокаВДатаВремя(НоваяСтрока.Партия.ДатаИзготовления1);
		КонецЕсли;
		Если ЗначениеЗаполнено(НоваяСтрока.Партия.ДатаИзготовления2) Тогда
			НоваяСтрока.ДатаИзготовления2 = ВетИС_APIСервер.СтрокаВДатаВремя(НоваяСтрока.Партия.ДатаИзготовления2);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(НоваяСтрока.Партия.ДатаСрокГодности1) Тогда
			НоваяСтрока.ДатаСрокГодности1 = ВетИС_APIСервер.СтрокаВДатаВремя(НоваяСтрока.Партия.ДатаСрокГодности1);
		КонецЕсли;
		Если ЗначениеЗаполнено(НоваяСтрока.Партия.ДатаСрокГодности2) Тогда
			НоваяСтрока.ДатаСрокГодности2 = ВетИС_APIСервер.СтрокаВДатаВремя(НоваяСтрока.Партия.ДатаСрокГодности2);
		КонецЕсли;
		
		НоваяСтрока.Производитель_площадка = НоваяСтрока.Партия.Производитель_Площадка;
		НоваяСтрока.Производитель_Страна = ?(ЗначениеЗаполнено(НоваяСтрока.Производитель_площадка.Страна), 
			НоваяСтрока.Производитель_площадка.Страна,
			ПараметрыОрганизации["Страна"]);
	КонецЦикла;
	
	Если Не ДокВСД.Продукция.Количество() ТОгда
		ВетИС_ЯдроСервер.СообщитьИнфо("Отсутстсвуют партии к списанию.");
		Возврат;	
	КонецЕсли;
	
	Для каждого Документ Из ДокументыОснование Цикл
	
		нСтр = ДокВСД.ДокументыОснования.Добавить();
		нСтр.ДокументОснования = Документ;
		
	КонецЦикла;
	
	ДокВСД.Записать();
	
КонецПроцедуры

