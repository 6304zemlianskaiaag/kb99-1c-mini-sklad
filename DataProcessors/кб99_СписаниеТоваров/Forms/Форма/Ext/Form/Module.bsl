КонецПроцедуры

&НаСервере
Функция ПодготовитьСписокВСДКОтправке()
	
	СписокДокументовКОтправке = Новый Массив;
	
	Для Каждого СтрТч Из Список Цикл
		
		ВСДДокумент = СтрТч.ДокументИнвентаризации;
		
		// Пропускаем незаполненные и неотмеченные строки
		Если НЕ ЗначениеЗаполнено(ВСДДокумент) ИЛИ НЕ СтрТч.Отметка Тогда
			Продолжить;
		КонецЕсли;
			
		// Пропускаем документы с заявками, если не требуется их повторная отправка
		ПоследнийЗапрос = ВетИС_УтилитыКлиентСервер.НайтиПоследнийЗапрос(ВСДДокумент);
		Если ПоследнийЗапрос.СтатусЗапросаПеречисление = Перечисления.кб99_СтатусЗапроса.COMPLETED Тогда
			ВетИС_ЯдроСервер.СообщитьИнфо("Документ: " + ВСДДокумент + " уже обработан. Пропускаем.");
			Продолжить;
		КонецЕсли;
		
		СписокДокументовКОтправке.Добавить(ВСДДокумент);
		
	КонецЦикла;
	
	СписокДокументовКОтправке = ВетИС_УтилитыКлиентСервер.СвернутьМассив(СписокДокументовКОтправке);
	
	Возврат СписокДокументовКОтправке;
	
КонецФункции

&НаСервере
Функция ПодготовитьТаблицуПартийКСписанию(ПараметрыОрганизации)
		
	ВремПартии = Новый ТаблицаЗначений;   
	ВремПартии.Колонки.Добавить("Номенклатура");
	ВремПартии.Колонки.Добавить("ВСД_Продукция_Элемент");
	ВремПартии.Колонки.Добавить("КоличествоСписания");
	ВремПартии.Колонки.Добавить("СерияНоменклатуры");
	ВремПартии.Колонки.Добавить("Документ");
	ВремПартии.Колонки.Добавить("ТермУсловияПеревозки");
	ВремПартии.Колонки.Добавить("Контрагент");
	ВремПартии.Колонки.Добавить("ВидПродукции");
	
	РаспределенныеПартии = Новый ТаблицаЗначений; // итоговая ТЗ
	РаспределенныеПартии.Колонки.Добавить("Номенклатура");
	РаспределенныеПартии.Колонки.Добавить("Продукция_Элемент");
	РаспределенныеПартии.Колонки.Добавить("Партия");
	РаспределенныеПартии.Колонки.Добавить("Остаток");
	РаспределенныеПартии.Колонки.Добавить("Количество");
	РаспределенныеПартии.Колонки.Добавить("КоличествоСписания");
	РаспределенныеПартии.Колонки.Добавить("ПолеСортировки");
	РаспределенныеПартии.Колонки.Добавить("Документ");
	РаспределенныеПартии.Колонки.Добавить("ТермическиеУсловияПеревозки");
	РаспределенныеПартии.Колонки.Добавить("ВидПродукции");
	
	ПолеСортировкиПокупателя = Неопределено;
	ЗнакСортировкиПокупателя = Неопределено;
	
	Для Каждого СтрОтгрузки Из Список Цикл
		Если НЕ(СтрОтгрузки.Отметка) Тогда
			Продолжить;
		КонецЕсли;
				
		Если ЗначениеЗаполнено(СтрОтгрузки.ДокументИнвентаризации) Тогда
			ВетИС_ЯдроСервер.СообщитьИнфо("Для "+СтрОтгрузки.ДокументРеализации+" уже создан "+СтрОтгрузки.ДокументИнвентаризации+" ->Пропускаю");
				Продолжить;
		КонецЕсли;
		
		тз = ВетИС_ЗаполнениеДокументовСервер.ВыгрузитьТЧ(СтрОтгрузки.ДокументРеализации, ПараметрыОрганизации);
		Для Каждого стрТЗ Из ТЗ Цикл
	        СтрПартий = Времпартии.Добавить();
			СтрПартий.Номенклатура = стрТЗ.Номенклатура;
			СтрПартий.ВСД_Продукция_Элемент = стрТЗ.Продукция_Элемент;
			СтрПартий.КоличествоСписания = стрТЗ.Количество;
			СтрПартий.СерияНоменклатуры = стрТЗ.СерияНоменклатуры;
			СтрПартий.Документ = СтрОтгрузки.ДокументРеализации;
			СтрПартий.Контрагент = СтрОтгрузки.ДокументРеализации.Контрагент;
			СтрПартий.ТермУсловияПеревозки = стрТЗ.ТермУсловияПеревозки;
			СтрПартий.ВидПродукции = стрТЗ.ВидПродукции;
		КонецЦикла;
		
	КонецЦикла;
	
	ВремПартии.Свернуть("ВСД_Продукция_Элемент, СерияНоменклатуры, Номенклатура, Документ, ТермУсловияПеревозки, Контрагент, ВидПродукции", "КоличествоСписания");
	ВремПартии.Сортировать("ВСД_Продукция_Элемент");

	Если ВремПартии.Количество() = 0 Тогда
		ВетИС_ЯдроСервер.СообщитьИнфо("Нет документов к созданию ВСД ->");
		Возврат РаспределенныеПартии;
	КонецЕсли;
	
	СписокПродукцииЭлементов = ВетИС_УтилитыКлиентСервер.СвернутьМассив(ВремПартии.ВыгрузитьКолонку("ВСД_Продукция_Элемент"));
	СписокНоменклатуры = ВетИС_УтилитыКлиентСервер.СвернутьМассив(ВремПартии.ВыгрузитьКолонку("Номенклатура"));
	
	тзАктуальныхПартий = ВетИС_ЯдроСервер.ПолучитьАктуальныеПартии(ПараметрыОрганизации, 
		СписокПродукцииЭлементов, 
		ПараметрыОрганизации.Отправитель_Площадка, 
		ПараметрыОрганизации.Отправитель_ХозСубъект,
		ПолеСортировкиПокупателя,
		ЗнакСортировкиПокупателя,
		СписокНоменклатуры);
	
	Если НЕ (ТипЗнч(тзАктуальныхПартий) = Тип("ТаблицаЗначений")) Тогда
		ВетИС_ЯдроСервер.СообщитьИнфо("Нет актуальных партий для создания Документов ");
		Возврат РаспределенныеПартии;
	КонецЕсли;
	
	УменьшитьАктуальныеПартииНаРаспределенные(тзАктуальныхПартий);
	
	Для Каждого стрНужныеПартии Из ВремПартии Цикл
		
		СтрокиПартий = ВетИС_ЯдроСервер.ПодобратьПартииПоПродукцияЭлемент(ПараметрыОрганизации, 
				тзАктуальныхПартий, 
				стрНужныеПартии.ВСД_Продукция_Элемент, 
				стрНужныеПартии.КоличествоСписания, 
				стрНужныеПартии.СерияНоменклатуры, 
				стрНужныеПартии.Номенклатура, 
				стрНужныеПартии.Контрагент);
				
		Если СтрокиПартий.Количество() = 0  Тогда
			НоваяСтрока = РаспределенныеПартии.Добавить();
			НоваяСтрока.Документ = стрНужныеПартии.Документ;
			НоваяСтрока.ТермическиеУсловияПеревозки = стрНужныеПартии.ТермУсловияПеревозки;
			НоваяСтрока.Номенклатура= стрНужныеПартии.Номенклатура;
			НоваяСтрока.Продукция_Элемент = стрНужныеПартии.ВСД_Продукция_Элемент;
			НоваяСтрока.КоличествоСписания = стрНужныеПартии.КоличествоСписания;
			НоваяСтрока.Количество = 0;
			НоваяСтрока.Остаток = 0;
			НоваяСтрока.ВидПродукции = стрНужныеПартии.ВидПродукции;
			Попытка
				НоваяСтрока.ПолеСортировки 		= ВетИС_APIСервер.ДатаXML(стрНужныеПартии.СерияНоменклатуры);
			Исключение
			КонецПопытки;
			ВетИС_ЯдроСервер.СообщитьИнфо("Нет партий для ["+стрНужныеПартии.ВСД_Продукция_Элемент +"]");
		   	Продолжить;
		КонецЕсли;
		
		Для Каждого СтрПартии Из СтрокиПартий Цикл
			НоваяСтрока = РаспределенныеПартии.Добавить();
			НоваяСтрока.Номенклатура= стрНужныеПартии.Номенклатура; 
			НоваяСтрока.Документ=стрНужныеПартии.Документ;
			НоваяСтрока.Партия = СтрПартии.Партия;
			НоваяСтрока.Продукция_Элемент = СтрПартии.Партия.Продукция_Элемент; 
			НоваяСтрока.Количество = СтрПартии.Количество; 
			НоваяСтрока.КоличествоСписания = СтрПартии.Количество;
			НоваяСтрока.ПолеСортировки 		= СтрПартии.ПолеСортировки;
			НоваяСтрока.ТермическиеУсловияПеревозки = стрНужныеПартии.ТермУсловияПеревозки;
			НоваяСтрока.Остаток = НоваяСтрока.Партия.Количество;
			НоваяСтрока.ВидПродукции = стрНужныеПартии.ВидПродукции;
		КонецЦикла;
		
		Если (СтрокиПартий.Итог("Количество") < стрНужныеПартии.КоличествоСписания) Тогда 
			НоваяСтрока = РаспределенныеПартии.Добавить();
			НоваяСтрока.Номенклатура= стрНужныеПартии.Номенклатура;
			НоваяСтрока.Документ=стрНужныеПартии.Документ;
			НоваяСтрока.Продукция_Элемент = стрНужныеПартии.ВСД_Продукция_Элемент;
			НоваяСтрока.КоличествоСписания	=  стрНужныеПартии.КоличествоСписания - СтрокиПартий.Итог("Количество") ;
			НоваяСтрока.ТермическиеУсловияПеревозки = стрНужныеПартии.ТермУсловияПеревозки;
			НоваяСтрока.ВидПродукции = стрНужныеПартии.ВидПродукции;
			Попытка
				НоваяСтрока.ПолеСортировки = ВетИС_APIСервер.ДатаXML(стрНужныеПартии.СерияНоменклатуры);
			Исключение
			КонецПопытки;
			НоваяСтрока.Количество = 0;
			НоваяСтрока.Остаток = 0;
		КонецЕсли;
	КонецЦикла;
	
	Возврат РаспределенныеПартии;
		
КонецФункции

&НаСервере
Процедура УменьшитьАктуальныеПартииНаРаспределенные(тзАктуальныхПартий)

	тз = Список.Выгрузить();
	тз.Свернуть("ДокументИнвентаризации, СтатусЗапроса", "");
	
	Для Каждого Строкатз Из Тз Цикл
		
		Если НЕ ЗначениеЗаполнено(Строкатз.ДокументИнвентаризации) Тогда
		    Продолжить;
		КонецЕсли;
		
		Если Строкатз.СтатусЗапроса = Перечисления.кб99_СтатусЗапроса.COMPLETED Тогда
		    Продолжить;
		КонецЕсли;
		
		тзДокВСД = Строкатз.ДокументИнвентаризации.Продукция.Выгрузить();
		тзДокВСД.Свернуть("Партия", "Количество");
		
		Для Каждого СтрокаВСД Из тзДокВСД Цикл
		    Если НЕ ЗначениеЗаполнено(СтрокаВСД.Партия) Тогда
		        Продолжить;
			КонецЕсли;
			
			НайденнаяСтрока = ТзАктуальныхПартий.Найти(СтрокаВСД.Партия, "Партия");

			Если НайденнаяСтрока <> Неопределено Тогда
    			НайденнаяСтрока.Количество = НайденнаяСтрока.Количество - (СтрокаВСД.Партия.Количество - СтрокаВСД.Количество);
				Если НайденнаяСтрока.Количество < 0  Тогда
					ВетИС_ЯдроСервер.СообщитьИнфо("В заполненных ранее ВСД на отправку обнаружено ПРЕВЫШЕНИЕ количества имеющейся партии по "+НайденнаяСтрока.Продукция_Элемент+"; (№ записи : "+СокрЛП(НайденнаяСтрока.Партия.НомерЗаписи)+") ; документ "+Строкатз.ДокументИнвентаризации);
					НайденнаяСтрока.Количество = 0;    
				КонецЕсли;
			КонецЕсли;
			
		КонецЦикла;
	КонецЦикла;
	
	НайденнаяСтрока = ТзАктуальныхПартий.Найти(0, "Количество");
	Пока НЕ(НайденнаяСтрока = Неопределено) Цикл
		ТзАктуальныхПартий.Удалить(НайденнаяСтрока);
		НайденнаяСтрока = ТзАктуальныхПартий.Найти(0,"Количество");
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти
