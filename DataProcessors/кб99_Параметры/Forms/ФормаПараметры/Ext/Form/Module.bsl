&НаСервере
Процедура кнЗаполнитьУсловияПеревозкиНаСервере()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВСД2_транзакцияУсловияПеревозки.Ссылка КАК ВСДДок
	|ИЗ
	|	Документ.ВСД2_транзакция.УсловияПеревозки КАК ВСД2_транзакцияУсловияПеревозки
	|ГДЕ
	|	ВСД2_транзакцияУсловияПеревозки.удалить_GUID <> """"
	|	И НЕ ВСД2_транзакцияУсловияПеревозки.Ссылка.ПометкаУдаления
	|
	|СГРУППИРОВАТЬ ПО
	|	ВСД2_транзакцияУсловияПеревозки.Ссылка";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		ДокОбъект = ВыборкаДетальныеЗаписи.ВСДДок.ПолучитьОбъект();
		
		ПустыеДанныеЗаполнения = Новый Структура("удалить_Название,удалить_GUID,удалить_UUID,удалить_ВидПродукции,удалить_Решение");
		
		Для Каждого Стр Из ДокОбъект.УсловияПеревозки Цикл
			
			ДанныеЗаполнения = Новый Структура();
			ДанныеЗаполнения.Вставить("Наименование", Стр.удалить_Название);
			ДанныеЗаполнения.Вставить("GUID", Стр.удалить_GUID);
			ДанныеЗаполнения.Вставить("UUID", Стр.удалить_UUID);
			ДанныеЗаполнения.Вставить("ВидПродукции", Стр.удалить_ВидПродукции);
			ДанныеЗаполнения.Вставить("Решение", Стр.удалить_Решение);
			
			УсловиеПеревозки = ВетИС_APIСервер.НайтиУсловияПеревозки(ДанныеЗаполнения);
			Если ЗначениеЗаполнено(УсловиеПеревозки) Тогда
				
				Стр.Условие = УсловиеПеревозки;
				ЗаполнитьЗначенияСвойств(Стр, ПустыеДанныеЗаполнения);
				
			КонецЕсли;
		КонецЦикла;
		
	КонецЦикла;
	
	ДокОбъект.Записать(РежимЗаписиДокумента.Запись);
	
КонецПроцедуры

&НаКлиенте
Процедура кнЗаполнитьУсловияПеревозки(Команда)
	
	Состояние("Выполняется обработка",, "Начало в " + ТекущаяДата() + " Подождите...", БиблиотекаКартинок.kb99_wrench);
	
	кнЗаполнитьУсловияПеревозкиНаСервере();
	
	ВетИС_ЯдроСервер.СообщитьПользователю("Обработка завершена " + ТекущаяДата());
	
КонецПроцедуры

&НаСервере
// Однократная миграция параметров из ХранилищеОбщихНастроек (устаревший способ хранения)
// в РегистрСведений.кб99_Параметры (текущий способ хранения).
// Вызывается командой "Перейти на новую версию параметров" — запускается один раз на организацию.
Процедура ЗагрузитьПараметрыИзХранилища()

	флСохранятьНастройкиДляТекущегоПользователя = Объект.флСохранятьНастройкиДляТекущегоПользователя;

	// Читаем настройки из старого хранилища напрямую (ВетИС_ЯдроСервер.ЗагрузитьПараметры_СтарыйВариант устарела)
	КлючОбъекта   = "Обработка.Интеграция_ГИС_Меркурий.Форма.ФормаУФ";
	ВладелецНастроек = ИмяПользователя();

	СписокКонстант = Неопределено;
	Попытка
		// Определяем способ хранения: на пользователя или на организацию
		флНаПользователя = ХранилищеОбщихНастроек.Загрузить(КлючОбъекта, "НастройкиВСДПоПользователю", , ВладелецНастроек);
		Если (флНаПользователя = Неопределено) Или НЕ флНаПользователя Тогда
			СписокКонстант = ХранилищеОбщихНастроек.Загрузить(
				КлючОбъекта,
				Объект.Организация.УникальныйИдентификатор(),
				,
				Объект.Организация.УникальныйИдентификатор());
		Иначе
			СписокКонстант = ХранилищеОбщихНастроек.Загрузить(
				КлючОбъекта,
				Объект.Организация.УникальныйИдентификатор(),
				,
				ВладелецНастроек);
		КонецЕсли;
	Исключение
		ВетИС_ЯдроСервер.СообщитьИнфо("Нет прав на восстановление настроек.");
	КонецПопытки;

	Если СписокКонстант = Неопределено Тогда
		ВетИС_ЯдроСервер.СообщитьИнфо("Не удалось загрузить настройки из хранилища для организации: " + Объект.Организация);
		Возврат;
	КонецЕсли;

	СписокКонстант.Вставить("Организация", Объект.Организация);
	СписокКонстант.Вставить("флСохранятьНастройкиДляТекущегоПользователя", флСохранятьНастройкиДляТекущегоПользователя);

	ВетИС_ЯдроСервер.ЗагрузитьПараметрыВОбработку(Объект, СписокКонстант);

	// Восстанавливаем текущее значение флага (не перезаписываем значением из старого хранилища)
	Объект.флСохранятьНастройкиДляТекущегоПользователя = флСохранятьНастройкиДляТекущегоПользователя;

КонецПроцедуры

&НаКлиенте
Процедура ПереходНаНовуюВерсиюПараметров(Команда)
	
	ЗагрузитьПараметрыИзХранилища();
	
КонецПроцедуры

&НаКлиенте
// @grace-contract: ВыборКаталога_Завершение
//   Вход: см. сигнатуру
//   Выход: нет
//   Исключение: нет
