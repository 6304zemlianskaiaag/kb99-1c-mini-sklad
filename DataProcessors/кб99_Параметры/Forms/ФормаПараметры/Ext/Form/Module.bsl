Процедура кнИнициализация(Команда)
	
	Если ПустаяСтрока(Объект.param_username) = 1 Тогда
		ПредупреждениеПользователю("Заполните параметр [param_username]");
		Возврат;
	КонецЕсли;
	Если ПустаяСтрока(Объект.param_password) = 1 Тогда
