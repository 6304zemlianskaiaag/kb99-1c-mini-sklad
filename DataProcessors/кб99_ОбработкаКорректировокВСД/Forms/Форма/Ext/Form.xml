		<Attribute name="СписокДокументов" id="2">
			<Title>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Список документов</v8:content>
				</v8:item>
			</Title>
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	ДокументКорректировкаРеализации.Ссылка КАК Основание,
	ВСД2_КорректировкаРеализации.Ссылка КАК КорректировкаВСД,
	ДокументКорректировкаРеализации.Организация КАК Организация,
	ДокументКорректировкаРеализации.Контрагент КАК Контрагент,
	ВЫБОР
		КОГДА ВСД2_КорректировкаРеализации.Ссылка ЕСТЬ NULL
			ТОГДА "Оформить"
		КОГДА ВСД2_КорректировкаРеализации.Обработан
			ТОГДА "Не требуется"
		ИНАЧЕ "Обработать"
	КОНЕЦ КАК ДальнейшееДействие
ИЗ
	Документ.КорректировкаРеализации КАК ДокументКорректировкаРеализации
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ВСД2_КорректировкаРеализации КАК ВСД2_КорректировкаРеализации
		ПО ДокументКорректировкаРеализации.Ссылка = ВСД2_КорректировкаРеализации.ДокументОснование
			И (НЕ ВСД2_КорректировкаРеализации.ПометкаУдаления)
ГДЕ
	ДокументКорректировкаРеализации.Проведен
	И ДокументКорректировкаРеализации.Дата МЕЖДУ &amp;НачалоПериода И &amp;ОкончаниеПериода
	И ВЫБОР
			КОГДА &amp;ОтборПоСтатусу = 1
				ТОГДА ИСТИНА
			КОГДА &amp;ОтборПоСтатусу = 2
				ТОГДА ВЫБОР
							КОГДА ВСД2_КорректировкаРеализации.Ссылка ЕСТЬ NULL
								ТОГДА "Оформить"
							КОГДА ВСД2_КорректировкаРеализации.Обработан
								ТОГДА "Не требуется"
							ИНАЧЕ "Обработать"
						КОНЕЦ = "Оформить"
						ИЛИ ВЫБОР
							КОГДА ВСД2_КорректировкаРеализации.Ссылка ЕСТЬ NULL
								ТОГДА "Оформить"
							КОГДА ВСД2_КорректировкаРеализации.Обработан
								ТОГДА "Не требуется"
							ИНАЧЕ "Обработать"
						КОНЕЦ = "Обработать"
			ИНАЧЕ ВЫБОР
					КОГДА ВСД2_КорректировкаРеализации.Ссылка ЕСТЬ NULL
						ТОГДА "Оформить"
					КОГДА ВСД2_КорректировкаРеализации.Обработан
						ТОГДА "Не требуется"
					ИНАЧЕ "Обработать"
				КОНЕЦ = "Не требуется"
		КОНЕЦ</QueryText>
				<MainTable>Document.ВСД2_КорректировкаРеализации</MainTable>
				<ListSettings>
					<dcsset:filter>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>dfcece9d-5077-440b-b6b3-45a5cb4538eb</dcsset:userSettingID>
					</dcsset:filter>
					<dcsset:order>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>88619765-ccb3-46c6-ac52-38e9c992ebd4</dcsset:userSettingID>
					</dcsset:order>
					<dcsset:conditionalAppearance>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>b75fecce-942b-4aed-abc9-e6a02e460fb3</dcsset:userSettingID>
					</dcsset:conditionalAppearance>
					<dcsset:itemsViewMode>Normal</dcsset:itemsViewMode>
					<dcsset:itemsUserSettingID>911b6018-f537-43e8-a417-da56b22f9aec</dcsset:itemsUserSettingID>
				</ListSettings>
			</Settings>
		</Attribute>
