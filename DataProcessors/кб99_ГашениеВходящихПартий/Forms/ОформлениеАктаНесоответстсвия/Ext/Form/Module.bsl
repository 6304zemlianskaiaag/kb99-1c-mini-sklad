// @grace-module: ГашениеВСД
// @grace-purpose: Форма оформления акта несоответствия при гашении входящих ВСД
// @grace-depends: ЯдроВСД, ИнтеграцияВетИС_API, РегистрыПартий
// @grace-version: 1.0
// @grace-contract-ref: docs/Contracts.xml -> module="ГашениеВСД"
// GRACE:DEPENDENCY target="кб99_ВСД"

&НаКлиенте
Процедура ЗаполнитьАкт(Команда)

	Отказ = Ложь;

	Если Не ЗначениеЗаполнено(ПричинаАкта) Тогда
		ВетИС_ЯдроСервер.СообщитьПользователю("Укажите причину составления акта",, "ПричинаАкта",, Отказ);
	КонецЕсли;

	Если Отказ Тогда
		Возврат;
	КонецЕсли;

	Результат = Новый Структура;
	Результат.Вставить("флАктНесоответствия", Истина);
	Результат.Вставить("тОписаниеНесоответствия", ОписаниеНесоответствия);
	Результат.Вставить("тПричинаАкта", ПричинаАкта);

	Закрыть(Результат);

КонецПроцедуры

// GRACE:MODULE_END name="ГашениеВСД"
