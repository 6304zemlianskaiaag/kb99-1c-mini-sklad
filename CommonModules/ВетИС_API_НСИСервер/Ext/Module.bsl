Функция ВСД_ЦельНайтиПоGuid(ЦельGuid) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВСД_Цель.Ссылка КАК Цель
	|ИЗ
	|	Справочник.ВСД_Цель КАК ВСД_Цель
	|ГДЕ
	|	ВСД_Цель.GUID ПОДОБНО &GUID
	|	И НЕ ВСД_Цель.ПометкаУдаления";
	Запрос.УстановитьПараметр("GUID", СокрЛП(ЦельGuid));
	
	Результат = Запрос.Выполнить().Выбрать();
	
	Если Результат.Следующий() Тогда
		Ответ = Результат.Цель;
	Иначе
		Ответ = Справочники.ВСД_Цель.ПустаяСсылка();
		ВетИС_APIСервер.СообщитьИнфо("Цель с Guid ["+ЦельGuid+"]не найдена, выполните инициализацию.");
	КонецЕсли;
	
	Возврат Ответ;
	
КонецФункции


