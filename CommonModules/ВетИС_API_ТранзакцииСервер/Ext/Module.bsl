// @grace-contract: ПолучитьРезервыПартийДругихДокументов
//   Вход: ДокСсылка (ДокументСсылка.ВСД2_транзакция) — текущий документ (исключается из подсчёта)
//   Выход: Соответствие (Партия → Количество) — суммы резервов по партиям за исключением текущего документа
//   Исключение: нет
// GRACE:CONTRACT function="ПолучитьРезервыПартийДругихДокументов"
Функция ПолучитьРезервыПартийДругихДокументов(ДокСсылка) Экспорт

	Результат = Новый Соответствие;

	тзПартии = ДокСсылка.Товары.Выгрузить();
	МассивПартий = тзПартии.ВыгрузитьКолонку("Партия");

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Резервы.Партия КАК Партия,
	|	СУММА(Резервы.Количество) КАК Количество
	|ИЗ
	|	РегистрНакопления.кб99_РезервПартийВСД КАК Резервы
	|ГДЕ
	|	Резервы.Партия В (&МассивПартий)
	|	И Резервы.Регистратор <> &ТекущийДокумент
	|	И Резервы.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|
	|СГРУППИРОВАТЬ ПО
	|	Резервы.Партия";

	Запрос.УстановитьПараметр("МассивПартий", МассивПартий);
	Запрос.УстановитьПараметр("ТекущийДокумент", ДокСсылка);

	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Результат.Вставить(Выборка.Партия, Выборка.Количество);
	КонецЦикла;

	Возврат Результат;

КонецФункции

#КонецОбласти

