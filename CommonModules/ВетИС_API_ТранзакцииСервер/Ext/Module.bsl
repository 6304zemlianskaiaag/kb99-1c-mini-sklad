// GRACE:MODULE_START name="ВетИС_API_ТранзакцииСервер"
// @grace-module: ВетИС_API_ТранзакцииСервер
// @grace-purpose: Транзакции ВСД2: отгрузка, производство, аннулирование, условия перевозки
// @grace-depends: ВетИС_APIСервер, ВетИС_УтилитыКлиентСервер, ВетИС_ПараметрыСервер
// @grace-version: 1.0
// @grace-contract-ref: docs/Contracts.xml -> module="ВетИС_API_ТранзакцииСервер"
// GRACE:DEPENDENCY target="ВетИС_APIСервер"
// GRACE:DEPENDENCY target="ВетИС_УтилитыКлиентСервер"
// GRACE:DEPENDENCY target="ВетИС_ПараметрыСервер"

Функция Выбрать_ВСД2(докОснование) Экспорт
	
	тзДок = Новый ТаблицаЗначений;
	тзДок.Колонки.Добавить("Док");
	
	Если НЕ(ЗначениеЗаполнено(докОснование)) Тогда
		Возврат тзДок;
	ИначеЕсли (ТипЗнч(ДокОснование) = Тип("ДокументСсылка.ВСД2")) Тогда
		СтрТЗ = тзДок.Добавить();
		СтрТЗ.Док = докОснование;
	Иначе
		Запрос = Новый Запрос;
		ТекстЗапроса =
		"ВЫБРАТЬ
		|ВСД.Ссылка КАК Док
		|ИЗ
		|Справочник.кб99_ВСД2 КАК ВСД
		|ГДЕ
		|ВСД.ДокументОснование = &ВыбТранзакция";
		
		Запрос.Текст = ТекстЗапроса;
		Запрос.УстановитьПараметр("ВыбТранзакция", докОснование);
		
		РезультатЗапроса = Запрос.Выполнить();
		тзДок = РезультатЗапроса.Выгрузить();
	КонецЕсли;
	
	Возврат тзДок;
	
КонецФункции

Функция ПолучитьСписокВСД2_ЗапросXML(ПараметрыЗапроса) Экспорт
	
	Если ЗначениеЗаполнено(ПараметрыЗапроса["Смещение"]) Тогда 
		Смещение = ПараметрыЗапроса["Смещение"];
	Иначе
		Смещение = 0;
	КонецЕсли;
	
	Запрос = "<SOAP-ENV:Envelope xmlns:dt='http://api.vetrf.ru/schema/cdm/dictionary/v2'
	|xmlns:bs='http://api.vetrf.ru/schema/cdm/base'
	|xmlns:merc='http://api.vetrf.ru/schema/cdm/mercury/g2b/applications/v2'
	|xmlns:apldef='http://api.vetrf.ru/schema/cdm/application/ws-definitions'
	|xmlns:apl='http://api.vetrf.ru/schema/cdm/application'
	|xmlns:vd='http://api.vetrf.ru/schema/cdm/mercury/vet-document/v2'
	|xmlns:SOAP-ENV='http://schemas.xmlsoap.org/soap/envelope/'>
	|<SOAP-ENV:Header/>
	|<SOAP-ENV:Body>
	|<apldef:submitApplicationRequest>
	|<apldef:apiKey>" + СокрЛП(ПараметрыЗапроса.Параметры["param_api_key"]) + "</apldef:apiKey>
	|<apl:application>
	|<apl:serviceId>mercury-g2b.service:2.1</apl:serviceId>
	|<apl:issuerId>" + СокрЛП(ПараметрыЗапроса.Параметры["param_issuer_id"]) + "</apl:issuerId>
	|<apl:issueDate>" + ВетИС_APIСервер.ДатаXML(ТекущаяДата(), "T00:00:00") + "</apl:issueDate>
	|<apl:data>
	|<merc:getVetDocumentListRequest>
	|<merc:localTransactionId>a1</merc:localTransactionId>
	|<merc:initiator>
	|<vd:login>" + СокрЛП(ПараметрыЗапроса.Параметры["param_intiator_login"]) + "</vd:login>
	|</merc:initiator>
	|<bs:listOptions>
	|<bs:count>1000</bs:count>
	|<bs:offset>" + Формат(Смещение, "ЧДЦ=0; ЧН=0; ЧГ=") + "</bs:offset>
	|</bs:listOptions>";
	
	Если ЗначениеЗаполнено(ПараметрыЗапроса["vetDocumentType"]) Тогда
		Запрос = Запрос + "
		|<vd:vetDocumentType>" + ПараметрыЗапроса["vetDocumentType"] + "</vd:vetDocumentType>";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПараметрыЗапроса["vetDocumentStatus"]) Тогда
		Запрос = Запрос + "
		|<vd:vetDocumentStatus>" + ПараметрыЗапроса["vetDocumentStatus"] + "</vd:vetDocumentStatus>";
	КонецЕсли;
	
	Если ПараметрыЗапроса.Свойство("ПоступилиС") И ЗначениеЗаполнено(ПараметрыЗапроса["ПоступилиС"]) Тогда
		Запрос = Запрос + "
		|<vd:issueDateInterval>
		|<bs:beginDate>" + ВетИС_APIСервер.ДатаXML(ПараметрыЗапроса["ПоступилиС"], "T00:00:00") + "</bs:beginDate>
		|<bs:endDate>" + ВетИС_APIСервер.ДатаXML(ПараметрыЗапроса["ПоступилиПо"], "T23:59:59") + "</bs:endDate>
		|</vd:issueDateInterval>";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПараметрыЗапроса["ОтправительХозСубъект"]) ИЛИ ЗначениеЗаполнено(ПараметрыЗапроса["ОтправительПлощадка"]) Тогда
		Запрос = Запрос + "
		|<vd:consignor>";
		
		Если ЗначениеЗаполнено(ПараметрыЗапроса["ОтправительХозСубъект"].GUID) Тогда
			Запрос = Запрос + "
			|<dt:businessEntity>
			|<bs:guid>" + ПараметрыЗапроса["ОтправительХозСубъект"].GUID + "</bs:guid>
			|</dt:businessEntity>";
		КонецЕсли;
		
		Если значениеЗаполнено(ПараметрыЗапроса["ОтправительПлощадка"].GUID) Тогда
			Запрос = Запрос + "
			|<dt:enterprise>
			|<bs:guid>" + ПараметрыЗапроса["ОтправительПлощадка"].GUID + "</bs:guid>
			|</dt:enterprise>";
		КонецЕсли;
		
		Запрос = Запрос + "
		|</vd:consignor>";
	КонецЕсли;
	
	Запрос = Запрос + "
	|<dt:enterpriseGuid>" + ПараметрыЗапроса["ПолучательПлощадка"].GUID + "</dt:enterpriseGuid>
	|</merc:getVetDocumentListRequest>
	|</apl:data>
	|</apl:application>
	|</apldef:submitApplicationRequest>
	|</SOAP-ENV:Body>
	|</SOAP-ENV:Envelope>";
	
	Возврат Запрос;
	
КонецФункции

Функция ПолучитьСписокВСД(ПараметрыФункции) Экспорт
	
	Если НЕ(ЗначениеЗаполнено(ПараметрыФункции.ПолучательПлощадка.GUID)) Тогда 
		ВетИС_APIСервер.СообщитьИнфо("В выбранной Площадке пустой GUID");
		Возврат Ложь;
	КонецЕсли;
	
	ЗапросXML = ПолучитьСписокВСД2_ЗапросXML(ПараметрыФункции);
	ПараметрыФункции.Вставить("ЗапросXML", ЗапросXML);
	Статус = ОтправитьЗапрос(ПараметрыФункции);
	
	Возврат Статус;
	
КонецФункции

Функция ВСД2_ЗагрузитьПоUUID_ЗапросXML(Параметры, док) Экспорт
	
	Запрос = "<SOAP-ENV:Envelope xmlns:dt='http://api.vetrf.ru/schema/cdm/dictionary/v2'
	|xmlns:bs='http://api.vetrf.ru/schema/cdm/base'
	|xmlns:merc='http://api.vetrf.ru/schema/cdm/mercury/g2b/applications/v2'
	|xmlns:apldef='http://api.vetrf.ru/schema/cdm/application/ws-definitions'
	|xmlns:apl='http://api.vetrf.ru/schema/cdm/application'
	|xmlns:vd='http://api.vetrf.ru/schema/cdm/mercury/vet-document/v2'
	|xmlns:SOAP-ENV='http://schemas.xmlsoap.org/soap/envelope/'>
	|<SOAP-ENV:Header/>
	|<SOAP-ENV:Body>
	|<apldef:submitApplicationRequest>
	|<apldef:apiKey>" + Параметры["param_api_key"] + "</apldef:apiKey>
	|<apl:application>
	|<apl:serviceId>mercury-g2b.service:2.1</apl:serviceId>
	|<apl:issuerId>" + Параметры["param_issuer_id"] + "</apl:issuerId>
	|<apl:issueDate>" + ВетИС_APIСервер.ДатаXML(ТекущаяДата(), "T00:00:00") + "</apl:issueDate>
	|<apl:data>
	|<merc:getVetDocumentByUuidRequest>
	|<merc:localTransactionId>[GUID]</merc:localTransactionId>
	|<merc:initiator>
	|<vd:login>" + Параметры["param_intiator_login"] + "</vd:login>
	|</merc:initiator>
	|<bs:uuid>" + СокрЛП(док.UUID) + "</bs:uuid>
	|<dt:enterpriseGuid>" + СокрЛП(Док.Отправитель_Площадка.GUID) + "</dt:enterpriseGuid>
	|</merc:getVetDocumentByUuidRequest>
	|</apl:data>
	|</apl:application>
	|</apldef:submitApplicationRequest>
	|</SOAP-ENV:Body>
	|</SOAP-ENV:Envelope>";
	
	Возврат Запрос;
	
КонецФункции

Функция ВСД2_ЗагрузитьПоUUID(Знач Параметры, докОснование) Экспорт
	
	тзВСД = Выбрать_ВСД2(докОснование);
	Для Каждого строкаВСД ИЗ тзВСД Цикл
		
		Если НЕ(ЗначениеЗаполнено(строкаВСД.Док.UUID)) Тогда 
			ВетИС_APIСервер.СообщитьИнфо("Пустой UUID в документе " + строкаВСД.Док);
			Возврат Ложь;
		КонецЕсли;
		
		ЗапросXML = ВСД2_ЗагрузитьПоUUID_ЗапросXML(Параметры, строкаВСД.Док);
		ПараметрыФункции = Новый Структура();
		ПараметрыФункции.Вставить("Параметры", Параметры);
		ПараметрыФункции.Вставить("ЗапросXML", ЗапросXML);
		ПараметрыФункции.Вставить("докОснование", строкаВСД.Док);
		Статус = ОтправитьЗапрос(ПараметрыФункции);
		
	КонецЦикла;
	
КонецФункции

Процедура ОбновитьСтатусыВСД(Знач СписокВСД, Знач ПараметрыИнтеграции) Экспорт
	
	Для Каждого СсылкаВСД Из СписокВСД Цикл
		
		Если Не ЗначениеЗаполнено(СсылкаВСД) Тогда
			Продолжить;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(СсылкаВСД.UUID) Тогда
			Продолжить;
		КонецЕсли;
		
		ЗапросXML = ВСД2_ЗагрузитьПоUUID_ЗапросXML(ПараметрыИнтеграции, СсылкаВСД);
		
		ПараметрыФункции = Новый Структура();
		ПараметрыФункции.Вставить("Параметры", ПараметрыИнтеграции);
		ПараметрыФункции.Вставить("ЗапросXML", ЗапросXML);
		ПараметрыФункции.Вставить("докОснование", СсылкаВСД);
		
		ОтправитьЗапрос(ПараметрыФункции);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ОбновитьСтатусыВСД_Фон(Знач Параметры, Знач АдресХранилища) Экспорт
	
	ОбновитьСтатусыВСД(Параметры.СписокВСД, Параметры.ПараметрыИнтеграции);
	
КонецПроцедуры

Процедура ОбновитьИРаспределитьВСД_Фон(Знач Параметры, Знач АдресХранилища) Экспорт
	
	ДокументКорректировки = Параметры.ДокументКорректировки;
	ДокументРеализации = Параметры.ДокументРеализации;
	Организация = Параметры.Организация;
	Контрагент = Параметры.Контрагент;
	
	ПараметрыИнтеграции = ВетИС_ЯдроСервер.ЗагрузитьПараметры(Организация);
	
	// 1. Получаем список номенклатуры из корректировки
	ЗапросТовары = Новый Запрос;
	Если ВетИС_УтилитыКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДокументКорректировки, "Расхождения") Тогда
		ТекстЗапроса = 
			"ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	КорректировкаРеализацииТовары.Номенклатура КАК Номенклатура
			|ИЗ
			|	Документ.КорректировкаРеализации.Расхождения КАК КорректировкаРеализацииТовары
			|ГДЕ
			|	КорректировкаРеализацииТовары.Ссылка = &Ссылка;";
	Иначе
		ТекстЗапроса = 
			"ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	КорректировкаРеализацииТовары.Номенклатура КАК Номенклатура
			|ИЗ
			|	Документ.КорректировкаРеализации.Товары КАК КорректировкаРеализацииТовары
			|ГДЕ
			|	КорректировкаРеализацииТовары.Ссылка = &Ссылка
			|	И КорректировкаРеализацииТовары.Количество <> КорректировкаРеализацииТовары.КоличествоДоИзменения";
	КонецЕсли;
	
	ЗапросТовары.Текст = ТекстЗапроса;
	ЗапросТовары.УстановитьПараметр("Ссылка", ДокументКорректировки);
	РезультатТовары = ЗапросТовары.Выполнить();
	
	СписокПродукцииМеркурий = Новый Массив;
	Если Не РезультатТовары.Пустой() Тогда
		Выборка = РезультатТовары.Выбрать();
		Пока Выборка.Следующий() Цикл
			МассивСоответствий = ВетИС_ЯдроСервер.Продукция_Элемент_ПолучитьСписок_ПоНоменклатуреИКонтрагенту(Выборка.Номенклатура, Контрагент);
			Для Каждого Элемент Из МассивСоответствий Цикл
				Если СписокПродукцииМеркурий.Найти(Элемент) = Неопределено Тогда
					СписокПродукцииМеркурий.Добавить(Элемент);
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;
	
	Если СписокПродукцииМеркурий.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	// 2. Получаем все оформленные ВСД по реализации и продукции
	ЗапросВСД = Новый Запрос;
		ЗапросВСД.Текст = 
			"ВЫБРАТЬ
			|	кб99_ВСД2.Ссылка КАК ВСД,
			|	кб99_ВСД2.UUID КАК UUID,
			|	ВСД2_транзакцияТовары.ИдентификаторСтроки КАК ИдентификаторСтроки,
			|	ВСД2_транзакцияТовары.Номенклатура КАК Номенклатура,
			|	ВСД2_транзакция.Ссылка КАК ВСД2_транзакция,
			|	кб99_ВСД2.Отправитель_ХозСубъект КАК НашаХС,
			|	кб99_ВСД2.Отправитель_Площадка КАК НашаПлощадка,
			|	кб99_ВСД2.Получатель_Площадка КАК ПлощадкаКлиента,
			|	кб99_ВСД2.Получатель_ХозСубъект КАК ХСКлиента
			|ИЗ
			|	Документ.ВСД2_транзакция КАК ВСД2_транзакция
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.кб99_ВСД2 КАК кб99_ВСД2
			|		ПО ВСД2_транзакция.Ссылка = кб99_ВСД2.ДокументОснование
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВСД2_транзакция.Товары КАК ВСД2_транзакцияТовары
			|		ПО ВСД2_транзакция.Ссылка = ВСД2_транзакцияТовары.Ссылка
			|			И кб99_ВСД2.Продукция_Элемент = ВСД2_транзакцияТовары.Продукция_Элемент
			|ГДЕ
			|	ВСД2_транзакция.ДокументОснование = &ДокументРеализации
			|	И ВСД2_транзакция.ПометкаУдаления = ЛОЖЬ
			|	И кб99_ВСД2.Продукция_Элемент В(&СписокПродукцииМеркурий)";
	
	ЗапросВСД.УстановитьПараметр("ДокументРеализации", ДокументРеализации);
	ЗапросВСД.УстановитьПараметр("СписокПродукцииМеркурий", СписокПродукцииМеркурий);
	
	ТаблицаВСД = ЗапросВСД.Выполнить().Выгрузить();
	Если ТаблицаВСД.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	СписокДляОбновления = ТаблицаВСД.ВыгрузитьКолонку("ВСД");
	
	// 3. Обновляем статусы в Меркурии
	ОбновитьСтатусыВСД(СписокДляОбновления, ПараметрыИнтеграции);
	
	// 4. Распределяем по табличным частям
	ДанныеРезультата = Новый Структура;
	ДанныеРезультата.Вставить("ВСДКАннулированию", Новый Массив);
	ДанныеРезультата.Вставить("ВСДКГашению", Новый Массив);
	
	// Подготовка данных для шапки документа
	ДанныеШапки = Новый Структура;
	ПерваяСтр = ТаблицаВСД[0];
	ДанныеШапки.Вставить("Отправитель_ХозСубъект", ПерваяСтр.НашаХС);
	ДанныеШапки.Вставить("Отправитель_Площадка",   ПерваяСтр.НашаПлощадка);
	ДанныеШапки.Вставить("Получатель_ХозСубъект", ПерваяСтр.ХСКлиента);
	ДанныеШапки.Вставить("Получатель_Площадка",    ПерваяСтр.ПлощадкаКлиента);
	ДанныеРезультата.Вставить("ДанныеШапки", ДанныеШапки);
	
	ЕстьПогашенные = Ложь;
	Для Каждого Стр Из ТаблицаВСД Цикл
		
		АктуальныйСтатус = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Стр.ВСД, "СтатусВСД");
		
		СтруктураСтроки = Новый Структура;
		СтруктураСтроки.Вставить("ВСД", Стр.ВСД);
		СтруктураСтроки.Вставить("СтатусВСД", АктуальныйСтатус);
		СтруктураСтроки.Вставить("ИдентификаторСтроки", Стр.ИдентификаторСтроки);
		СтруктураСтроки.Вставить("Номенклатура", Стр.Номенклатура);
		СтруктураСтроки.Вставить("ВСД2_транзакция", Стр.ВСД2_транзакция);
		
		Если АктуальныйСтатус = Перечисления.кб99_СтатусВСД.CONFIRMED Тогда
			ДанныеРезультата.ВСДКАннулированию.Добавить(СтруктураСтроки);
		ИначеЕсли АктуальныйСтатус = Перечисления.кб99_СтатусВСД.UTILIZED Тогда
			ЕстьПогашенные = Истина;
		КонецЕсли;
		
	КонецЦикла;
	
	// 5. Если есть погашенные, ищем возвратные ВСД
	Если ЕстьПогашенные Тогда
		
		ПараметрыЗапроса = Новый Структура;
		ПараметрыЗапроса.Вставить("vetDocumentType",   "RETURNABLE");
		ПараметрыЗапроса.Вставить("vetDocumentStatus", "CONFIRMED");
		ПараметрыЗапроса.Вставить("Смещение",          0);
		ПараметрыЗапроса.Вставить("ОтправительХозСубъект", ДанныеШапки.Получатель_ХозСубъект);
		ПараметрыЗапроса.Вставить("ОтправительПлощадка",   ДанныеШапки.Получатель_Площадка);
		ПараметрыЗапроса.Вставить("ПолучательПлощадка",    ДанныеШапки.Отправитель_Площадка);
		ПараметрыЗапроса.Вставить("ДокОснование",          Неопределено);
		ПараметрыЗапроса.Вставить("Параметры",             ПараметрыИнтеграции);
		
		ПолучитьСписокВСД(ПараметрыЗапроса);
		
		// Собираем ссылки на созданные/найденные возвратные ВСД
		СписокСсылокВозвратов = Новый Массив;
		Если ПараметрыЗапроса.Свойство("ВсдРезультатМассив") Тогда
			Для Каждого СтрВсд Из ПараметрыЗапроса.ВсдРезультатМассив Цикл
				Если ЗначениеЗаполнено(СтрВсд.ДокВСД) Тогда
					СписокСсылокВозвратов.Добавить(СтрВсд.ДокВСД);
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
		Если СписокСсылокВозвратов.Количество() > 0 Тогда
			
			// Ищем полученные возвраты в базе для получения связей с транзакциями
			ЗапросВозвраты = Новый Запрос;
						ЗапросВозвраты.Текст = 
							"ВЫБРАТЬ
							|	кб99_ВСД2.Ссылка КАК ВСД,
							|	кб99_ВСД2.СтатусВСД КАК СтатусВСД,
							|	МАКСИМУМ(ВСД2_транзакцияТовары.ИдентификаторСтроки) КАК ИдентификаторСтроки,
							|	МАКСИМУМ(ВСД2_транзакцияТовары.Номенклатура) КАК Номенклатура,
							|	ВСД2_транзакция.Ссылка КАК ВСД2_транзакция
							|ИЗ
							|	Справочник.кб99_ВСД2 КАК кб99_ВСД2
							|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВСД2_транзакция КАК ВСД2_транзакция
							|		ПО (кб99_ВСД2.ТтнНомер = (ВЫРАЗИТЬ(ВСД2_транзакция.ТтнНомер КАК СТРОКА(255))))
							|			И кб99_ВСД2.ТтнДата = ВСД2_транзакция.ТтнДата
							|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВСД2_транзакция.Товары КАК ВСД2_транзакцияТовары
							|		ПО (ВСД2_транзакция.Ссылка = ВСД2_транзакцияТовары.Ссылка)
							|			И кб99_ВСД2.Продукция_Элемент = ВСД2_транзакцияТовары.Продукция_Элемент
							|ГДЕ
							|	кб99_ВСД2.Ссылка В(&СписокСсылокВозвратов)
							|
							|СГРУППИРОВАТЬ ПО
							|	ВСД2_транзакция.Ссылка,
							|	кб99_ВСД2.Ссылка,
							|	кб99_ВСД2.СтатусВСД";
			
			ЗапросВозвраты.УстановитьПараметр("СписокСсылокВозвратов", СписокСсылокВозвратов);
			РезультатВозвраты = ЗапросВозвраты.Выполнить();
			
			Если Не РезультатВозвраты.Пустой() Тогда
				Выборка = РезультатВозвраты.Выбрать();
				Пока Выборка.Следующий() Цикл
								СтруктураСтроки = Новый Структура;
								СтруктураСтроки.Вставить("ВСД", Выборка.ВСД);
								СтруктураСтроки.Вставить("СтатусВСД", Выборка.СтатусВСД);
								СтруктураСтроки.Вставить("ИдентификаторСтроки", Выборка.ИдентификаторСтроки);
								СтруктураСтроки.Вставить("Номенклатура", Выборка.Номенклатура);
								СтруктураСтроки.Вставить("ВСД2_транзакция", Выборка.ВСД2_транзакция);
								ДанныеРезультата.ВСДКГашению.Добавить(СтруктураСтроки);
				КонецЦикла;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	// Помещаем результат в хранилище
	ПоместитьВоВременноеХранилище(ДанныеРезультата, АдресХранилища);
	
КонецПроцедуры

Функция ПолучитьИнформациюОпроисхожденииВСД(СтрокаТЧ, ПараметрыОрганизации) Экспорт
	
	Попытка
		ЗаголовокHTTP = Новый Соответствие();
		ЗаголовокHTTP.Вставить("Content-type", "text/xml; charset=utf-8");
		
		АдресСервисаПроверкиВСД = кб99_ВСД_Отправка.ПутьКСерверуСИнформациейПоВСД(ПараметрыОрганизации);
		Соединение = Новый HTTPСоединение(АдресСервисаПроверкиВСД,,,,,, Новый ЗащищенноеСоединениеOpenSSL());
		HTTPЗапрос = Новый HTTPЗапрос("/pub/operatorui?_action=findVetDocumentFormByUuid&uuid=" + СтрокаТЧ.UUID, ЗаголовокHTTP);
		
		Результат = Соединение.Получить(HTTPЗапрос);
		Ответ = Результат.ПолучитьТелоКакСтроку();
		
		ЧтениеХТМЛ = Новый ЧтениеHTML;
		ПостроительДОМ = Новый ПостроительDOM;
		
		ЧтениеХТМЛ.УстановитьСтроку(Ответ, "UTF-8");
		ДокументХТМЛ = ПостроительДОМ.Прочитать(ЧтениеХТМЛ);
		
		ЭлементыDIV = ДокументХТМЛ.ПолучитьЭлементыПоИмени("DIV");
		
		ДанныеОДокументе = Неопределено;
		
		Для Каждого Элем Из ЭлементыDIV Цикл
			Если Элем.ТекстовоеСодержимое = "Номер и дата производственного ВСД" Тогда
				ДанныеОДокументе = Элем.СледующийСоседний.ТекстовоеСодержимое;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Если ЗначениеЗаполнено(ДанныеОДокументе) Тогда
			СписокДокументов = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ДанныеОДокументе, ";", Ложь);
			СтруктураДок = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(СписокДокументов[СписокДокументов.Количество() - 1], " ", Истина);
			
			НомерПроизводства = СтруктураДок[1];
			ДатаОтвет = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(СтруктураДок[3], ".", Ложь);
			Число = ДатаОтвет[0];
			Месяц = ДатаОтвет[1];
			Год = ДатаОтвет[2];
			
			ДатаПроизводства = Дата(Год, Месяц, Число);
			ДатаИзготовления = ВетИС_APIСервер.СтрокаВДатаВремя(СтрокаТЧ.ДатаИзготовления1);
			
			МаксимальноеОтклонениеОтДатыПроизводства = ?(ПараметрыОрганизации.ВходящиеПроверятьДатуИзготовленияКоличествоДней = 0, 1, ПараметрыОрганизации.ВходящиеПроверятьДатуИзготовленияКоличествоДней);
			
			Если ДатаПроизводства < ДатаИзготовления Тогда
				ВетИС_ЯдроСервер.СообщитьИнфо(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("В ВСД [%1] дата изготовления больше даты производственной транзакции. Дата изготовления: %2, дата производственной транзакции: %3", 
				СтрокаТЧ.НаименованиеПродукции, Формат(ДатаИзготовления, "ДЛФ=D"), Формат(ДатаПроизводства, "ДЛФ=D")), СтрокаТЧ.ДокВСД);
				Ошибка = "Дата изготовления позже даты производства";
				СтрокаТЧ.Ошибки = ?(ЗначениеЗаполнено(СтрокаТЧ.Ошибки), СтрокаТЧ.Ошибки + ", " + Ошибка, Ошибка);
			ИначеЕсли ДатаПроизводства - ДатаИзготовления > МаксимальноеОтклонениеОтДатыПроизводства * 86400 Тогда
				ВетИС_ЯдроСервер.СообщитьИнфо(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("В ВСД [%1] дата изготовления меньше даты производства более %2 суток. Дата изготовления: %3, дата производственной транзакции: %4", 
				СтрокаТЧ.НаименованиеПродукции, МаксимальноеОтклонениеОтДатыПроизводства, Формат(ДатаИзготовления, "ДЛФ=D"), Формат(ДатаПроизводства, "ДЛФ=D")), СтрокаТЧ.ДокВСД);
				Ошибка = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("Дата изготовления раньше даты производства более %1 суток", МаксимальноеОтклонениеОтДатыПроизводства);
				СтрокаТЧ.Ошибки = ?(ЗначениеЗаполнено(СтрокаТЧ.Ошибки), СтрокаТЧ.Ошибки + ", " + Ошибка, Ошибка);
			КонецЕсли;
		Иначе
			ВетИС_ЯдроСервер.СообщитьИнфо(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("В ВСД [%1] нет данных о происхождении продукции", СтрокаТЧ.НаименованиеПродукции), СтрокаТЧ.ДокВСД);
			Ошибка = "Нет данных о производственном ВСД";
			СтрокаТЧ.Ошибки = ?(ЗначениеЗаполнено(СтрокаТЧ.Ошибки), СтрокаТЧ.Ошибки + ", " + Ошибка, Ошибка);
		КонецЕсли;
	Исключение
		ВетИС_ЯдроСервер.СообщитьИнфо("Не удалось получить данные о производственном документе");
		ЗаписьЖурналаРегистрации("Ошибка при получении документа о происхождении продукции",
		УровеньЖурналаРегистрации.Предупреждение, , , ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
	
КонецФункции

Функция ВСД2_транзакция_ЗапросXML(Параметры, ДокСсылка) Экспорт
	
	Запрос_Шапка = "<SOAP-ENV:Envelope
	|xmlns:dt='http://api.vetrf.ru/schema/cdm/dictionary/v2'
	|xmlns:bs='http://api.vetrf.ru/schema/cdm/base'
	|xmlns:merc='http://api.vetrf.ru/schema/cdm/mercury/g2b/applications/v2'
	|xmlns:apldef='http://api.vetrf.ru/schema/cdm/application/ws-definitions'
	|xmlns:apl='http://api.vetrf.ru/schema/cdm/application'
	|xmlns:vd='http://api.vetrf.ru/schema/cdm/mercury/vet-document/v2'
	|xmlns:SOAP-ENV='http://schemas.xmlsoap.org/soap/envelope/'>
	|<SOAP-ENV:Header/>
	|<SOAP-ENV:Body>
	|<apldef:submitApplicationRequest>
	|<apldef:apiKey>" + СокрЛП(Параметры["param_api_key"]) + "</apldef:apiKey>
	|<apl:application>
	|<apl:serviceId>mercury-g2b.service:2.1</apl:serviceId>
	|<apl:issuerId>" + СокрЛП(Параметры["param_issuer_id"]) + "</apl:issuerId>
	|<apl:issueDate>" + ВетИС_APIСервер.ДатаXML(ДокСсылка.Дата, "T00:00:00") + "</apl:issueDate>
	|<apl:data>
	|<merc:prepareOutgoingConsignmentRequest>
	|<merc:localTransactionId>" + СокрЛП(ДокСсылка.Номер) + "</merc:localTransactionId>
	|<merc:initiator>
	|<vd:login>" + СокрЛП(Параметры["param_intiator_login"]) + "</vd:login>
	|</merc:initiator>
	|";
	
	//************************
	// Есть/нет ТТН
	ДатаДоставки = ?(ЗначениеЗаполнено(ДокСсылка.ТтнДата), ДокСсылка.ТтнДата, ДокСсылка.Дата);
	
	delivery = "
	|<merc:delivery>
	|<vd:deliveryDate>" + ВетИС_APIСервер.ДатаXML(ДатаДоставки, "T00:00:00") + "</vd:deliveryDate>
	|<vd:consignor>
	|<dt:businessEntity>
	|<bs:guid>" + СокрЛП(ДокСсылка.Отправитель_ХозСубъект.GUID) + "</bs:guid>
	|</dt:businessEntity>
	|<dt:enterprise>
	|<bs:guid>" + СокрЛП(ДокСсылка.Отправитель_Площадка.GUID) + "</bs:guid>
	|</dt:enterprise>
	|</vd:consignor>
	|<vd:consignee>
	|<dt:businessEntity>
	|<bs:guid>" + СокрЛП(ДокСсылка.Получатель_ХозСубъект.GUID) + "</bs:guid>
	|</dt:businessEntity>
	|<dt:enterprise>
	|<bs:guid>" + СокрЛП(ДокСсылка.Получатель_Площадка.GUID) + "</bs:guid>
	|</dt:enterprise>";
	
	// <dt:globalID>4607009526782</dt:globalID> 	dt:GLNType 	[0..*]  [ ... ] Global Location Number - уникальный номер площадки
	delivery = delivery + "
	|</vd:consignee>";
	
	consignment = "";
	
	тз = ДокСсылка.Товары.Выгрузить();
	Для А = 0 По тз.Количество() - 1 Цикл
		СтрокаДокумента = тз[А];
		consignment = consignment + "
		|<vd:consignment id='_" + (А + 1) + "'>";
		
		consignment = consignment + ВетИС_API_ПартииСервер.ProductItem_в_XML(СтрокаДокумента, 1);
		consignment = consignment + "
		|<vd:volume>" + Формат(СтрокаДокумента.Количество, "ЧРД=.; ЧГ=0;ЧН=0") + "</vd:volume>
		|<vd:unit>
		|<bs:guid>" + СокрЛП(СтрокаДокумента.ЕдиницаИзмерения.GUID) + "</bs:guid>
		|</vd:unit>
		|";
		
		consignment = consignment + "
		|<vd:lowGradeCargo>" + ВетИС_APIСервер.НашеБулево(СтрокаДокумента.Некачественный) + "</vd:lowGradeCargo>";
		
		тзУпаковка = ДокСсылка.УровниУпаковки.Выгрузить();
		тзМаркировка = ДокСсылка.Маркировка.Выгрузить();
		consignment = consignment + ВетИС_API_ПартииСервер.УровниУпаковки_в_XML(СтрокаДокумента.КлючСтроки, тзУпаковка, тзМаркировка);
		
		Если ЗначениеЗаполнено(СтрокаДокумента.ВидПроисхожденияНеПищевойПродукции) Тогда
			consignment = consignment + "
			|<vd:applicableClassifications>
			|	<vd:nonFoodSource>" + ВетИС_APIСервер.ПолучитьИдентификаторПеречисления(СтрокаДокумента.ВидПроисхожденияНеПищевойПродукции) + "</vd:nonFoodSource>
			|</vd:applicableClassifications>
			|";
		КонецЕсли;
		
		consignment = consignment + "
		|<vd:sourceStockEntry>
		|<bs:guid>" + СокрЛП(СтрокаДокумента.Партия.GUID) + "</bs:guid>
		|</vd:sourceStockEntry>
		|</vd:consignment>
		|";
	КонецЦикла; // по строкам документа
	
	ЗапросДоставка = "";
	Если ЗначениеЗаполнено(ДокСсылка.Перевозчик_ХозСубъект) Тогда
		ЗапросДоставка = "
		|<vd:broker>
		|<bs:guid>" + СокрЛП(ДокСсылка.Перевозчик_ХозСубъект.GUID) + "</bs:guid>
		|</vd:broker>";
	КонецЕсли;
	
	ЗапросДоставка = ЗапросДоставка + "
	|<vd:transportInfo>
	|<vd:transportType>1</vd:transportType>
	|<vd:transportNumber>
	|<vd:vehicleNumber>" + СокрЛП(ДокСсылка.номерАвто) + "</vd:vehicleNumber>";
	
	Если ЗначениеЗаполнено(ДокСсылка.НомерПрицепа) Тогда
		ЗапросДоставка = ЗапросДоставка + "
		|<vd:trailerNumber>" + СокрЛП(ДокСсылка.НомерПрицепа) + "</vd:trailerNumber>";
	КонецЕсли;
	
	ЗапросДоставка = ЗапросДоставка + "
	|</vd:transportNumber>
	|</vd:transportInfo>
	|<vd:transportStorageType>" + XMLСтрока(ДокСсылка.ТермическиеУсловияПеревозки) + "</vd:transportStorageType>";
	
	ЗапросДоставка = ЗапросДоставка + "
	|<vd:shipmentRoute>
	|" + Запрос_МаршрутДоставки(ДокСсылка) + "
	|</vd:shipmentRoute>";
	
	ЗапросПодвал = "";
	ЗапросПодвал = ЗапросПодвал + " 
	|<vd:accompanyingForms>";
	
	Если ЗначениеЗаполнено(ДокСсылка.ТтнДата) Тогда
		// Тип товарно-транспортной накладной.
		// Допустимые типы Для waybill: 1, 2, 3, 4, 5
		ЗапросПодвал = ЗапросПодвал + "
		|<vd:waybill>
		|<vd:issueSeries>" + СокрЛП(ДокСсылка.ТтнСерия) + "</vd:issueSeries>
		|<vd:issueNumber>" + СокрЛП(ДокСсылка.ТтнНомер) + "</vd:issueNumber>
		|<vd:issueDate>" + ВетИС_APIСервер.ДатаXML(ДокСсылка.ТтнДата) + "</vd:issueDate>
		|<vd:type>1</vd:type>      
		|</vd:waybill>";
	КонецЕсли;
	
	// !!! Цели в ТЧ документа
	Для А = 0 По тз.Количество() - 1 Цикл
		СтрокаДокумента = тз[А];
		ЗапросПодвал = ЗапросПодвал + "
		|<vd:vetCertificate for='_" + (А + 1) + "'>
		|<vd:authentication>
		|<vd:purpose>
		|<bs:guid>" + ?(ЗначениеЗаполнено(СтрокаДокумента.Цель), (СтрокаДокумента.Цель.Guid), Параметры["ВСДЦель"].Guid) + "</bs:guid>		
		|</vd:purpose>
		|<vd:cargoInspected>" + ВетИС_APIСервер.НашеБулево(ДокСсылка.cargoInspected) + "</vd:cargoInspected>
		|<vd:cargoExpertized>" + ВетИС_APIСервер.ПолучитьИдентификаторПеречисления(СтрокаДокумента.РезультатыИсследований) + "</vd:cargoExpertized>
		|<vd:locationProsperity>" + СокрЛП(ДокСсылка.Местность) + "</vd:locationProsperity>";
		
		// Регионализация  - ДОРАБОТКА по ВИДУ ПРОДУКЦИИ
		тзУсловияПеревозки = ДокСсылка.УсловияПеревозки.Выгрузить();
		Если ЗначениеЗаполнено(тзУсловияПеревозки) Тогда
			Для каждого стрУсловия ИЗ тзУсловияПеревозки Цикл
				Если стрУсловия.Отметка 
						И стрУсловия.Условие.ВидПродукции = СтрокаДокумента.Продукция_Элемент.ВидПродукции Тогда
					ЗапросПодвал = ЗапросПодвал + "
					|<vd:r13nClause>
					|<vd:condition>
					|<bs:guid>" + стрУсловия.Условие.GUID + "</bs:guid>
					|</vd:condition>
					|</vd:r13nClause>
					|";
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтрокаДокумента.ОсобыеОтметки) Тогда
			ОсобыеОтметки = СтрокаДокумента.ОсобыеОтметки + "; ";
		Иначе
			ОсобыеОтметки = "";
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДокСсылка.ОсобыеОтметки) Тогда
			ОсобыеОтметки = ОсобыеОтметки + ДокСсылка.ОсобыеОтметки;
		КонецЕсли;
		
		Если Параметры.ДобавлятьОсобыеОтметкиИзВходящегоВСД Тогда
			Если ЗначениеЗаполнено(ОсобыеОтметки) Тогда
				ОсобыеОтметки = ОсобыеОтметки + "; " + СтрокаДокумента.Партия.vetDocument.ОсобыеОтметки;
			Иначе
				ОсобыеОтметки = СтрокаДокумента.Партия.vetDocument.ОсобыеОтметки;
			КонецЕсли;
		КонецЕсли;
		
		ЗапросПодвал = ЗапросПодвал + ?(ЗначениеЗаполнено(ОсобыеОтметки), "<vd:specialMarks>" + СокрЛП(ОсобыеОтметки) + "</vd:specialMarks>", "");
		
		ЗапросПодвал = ЗапросПодвал + "
		|</vd:authentication>
		|</vd:vetCertificate>";
	КонецЦикла;
	
	// Связанные документы
	// http://help.vetrf.ru/wiki/DocumentType_v2.0
	// тип 16 = Заказ, 6 = ТОРГ12,  1 = ТрН
	//        |<vd:issueSeries>А</vd:issueSeries>
	//        |<vd:issueDate>2017-09-26</vd:issueDate>
	
	СвязанныеДокументы = "";
	Если ЗначениеЗаполнено(ДокСсылка.НомерЗаказаПокупателя) Тогда
		СвязанныеДокументы = "
		|<vd:relatedDocument>
		|<vd:issueNumber>" + СокрЛП(ДокСсылка.НомерЗаказаПокупателя) + "</vd:issueNumber>
		|<vd:issueDate>" + ВетИС_APIСервер.ДатаXML(ДокСсылка.ДатаЗаказаПокупателя) + "</vd:issueDate>
		|<vd:type>16</vd:type>
		|<vd:relationshipType>1</vd:relationshipType>
		|</vd:relatedDocument>";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДокСсылка.ТОРГ12Номер) Тогда
		СвязанныеДокументы = СвязанныеДокументы + "
		|<vd:relatedDocument>
		|<vd:issueNumber>" + СокрЛП(ДокСсылка.ТОРГ12Номер) + "</vd:issueNumber>
		|<vd:issueDate>" + ВетИС_APIСервер.ДатаXML(ДокСсылка.ТОРГ12Дата) + "</vd:issueDate>
		|<vd:type>6</vd:type>
		|<vd:relationshipType>1</vd:relationshipType>
		|</vd:relatedDocument>";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДокСсылка.УпдНомер) Тогда
		СвязанныеДокументы = СвязанныеДокументы + "
		|<vd:relatedDocument>
		|<vd:issueNumber>" + СокрЛП(ДокСсылка.УпдНомер) + "</vd:issueNumber>
		|<vd:issueDate>" + ВетИС_APIСервер.ДатаXML(ДокСсылка.УпдДата) + "</vd:issueDate>
		|<vd:type>23</vd:type>
		|<vd:relationshipType>1</vd:relationshipType>
		|</vd:relatedDocument>";
	КонецЕсли;
	
	Для А = 0 По тз.Количество() - 1 Цикл
		СтрокаДокумента = тз[А];
		Если ЗначениеЗаполнено(СтрокаДокумента.UUID_ВСД) Тогда
			СвязанныеДокументы = СвязанныеДокументы + "
			|<vd:relatedDocument for='_" + (А + 1) + "'>
			|<vd:issueNumber>" + СокрЛП(СтрокаДокумента.UUID_ВСД) + "</vd:issueNumber>
			|<vd:issueDate>" + ВетИС_APIСервер.ДатаXML(ДокСсылка.ДокументОснование.Дата) + "</vd:issueDate>
			|<vd:type>11</vd:type>
			|<vd:relationshipType>2</vd:relationshipType>
			|</vd:relatedDocument>";
		КонецЕсли
	КонецЦикла;
	
	Если ЗначениеЗаполнено(СвязанныеДокументы) Тогда
		ЗапросПодвал = ЗапросПодвал + СвязанныеДокументы;
	КонецЕсли;
	
	ЗапросПодвал = ЗапросПодвал + "
	|</vd:accompanyingForms>
	|</merc:delivery>
	|</merc:prepareOutgoingConsignmentRequest>
	|</apl:data>
	|</apl:application>
	|</apldef:submitApplicationRequest>
	|</SOAP-ENV:Body>
	|</SOAP-ENV:Envelope>";
	
	Запрос = Запрос_Шапка +
	delivery +
	consignment +
	?(ДокСсылка.СменаСобственностиБезПеревозки, "", ЗапросДоставка) +
	ЗапросПодвал;
	
	Возврат Запрос;
	
КонецФункции

Функция ПроверитьЗаполнениеДокумента(ДокСсылка, ПараметрыОрганизации) Экспорт
	
	Докобъект = ДокСсылка.ПолучитьОбъект();
	Ответ = ДокОбъект.ПроверитьЗаполнение();
	
	ЗапросВетис = ВетИС_УтилитыКлиентСервер.НайтиПоследнийЗапрос(ДокСсылка);
	//Если ( ЗапросВетис.СтатусЗапроса = "IN_PROCESS")
	//		Или ( ЗапросВетис.СтатусЗапроса = "ACCEPTED")	Тогда 
	Если ЗапросВетис.СтатусЗапросаПеречисление = Перечисления.кб99_СтатусЗапроса.IN_PROCESS ИЛИ
		ЗапросВетис.СтатусЗапросаПеречисление = Перечисления.кб99_СтатусЗапроса.ACCEPTED Тогда
		ВетИС_APIСервер.СообщитьИнфо("Последний запрос отправлен, но ответ не получен, статус запроса = " + ЗапросВетис.СтатусЗапроса + ". Получите ответ Ветис", ДокСсылка);
		Ответ = Ложь;
	КонецЕсли;
	
	Возврат Ответ;
	
КонецФункции

Процедура ЗафиксироватьОшибку(СообщениеОбОшибке, ДокСсылка) Экспорт
	
	ВетИС_APIСервер.СообщитьИнфо(СообщениеОбОшибке, ДокСсылка);
	
	МенеджерЗаписи = РегистрыСведений.кб99_Запросы.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.Период = ТекущаяДата();
	МенеджерЗаписи.Объект = ДокСсылка;
	//МенеджерЗаписи.ApplicationID = ApplicationID;
	//МенеджерЗаписи.СтатусЗапроса = Статус;
	МенеджерЗаписи.СтатусЗапросаПеречисление = Перечисления.кб99_СтатусЗапроса.REJECTED;
	МенеджерЗаписи.Пользователь = ВетИС_ПараметрыСервер.ПолучитьТекущегоПользователя();
	МенеджерЗаписи.Ошибки = СообщениеОбОшибке;
	МенеджерЗаписи.Записать();
	
КонецПроцедуры

Функция ПроверитьЗаполнениеДокументаТранзакция(ДокСсылка, ПараметрыОрганизации) Экспорт
	
	Если ТипЗнч(ДокСсылка) = Тип("СправочникСсылка.кб99_ВСД2") Тогда
		Возврат Истина;
	КонецЕсли;
	
	Ответ = ПроверитьЗаполнениеДокумента(ДокСсылка, ПараметрыОрганизации);
	
	Если Не ВетИС_ПараметрыСервер.ПроверитьЗначениеПараметра(ПараметрыОрганизации, 
		"КонтролироватьПравильностьЗаполненияНомераАвтомобиля") Тогда
		Возврат Ложь;
	Иначе
		ПроверятьНомерАвто = ПараметрыОрганизации.КонтролироватьПравильностьЗаполненияНомераАвтомобиля;
	КонецЕсли;
	
	ОписаниеОшибки = "";
	
	Если ДокСсылка.СтатусВСД = Перечисления.кб99_СтатусВСД.CONFIRMED ИЛИ 
		ДокСсылка.СтатусВСД = Перечисления.кб99_СтатусВСД.UTILIZED Тогда
		
		ОписаниеОшибки = ОписаниеОшибки + "Запрещена повторная отправка оформленного ВСД" + Символы.ПС;
		Ответ = Ложь;
	КонецЕсли;
	
	Если Не ДокСсылка.СменаСобственностиБезПеревозки Тогда
		Если Не ЗначениеЗаполнено(ДокСсылка.НомерАвто) Тогда
			ОписаниеОшибки = ОписаниеОшибки + "Не заполнен номер автомобиля." + Символы.ПС;
			Ответ = Ложь;
		КонецЕсли;
		
		Если ПроверятьНомерАвто И Ответ = Истина Тогда
			ОписаниеОшибки = ОписаниеОшибки + ПроверитьНомерАвтомобиля(Ответ, ДокСсылка);
		КонецЕсли;
	Иначе
		Если ДокСсылка.Отправитель_Площадка.guid <> ДокСсылка.Получатель_Площадка.guid Тогда
			ОписаниеОшибки = ОписаниеОшибки + "Различаются GUID площадок отправителя и получателя. Смена владельца без перевозки не возможна!" + Символы.ПС;
			Ответ = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	тзПартии = ДокСсылка.Товары.Выгрузить();

	// Контроль резервов: получаем суммы резервов других документов по партиям
	КонтролироватьРезервы = ВетИС_ПараметрыСервер.ПроверитьЗначениеПараметра(ПараметрыОрганизации,
		"КонтролироватьРезервыПартий") И ПараметрыОрганизации["КонтролироватьРезервыПартий"];
	Если КонтролироватьРезервы Тогда
		РезервыДругих = ПолучитьРезервыПартийДругихДокументов(ДокСсылка);
	Иначе
		РезервыДругих = Новый Соответствие;
	КонецЕсли;

	Для Каждого Стр Из тзПартии Цикл
		РезервДругих = РезервыДругих[Стр.Партия];
		Если РезервДругих = Неопределено Тогда
			РезервДругих = 0;
		КонецЕсли;
		СвободныйОстаток = Стр.Партия.Количество - РезервДругих;
		Если Стр.Количество > СвободныйОстаток Тогда
			Ответ = Ложь;
			ОписаниеОшибки = ОписаниеОшибки + "В строке " + Стр.НомерСтроки + " количество списания (" + Стр.Количество + ") превышает свободный остаток партии (" + СвободныйОстаток + ")" + Символы.ПС;
		КонецЕсли;
	КонецЦикла;
	
	Если ПараметрыОрганизации["ПарамКонтроллироватьСрокГодностиПриОтправке"] Тогда 
		Для Каждого Стр Из тзПартии Цикл
			ДатаСрокГодности2 = ВетИС_APIСервер.СтрокаВДатаВремя(Стр.Партия.ДатаСрокГодности2);
			ДатаСрокГодности1 = ВетИС_APIСервер.СтрокаВДатаВремя(Стр.Партия.ДатаСрокГодности1);
			Если ЗначениеЗаполнено(ДатаСрокГодности1) Тогда 
				Если ДатаСрокГодности1 - ПараметрыОрганизации["СрокГодностиДней"] * 86400 <= ТекущаяДата() Тогда
					ОписаниеОшибки = ОписаниеОшибки + "Выбрана партия с недопустимым сроком годности: " + ДатаСрокГодности1 + " (менее " + ПараметрыОрганизации["СрокГодностиДней"] + " дней до окончания срока) в строке " + Стр.НомерСтроки + "!" + Символы.ПС;
					Ответ = Ложь;
				КонецЕсли;
			КонецЕсли
		КонецЦикла;
	КонецЕсли;
	
	Если ПараметрыОрганизации["ПарамКонтроллироватьЗаполнениеУровнейУпаковки"] Тогда
		тзПартии = ДокСсылка.Товары.Выгрузить();
		Для Каждого Стр Из тзПартии Цикл
			ПараметрыОтбора = Новый Структура("СтрокаПродукции", Стр.КлючСтроки);
			Уровни = ДокСсылка.УровниУпаковки.НайтиСтроки(ПараметрыОтбора);
			Если Уровни.Количество() < 1 Тогда
				Ответ = Ложь;
				ОписаниеОшибки = ОписаниеОшибки + "Не заполнен ни один уровень упаковки для продукции в строке " + Стр.НомерСтроки + Символы.ПС;
			Иначе
				Маркировка = ДокСсылка.Маркировка.НайтиСтроки(ПараметрыОтбора);
				Если Маркировка.Количество() < 1 Тогда
					Ответ = Ложь;
					ОписаниеОшибки = ОписаниеОшибки + "Не указана маркировка упаковки для продукции в строке " + Стр.НомерСтроки + Символы.ПС;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Если Не Ответ Тогда 
		ЗафиксироватьОшибку(ОписаниеОшибки + "в документе " + ДокСсылка, ДокСсылка);
	КонецЕсли;
	
	Возврат Ответ;
	
КонецФункции

Функция ПроверитьЗаполнениеДокументаПроизводство(ДокСсылка, ПараметрыОрганизации) Экспорт
	
	Ответ = ПроверитьЗаполнениеДокумента(ДокСсылка, ПараметрыОрганизации);
	
	ЗапросВетис = ВетИС_УтилитыКлиентСервер.НайтиПоследнийЗапрос(ДокСсылка);
	Если ДокСсылка.Проведен И
		//И (ЗапросВетис.СтатусЗапроса = "COMPLETED") Тогда 
		ЗапросВетис.СтатусЗапросаПеречисление = Перечисления.кб99_СтатусЗапроса.COMPLETED Тогда
		ВетИС_APIСервер.СообщитьИнфо("Запрещена повторная отправка оформленного ВСД", ДокСсылка);
		Ответ = Ложь;
	КонецЕсли;
	
	тзПартии = ДокСсылка.ПартииСписания.Выгрузить();
	ИмяТабличнойЧасти = "[Партии списания]";
	ПроверитьПроизводствоПередОтправкой(Ответ, ПараметрыОрганизации, ДокСсылка, тзПартии);
	
	Для Каждого Стр Из ДокСсылка.Продукция Цикл
		Если Стр.Продукция_Элемент.ПометкаУдаления Тогда
			Ответ = Ложь;
			Комментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("В табличной части «Продукция» в строке №%1 выбран элемент, помеченный на удаление", Стр.НомерСтроки);
			ВетИС_ЯдроСервер.СообщитьИнфо(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("В документе %1 %2", ДокСсылка, Комментарий));	
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого Стр Из тзПартии Цикл
		Если Стр.Количество > Стр.Партия.Количество Тогда
			Ответ = Ложь;
			Комментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("В табличной части %1 в строке %2 количество списания превышает остаток партии", ИмяТабличнойЧасти, Стр.НомерСтроки);
			ВетИС_ЯдроСервер.СообщитьИнфо(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("В документе %1 %2", ДокСсылка, Комментарий));
		КонецЕсли;
	КонецЦикла;
	
	Если ПараметрыОрганизации["ПарамКонтроллироватьСрокГодностиПриОтправке"] Тогда 
		Для Каждого Стр Из тзПартии Цикл
			ДатаСрокГодности2 = ВетИС_APIСервер.СтрокаВДатаВремя(Стр.Партия.ДатаСрокГодности2);
			ДатаСрокГодности1 = ВетИС_APIСервер.СтрокаВДатаВремя(Стр.Партия.ДатаСрокГодности1);
			Если ЗначениеЗаполнено(ДатаСрокГодности1) Тогда 
				Если ДатаСрокГодности1 - ПараметрыОрганизации["СрокГодностиДней"] * 86400 <= ТекущаяДата() Тогда
					ВетИС_ЯдроСервер.СообщитьИнфо("Выбрана просроченная партия по срокам годности: " + ДатаСрокГодности1 + " (менее " + ПараметрыОрганизации["СрокГодностиДней"] + " дней до окончания срока) в строке " + Стр.НомерСтроки + "!", ДокСсылка);
					Ответ = Ложь;
				КонецЕсли;
			КонецЕсли
		КонецЦикла;
	КонецЕсли;
	
	Возврат Ответ;
	
КонецФункции

Функция ВСД2_транзакция_Отправить(ПараметрыФункции) Экспорт
	
	ДокСсылка = ПараметрыФункции.ДокОснование;
	
	Если НЕ ПроверитьЗаполнениеДокументаТранзакция(ДокСсылка, ПараметрыФункции.Параметры) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ЗапросXML = ВСД2_транзакция_ЗапросXML(ПараметрыФункции.Параметры, ДокСсылка);
	ПараметрыФункции.Вставить("ЗапросXML", ЗапросXML);
	
	Статус = ОтправитьЗапрос(ПараметрыФункции);
	
	Возврат Статус;
	
КонецФункции

Процедура СохранитьИПровестиУспешныйВСД(ПараметрыФункции) Экспорт
	
