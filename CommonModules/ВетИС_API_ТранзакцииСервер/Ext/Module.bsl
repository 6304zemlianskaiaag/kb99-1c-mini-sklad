		Возврат Ложь; 
	КонецЕсли;
	
	ЗапросXML = ВСД2_ОбновитьТранспорт_ЗапросXML( ПараметрыФункции.Параметры, ДокСсылка); 	
	ПараметрыФункции.Вставить( "ЗапросXML", ЗапросXML );	
	//Статус = ОтправитьЗапрос(Параметры, ДокСсылка, Истина, ЗапросXML );
