#Область РезервированиеПартий

// @grace-contract: СоздатьРезервПартий
//   Вход: ДокСсылка (ДокументСсылка.ВСД2_транзакция) — документ, для которого создаётся резерв
//   Выход: нет
//   Исключение: нет (ошибки логируются)
//   Инвариант: Очищает старые резервы по регистратору перед записью новых
//   GRACE-лог: ЛогВход, ЛогУспех
// GRACE:CONTRACT function="СоздатьРезервПартий"
// LLM_NOTE: Записывает Приход в РН кб99_РезервПартийВСД для каждой строки ТЧ Товары.
//           Вызывается из ПриЗаписи документа ВСД2_транзакция при КонтролироватьРезервыПартий=Истина.
//           НЕ привязана к проведению — пишет напрямую через НаборЗаписей.
Процедура СоздатьРезервПартий(ДокСсылка) Экспорт

	Если НЕ ЗначениеЗаполнено(ДокСсылка) Тогда
		Возврат;
	КонецЕсли;

	НаборЗаписей = РегистрыНакопления.кб99_РезервПартийВСД.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Регистратор.Установить(ДокСсылка);

	тзТовары = ДокСсылка.Товары.Выгрузить();
	Для Каждого Стр Из тзТовары Цикл
		Если НЕ ЗначениеЗаполнено(Стр.Партия) ИЛИ Стр.Количество <= 0 Тогда
			Продолжить;
		КонецЕсли;

		Запись = НаборЗаписей.Добавить();
		Запись.ВидДвижения = ВидДвиженияНакопления.Приход;
		Запись.Период = ТекущаяДата();
		Запись.Партия = Стр.Партия;
		Запись.Количество = Стр.Количество;
	КонецЦикла;

	НаборЗаписей.Записать(Истина);

КонецПроцедуры

