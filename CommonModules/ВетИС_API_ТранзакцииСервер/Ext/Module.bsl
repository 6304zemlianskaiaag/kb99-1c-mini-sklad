Процедура НайтиИЗавершитьРанееОформленныеНезавершенныеТранзакции(докСсылка) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВСД2_Производство.Ссылка КАК Док
	|ИЗ
	|	Документ.ВСД2_Производство КАК ВСД2_Производство
	|ГДЕ
	|	ВСД2_Производство.operationId ПОДОБНО &operationId
	|	И ВСД2_Производство.Ссылка <> &Ссылка
	|	И НЕ ВСД2_Производство.ПометкаУдаления";
	Запрос.УстановитьПараметр("operationId", ДокСсылка.operationId);
	Запрос.УстановитьПараметр("Ссылка", ДокСсылка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ДокОбъект = Выборка.Док.ПолучитьОбъект();
		ДокОбъект.ЗавершитьОперацию = Истина;
		ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
	КонецЦикла;
	
КонецПроцедуры

Процедура ПроверитьПроизводствоПередОтправкой(Результат, ПараметрыОрганизации, ДокСсылка, тзПартииСписания) Экспорт
	
	Комментарий = "";
	// Контроль наличия партий спсиания в вырабатываемой продукции
	СписываемоеСырье = тзПартииСписания.ВыгрузитьКолонку("Продукция_Элемент");
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.Текст = "ВЫБРАТЬ
	|	ВырабатываемаяПродукция.Продукция_Элемент КАК Продукция_Элемент
	|ПОМЕСТИТЬ втСырьеВПродукции
	|ИЗ
	|	&ВырабатываемаяПродукция КАК ВырабатываемаяПродукция
	|ГДЕ
	|	ВырабатываемаяПродукция.Продукция_Элемент В(&Продукция_Элемент)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПРЕДСТАВЛЕНИЕ(втСырьеВПродукции.Продукция_Элемент) КАК Продукция_Элемент
	|ИЗ
	|	втСырьеВПродукции КАК втСырьеВПродукции";
	Запрос.УстановитьПараметр("ВырабатываемаяПродукция", ДокСсылка.Продукция.Выгрузить());
	Запрос.УстановитьПараметр("Продукция_Элемент", СписываемоеСырье);
	РезультатЗапроса = Запрос.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
		Результат = Ложь;
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			Комментарий = Комментарий + " " + СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("Продукция ""%1"" присутствует в партиях списания и вырабатываемой продукции.", ВыборкаДетальныеЗаписи.Продукция_Элемент);
		КонецЦикла;
	КонецЕсли;
	
	// Запрос на продукцию по которой контролируется списываемое сырье
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СУММА(ВСД2_ПроизводствоПродукция.Количество) КАК КоличествоВырабатываемое,
	|	ВСД2_ПроизводствоПродукция.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ВСД2_Производство.Продукция КАК ВСД2_ПроизводствоПродукция
	|ГДЕ
	|	ВСД2_ПроизводствоПродукция.Ссылка = &Ссылка
	|	И НЕ ВСД2_ПроизводствоПродукция.Продукция_Элемент.НеКонтролироватьРасходСырья
	|
	|СГРУППИРОВАТЬ ПО
	|	ВСД2_ПроизводствоПродукция.Ссылка
	|";
	Запрос.УстановитьПараметр("Ссылка", ДокСсылка);
	РезультатЗапроса = Запрос.Выполнить();
	
	// Контроль не заполненной табличной части "Партии списания"
	Если ПараметрыОрганизации["ПроверятьЗаполнениеСырьяВПроизводстве"] И Не ЗначениеЗаполнено(тзПартииСписания)
		И Не РезультатЗапроса.Пустой() Тогда
		Результат = Ложь;
		Комментарий = Комментарий + " " + "Не указано сырье.";
	КонецЕсли;
	
	//Проверка баланса между количеством списываемого сырья и вырабатавыемой продукцией 
	Если ПараметрыОрганизации["ПроверятьБалансРасходаСырья"] И Не РезультатЗапроса.Пустой() Тогда
		Если тзПартииСписания.Количество() > 0 Тогда
			ВыборкаПоПродукции = РезультатЗапроса.Выбрать();
			ВыборкаПоПродукции.Следующий();
			ВырабатываемоеКоличество = ВыборкаПоПродукции.КоличествоВырабатываемое;
			СписываемоеКоличество = тзПартииСписания.Итог("Количество");
			А = ВырабатываемоеКоличество;
			Б = СписываемоеКоличество;
			Разница = ОКР(Макс(Б / А - 1, -(Б / А - 1)) * 100, 2, 1);
			
			Если Разница > ПараметрыОрганизации["ПроцентРасхожденияСырьеПродукция"] Тогда
				Результат = Ложь;
				Комментарий = Комментарий + " " + СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("Нарушен допустимый процент расхождения [Кол-во вырабатываемое / Кол-во списания]. Разрешено: %1%, расхождение: %2%",
				ПараметрыОрганизации["ПроцентРасхожденияСырьеПродукция"],
				Разница);
			КонецЕсли;
		Иначе
			Результат = Ложь;
			Комментарий = Комментарий + " " + СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("Нарушен допустимый процент расхождения [Кол-во вырабатываемое / Кол-во списания]. Разрешено: %1%, расхождение: 100%",
			ПараметрыОрганизации["ПроцентРасхожденияСырьеПродукция"]);
		КонецЕсли;
	КонецЕсли;
	
	//Проверка превышения срока годности вырабатываемой продукции над сроками годности сырья
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	ВСД2_ПроизводствоПродукция.Продукция_Элемент.КонтролироватьСрокиПриФасовке КАК КонтролироватьСрокиПриФасовке,
	|	ВСД2_ПроизводствоПродукция.ДатаСрокГодности1 КАК СрокГодности,
	|	ВСД2_ПроизводствоПродукция.НомерСтроки КАК НомерСтроки,
	|	ВСД2_ПроизводствоПродукция.Продукция_Элемент.СрокГодности КАК СрокГодностиДней,
	|	ВСД2_ПроизводствоПродукция.Продукция_Элемент.Наименование КАК Продукция
	|ИЗ
	|	Документ.ВСД2_Производство.Продукция КАК ВСД2_ПроизводствоПродукция
	|ГДЕ
	|	ВСД2_ПроизводствоПродукция.Ссылка = &Ссылка
	|	И ВСД2_ПроизводствоПродукция.Продукция_Элемент.КонтролироватьСрокиПриФасовке
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МИНИМУМ(ВСД2_ПроизводствоПартииСписания.Партия.ДатаСрокГодности1) КАК СрокГодности
	|ИЗ
	|	Документ.ВСД2_Производство.ПартииСписания КАК ВСД2_ПроизводствоПартииСписания
	|ГДЕ
	|	ВСД2_ПроизводствоПартииСписания.Ссылка = &Ссылка";

	Запрос.УстановитьПараметр("Ссылка", ДокСсылка);

	РезультатЗапроса = Запрос.ВыполнитьПакет();
	Если Не РезультатЗапроса[0].Пустой() Тогда
		
		ВыборкаПоСырью = РезультатЗапроса[1].Выбрать();
		ВыборкаПоСырью.Следующий();
		
		Если Не ЗначениеЗаполнено(ВыборкаПоСырью.СрокГодности) Тогда
			Результат = Ложь;
			Комментарий = Комментарий + " Не заполнены партии списания";
		Иначе
			
			МинСрокГодностиСырья = ВетИС_APIСервер.СтрокаВДату(ВыборкаПоСырью.СрокГодности);
			СтрокиДляКонтроля = РезультатЗапроса[0].Выбрать();
			//СтрокиКИзменениюСроков = Новый Массив;
			
			Пока СтрокиДляКонтроля.Следующий() Цикл
				//КонтрольныйСрокГодности = ТекущаяДатаСеанса() + СтрокиДляКонтроля.СрокГодностиДней * 86400;
				КонтрольныйСрокГодности = СтрокиДляКонтроля.СрокГодности;
				Если КонтрольныйСрокГодности > МинСрокГодностиСырья Тогда
					Результат = Ложь;
					Комментарий = Комментарий + СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(" Срок годности [%1] по продукции ""%2"" превышает минимальный срок годности [%3] сырья", 
						Формат(КонтрольныйСрокГодности, "ДФ=dd.MM.yyyy"), СтрокиДляКонтроля.Продукция, Формат(МинСрокГодностиСырья, "ДФ=dd.MM.yyyy"));
				//Иначе
				//	
				//	Если СтрокиДляКонтроля.СрокГодности > МинСрокГодностиСырья Тогда
				//		СтруктураСтроки = Новый Структура(); 
				//		СтруктураСтроки.Вставить("НомерСтроки",  СтрокиДляКонтроля.НомерСтроки);
				//		СтруктураСтроки.Вставить("СрокГодностиДо", СтрокиДляКонтроля.СрокГодности);
				//		СтруктураСтроки.Вставить("СрокГодности", МинСрокГодностиСырья);
				//		
				//		СтрокиКИзменениюСроков.Добавить(СтруктураСтроки);
				//	КонецЕсли;
					
				КонецЕсли;
			КонецЦикла;
			
			//Если СтрокиКИзменениюСроков.Количество() Тогда
			//	ВетИС_ЯдроСервер.СообщитьИнфо("Изменение сроков годности в документе " + ДокСсылка);
			//	ДокОбъект = ДокСсылка.ПолучитьОбъект();
			//	Для Каждого Стр Из СтрокиКИзменениюСроков Цикл 
			//		ДокОбъект.Продукция[Стр.НомерСтроки - 1].ДатаСрокГодности1 = Стр.СрокГодности;
			//		ВетИС_ЯдроСервер.СообщитьИнфо(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("В строке %1 изменен срок годности %2 -> %3",
			//			Стр.НомерСтроки, Формат(Стр.СрокГодностиДо, "ДФ=dd.MM.yyyy"), Формат(Стр.СрокГодности, "ДФ=dd.MM.yyyy")));
			//	КонецЦикла;
			//	ДокОбъект.Записать();
			//КонецЕсли;
				
		КонецЕсли;
			
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Комментарий) Тогда
		ВетИС_ЯдроСервер.СообщитьИнфо(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("В документе %1 содержаться ошибки: %2. Документ не отправлен.", ДокСсылка, СокрЛП(Комментарий)));
		
		ДокОбъект = ДокСсылка.ПолучитьОбъект();
		ДокОбъект.Комментарий = СокрЛП(Комментарий);
		ДокОбъект.Записать();
	КонецЕсли;
	
КонецПроцедуры

Функция ВСД2_ЛабораторныеИсследования_ЗапросXML(Параметры, ДокСсылка) Экспорт
	
	Запрос = "<SOAP-ENV:Envelope xmlns:dt='http://api.vetrf.ru/schema/cdm/dictionary/v2'
	|xmlns:bs='http://api.vetrf.ru/schema/cdm/base'
	|xmlns:merc='http://api.vetrf.ru/schema/cdm/mercury/g2b/applications/v2'
	|xmlns:apldef='http://api.vetrf.ru/schema/cdm/application/ws-definitions'
	|xmlns:apl='http://api.vetrf.ru/schema/cdm/application'
	|xmlns:vd='http://api.vetrf.ru/schema/cdm/mercury/vet-document/v2'
	|xmlns:SOAP-ENV='http://schemas.xmlsoap.org/soap/envelope/'>
	|<SOAP-ENV:Header/>
	|<SOAP-ENV:Body>
	|<apldef:submitApplicationRequest>
	|<apldef:apiKey>" + СокрЛП(Параметры["param_api_key"]) + "</apldef:apiKey>
	|<apl:application>
	|<apl:serviceId>mercury-g2b.service:2.1</apl:serviceId>
	|<apl:issuerId>" + СокрЛП(Параметры["param_issuer_id"]) + "</apl:issuerId>
	|<apl:issueDate>" + ВетИС_APIСервер.ДатаXML(ДокСсылка.Дата, "T00:00:00") + "</apl:issueDate>
	|<apl:data>
	|<merc:updateVeterinaryEventsRequest>
	|<merc:localTransactionId>" + СокрЛП(ДокСсылка.Номер) + "</merc:localTransactionId>
	|<merc:initiator>
	|<vd:login>" + СокрЛП(Параметры["param_vetdoctor_login"]) + "</vd:login>
	|</merc:initiator>
	|<merc:enterprise>
	|<bs:guid>" + СокрЛП(ДокСсылка.Партия.Получатель_Площадка.GUID) + "</bs:guid>
	|</merc:enterprise>
	|<vd:stockEntry>
	|<bs:guid>" + СокрЛП(ДокСсылка.Партия.GUID) + "</bs:guid>
	|<vd:vetEventList>";
	
	Для каждого строкаДок ИЗ ДокСсылка.Исследования Цикл
		Запрос = Запрос + "
		|<vd:laboratoryResearch>
		|<vd:actualDateTime>" + ВетИС_APIСервер.ДатаXML(строкаДок.ДатаРезультата, "T00:00:00") + "</vd:actualDateTime>
		|<vd:operator>
		|<dt:name>" + ВетИС_APIСервер.ЗаменитьСпецСимволы(строкаДок.НаименованиеЛаборатории) + "</dt:name>
		|</vd:operator>
		|<vd:referencedDocument>";
		
		Если ЗначениеЗаполнено(строкаДок.НомерАктаОтбораПроб) Тогда
			Запрос = Запрос + "
			|<vd:issueNumber>" + СокрЛП(строкаДок.НомерАктаОтбораПроб) + "</vd:issueNumber>
			|<vd:issueDate>" + ВетИС_APIСервер.ДатаXML(строкаДок.ДатаОтбораПроб) + "</vd:issueDate>";
		КонецЕсли;
		
		Запрос = Запрос + "
		|<vd:type>9</vd:type>
		|</vd:referencedDocument>
		|<vd:expertiseID>" + СокрЛП(строкаДок.НомерЭкспертизы) + "</vd:expertiseID>
		|<vd:disease>
		|<dt:name>" + ВетИС_APIСервер.ЗаменитьСпецСимволы(строкаДок.НаименованиеПоказателя) + "</dt:name>
		|</vd:disease>";
		
		Если ЗначениеЗаполнено(строкаДок.МетодИсследования) Тогда
			Запрос = Запрос + "
			|<vd:method>
			|<dt:name>" + СокрЛП(строкаДок.МетодИсследования) + "</dt:name>
			|</vd:method>";
		КонецЕсли;
		
		Запрос = Запрос + "
		|<vd:result>" + ВетИС_APIСервер.ПолучитьИдентификаторПеречисления(строкаДок.РезультатИсследования) + "</vd:result>
		|<vd:conclusion>" + СокрЛП(строкаДок.Заключение) + "</vd:conclusion>
		|</vd:laboratoryResearch>";
	КонецЦикла;
	
	Запрос = Запрос + "
	|</vd:vetEventList>
	|</vd:stockEntry>
	|</merc:updateVeterinaryEventsRequest>
	|</apl:data>
	|</apl:application>
	|</apldef:submitApplicationRequest>
	|</SOAP-ENV:Body>
	|</SOAP-ENV:Envelope>";
	
	Возврат Запрос;
	
КонецФункции

Функция ВСД2_ЛабораторныеИсследования_Отправить( ПараметрыФункции ) Экспорт
	
	ДокСсылка = ПараметрыФункции.ДокОснование;
	Если НЕ ПроверитьЗаполнениеДокумента( ДокСсылка, ПараметрыФункции.Параметры ) Тогда 
		Возврат Ложь; 
	КонецЕсли;	
	
	ЗапросXML = ВСД2_ЛабораторныеИсследования_ЗапросXML( ПараметрыФункции.Параметры, ДокСсылка);
	ПараметрыФункции.Вставить( "ЗапросXML", ЗапросXML );	
	//Статус = ОтправитьЗапрос(Параметры, ДокСсылка, Истина, ЗапросXML );
	Статус = ОтправитьЗапрос( ПараметрыФункции );
	
	Возврат Статус;
	
КонецФункции

Функция ВСД2_ЛабораторныеИсследования_ОтправитьПараллельно(Знач Параметры, АдресХранилища = Неопределено) Экспорт
	
	ВетИС_APIСервер.СообщитьИнфо("Начало отправки лаб.исследований в Ветис");
	
	ДокСсылка = Неопределено;
	СписокДокументов = Неопределено;
	Параметры.Свойство("СписокДокументов", СписокДокументов);
	
	ПараметрыФункции = Новый Структура;
	ПараметрыФункции.Вставить("Параметры", Параметры);
	ПараметрыФункции.Вставить("ПолучитьОтветВетис", Ложь);
	
	// отправка
	СписокДокументовПолучитьОтвет = Новый Массив;
	Для Каждого ДокВСД Из СписокДокументов Цикл
		ПараметрыФункции.Вставить("ДокОснование", ДокВСД);
		
		Статус = ВСД2_ЛабораторныеИсследования_Отправить(ПараметрыФункции);
		
		Если Статус = Перечисления.кб99_СтатусЗапроса.ACCEPTED Тогда
			СписокДокументовПолучитьОтвет.Добавить(ДокВСД);
		КонецЕсли;
	КонецЦикла;
	
	ВетИС_APIСервер.Пауза(Параметры["ПаузаСек"]);
	
	// ответ 
	Для Каждого ДокСсылка Из СписокДокументовПолучитьОтвет Цикл
		appID = ВетИС_УтилитыКлиентСервер.НайтиApplicationID(ДокСсылка);
		ПараметрыФункции.Вставить("ApplicationID", appID);
		ПараметрыФункции.ДокОснование = ДокСсылка;
		ПараметрыФункции.Вставить("СделатьПаузу", Ложь);
		Статус = ПолучитьРезультат_ВСД2(ПараметрыФункции);
		
		Для А = 1 По 10 Цикл
			Если Статус = Перечисления.кб99_СтатусЗапроса.IN_PROCESS Тогда
				ПараметрыФункции.СделатьПаузу = Истина;
				Статус = ПолучитьРезультат_ВСД2(ПараметрыФункции);
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	//Если Статус = "COMPLETED" Тогда
	РезультатОбработки = Новый Структура();
	РезультатОбработки.Вставить("ЗаданиеВыполнено", Статус = Перечисления.кб99_СтатусЗапроса.COMPLETED);
	
	Если ЗначениеЗаполнено(АдресХранилища) Тогда
		ПоместитьВоВременноеХранилище(РезультатОбработки, АдресХранилища);
	КонецЕсли;
	
	ВетИС_APIСервер.СообщитьИнфо("Отправка лаб.исследований завершена " + Статус);
	Возврат РезультатОбработки;
	
КонецФункции

Функция ВСД2_ОбъединениеПартий_ЗапросXML( Параметры, ДокСсылка) Экспорт
	
	Запрос ="<SOAP-ENV:Envelope 
	|xmlns:dt='http://api.vetrf.ru/schema/cdm/dictionary/v2' 
	|xmlns:bs='http://api.vetrf.ru/schema/cdm/base' 
	|xmlns:merc='http://api.vetrf.ru/schema/cdm/mercury/g2b/applications/v2' 
	|xmlns:apldef='http://api.vetrf.ru/schema/cdm/application/ws-definitions' 
	|xmlns:apl='http://api.vetrf.ru/schema/cdm/application' 
	|xmlns:vd='http://api.vetrf.ru/schema/cdm/mercury/vet-document/v2' 
	|xmlns:SOAP-ENV='http://schemas.xmlsoap.org/soap/envelope/'>
	|<SOAP-ENV:Header/>
	|<SOAP-ENV:Body>
	|<apldef:submitApplicationRequest>
	|<apldef:apiKey>"+ СокрЛП( Параметры["param_api_key"] ) +"</apldef:apiKey>
	|<apl:application>
	|<apl:serviceId>mercury-g2b.service:2.1</apl:serviceId>
	|<apl:issuerId>"+ СокрЛП( Параметры["param_issuer_id"] ) +"</apl:issuerId>
	|<apl:issueDate>" + ВетИС_APIСервер.ДатаВремяXML(ДокСсылка.Дата) + "</apl:issueDate>
	|<apl:data>
	|<merc:mergeStockEntriesRequest>
	|<merc:localTransactionId>" + СокрЛП(ДокСсылка.Номер) + "</merc:localTransactionId>
	|<merc:initiator>
	|<vd:login>"+ СокрЛП( Параметры["param_intiator_login"] ) +"</vd:login>
	|</merc:initiator>
	|<merc:enterprise>
	|<bs:guid>"+ СокрЛП(ДокСсылка.Владелец_Площадка.GUID) +"</bs:guid>
	|</merc:enterprise>
	|<merc:mergeOperation>
	|<vd:type>"+?(ДокСсылка.ОперацияПрисоединения,"ATTACH","MERGE")+"</vd:type>";
	тз = ДокСсылка.Продукция.Выгрузить();
	Для Каждого СтрокаДокумента ИЗ тз Цикл
		Запрос=Запрос+"
		|<vd:sourceStockEntry>
		|<bs:uuid>" + СокрЛП(СтрокаДокумента.Партия.uuid) + "</bs:uuid>
		|</vd:sourceStockEntry>";
	КонецЦикла;		
	Если НЕ ДокСсылка.ОперацияПрисоединения Тогда
		Запрос=Запрос+"
		|<vd:resultStockEntry>
		|<vd:batch>
		|<vd:subProduct>
		|<bs:guid>"+ СокрЛП(ДокСсылка.ВидПродукции.GUID) +"</bs:guid>
		|</vd:subProduct>";
		Запрос = Запрос + "
		|<vd:productItem>";
		Если ЗначениеЗаполнено(ДокСсылка.Продукция_Элемент.guid) тогда
			Запрос = Запрос + "	
			|<bs:guid>" + СокрЛП(ДокСсылка.Продукция_Элемент.guid) + "</bs:guid>";
		КонецЕсли;        	
		Если ЗначениеЗаполнено(ДокСсылка.Продукция_Элемент.GTIN) тогда
			Запрос = Запрос + "	
			|<dt:globalID>" + СокрЛП(ДокСсылка.Продукция_Элемент.GTIN) + "</dt:globalID>";
		КонецЕсли;
		Запрос = Запрос + "
		|<dt:name>" + ВетИС_APIСервер.ЗаменитьСпецСимволы(ДокСсылка.Продукция_Элемент.Наименование) + "</dt:name>";
		Если ЗначениеЗаполнено(ДокСсылка.Продукция_Элемент.Артикул) тогда
			Запрос = Запрос + "	
			|<dt:code>" + СокрЛП(ДокСсылка.Продукция_Элемент.Артикул) + "</dt:code>";
		КонецЕсли;
		Запрос = Запрос + "
		|</vd:productItem>";
		Запрос=Запрос+"
		|</vd:batch>
		|</vd:resultStockEntry>";			
	КонецЕсли;
	Запрос=Запрос+"
	|</merc:mergeOperation>
	|</merc:mergeStockEntriesRequest>
	|</apl:data>
	|</apl:application>
	|</apldef:submitApplicationRequest>
	|</SOAP-ENV:Body>
	|</SOAP-ENV:Envelope>";
	
	Возврат Запрос;
	
