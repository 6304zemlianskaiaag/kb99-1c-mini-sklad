			//ИначеЕсли (ТипЗнч(ДокСсылка) = Тип("ДокументСсылка.ВСД2_Производство")) Тогда
			//Если ПараметрыФункции.Параметры.Свойство("ЗавершитьПроизводство") Тогда
			//ДокОбъект.ЗавершитьОперацию = Истина;
			//НайтиИЗавершитьРанееОформленныеНезавершенныеТранзакции( ДокСсылка );
			//КонецЕсли;
			//ДокОбъект.Записать( РежимЗаписиДокумента.Проведение );
		Иначе
			ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
		КонецЕсли;
	Исключение
		ВетИС_ЯдроСервер.кб99_СообщитьОбОшибке("Не удалось записать реквизиты запроса в " + докСсылка + " " + Символы.ПС + ОписаниеОшибки(), ДокСсылка);
	КонецПопытки;
	
КонецПроцедуры

Функция ПолучитьРезультат_ВСД2(ПараметрыФункции) Экспорт
	
	Параметры = ПараметрыФункции["Параметры"];
	
	ApplicationID = ПараметрыФункции.ApplicationID;
	Если ЗначениеЗаполнено(ApplicationID) Тогда
		xdto = кб99_ВСД_Отправка.ПолучитьРезультатСервер(Параметры, ApplicationID);
	Иначе
		ВетИС_APIСервер.СообщитьИнфо("Пустая ссылка applicationID");
		Возврат Ложь;
	КонецЕсли;
	
	Если ПараметрыФункции.Свойство("СделатьПаузу") Тогда
		СделатьПаузу = ПараметрыФункции["СделатьПаузу"];
	Иначе 
		СделатьПаузу = Истина;
	КонецЕсли;
	
	ДокСсылка = ПараметрыФункции["ДокОснование"];
	
	Если СделатьПаузу Тогда
		ВетИС_APIСервер.Пауза(Параметры["ПаузаСек"]);
	КонецЕсли;
	
	Статус = ВетИС_APIСервер.СтатусЗапроса(xdto, докСсылка, Параметры);
	Если ВетИС_APIСервер.НайтиОшибки(xdto, докСсылка) Тогда
		Возврат Статус;
	КонецЕсли;
	
	Попытка
		ПришлоВСД = Число(xdto.Body.receiveApplicationResultResponse.application.result.getVetDocumentListResponse.VetDocumentList.count);
	Исключение
		ПришлоВСД = 1;
	КонецПопытки;
	
	Если Статус = Перечисления.кб99_СтатусЗапроса.COMPLETED Тогда
		Попытка
			//ПараметрыФункции.Вставить("xdto", xdto);
			ЗагрузитьXML_ВСД2(ПараметрыФункции, xdto);
			ЗагрузитьXML_Партии2(ПараметрыФункции, xdto);
		Исключение
			ЗаписьЖурналаРегистрации(
			СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Ошибка при записи партий в документе %1'"), ДокСсылка),
			УровеньЖурналаРегистрации.Ошибка, , ,
			ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			ВетИС_APIСервер.СообщитьИнфо("Ошибка = " + ОписаниеОшибки());
		КонецПопытки;
		
		// сохраняем статус и проводим документ
		Если ЗначениеЗаполнено(ДокСсылка) Тогда
			СохранитьИПровестиУспешныйВСД(ПараметрыФункции);
		КонецЕсли;
	КонецЕсли;
	
	Если ПараметрыФункции.Свойство("Смещение") Тогда
		Если ПришлоВСД = 1000 Тогда
			Если ЗначениеЗаполнено(ПараметрыФункции["Смещение"]) Тогда
				ПараметрыФункции["Смещение"] = ПараметрыФункции["Смещение"] + 1000;
			Иначе
				ПараметрыФункции["Смещение"] = 1000;
			КонецЕсли;
			ПолучитьСписокВСД(ПараметрыФункции);
		КонецЕсли;
	КонецЕсли;
	
	Возврат Статус;
	
КонецФункции

Функция ЗагрузитьXML_Партии2(ПараметрыФункции, xdto) Экспорт
	
	//xdto = ПараметрыФункции.xdto;
	Параметры = ПараметрыФункции.Параметры;
	ДокСсылка = ПараметрыФункции.ДокОснование;
	
	Попытка 
		appResult = xdto.Body.receiveApplicationResultResponse.application.result;
	Исключение
		ВетИС_APIСервер.СообщитьИнфо("Партии отсутствуют в запросе");
		Возврат Ложь;
	КонецПопытки;
	
	Попытка
		Если НЕ(appResult.Свойства().Получить("prepareOutcomingConsignmentResponse") = Неопределено) Тогда
			seList = appResult.prepareOutcomingConsignmentResponse.StockEntry;
		ИначеЕсли НЕ(appResult.Свойства().Получить("prepareOutgoingConsignmentResponse") = Неопределено) Тогда
			//Транзакция
			seList = appResult.prepareOutgoingConsignmentResponse.StockEntry;
		ИначеЕсли НЕ(appResult.Свойства().Получить("processIncomingConsignmentResponse") = Неопределено) Тогда
			//Гашение
			seList = appResult.processIncomingConsignmentResponse.StockEntry;
		ИначеЕсли НЕ(appResult.Свойства().Получить("registerProductionOperationResponse") = Неопределено) Тогда
			// Выпуск
			seList = appResult.registerProductionOperationResponse.stockEntryList.StockEntry;
		ИначеЕсли НЕ(appResult.Свойства().Получить("withdrawVetDocumentResponse") = Неопределено) Тогда
			// Аннулирование
			seList = appResult.withdrawVetDocumentResponse.StockEntry;
		ИначеЕсли НЕ(appResult.Свойства().Получить("resolveDiscrepancyResponse") = Неопределено) Тогда
			// Инвентаризация
			seList = appResult.resolveDiscrepancyResponse.stockEntryList.StockEntry;
		ИначеЕсли НЕ(appResult.Свойства().Получить("mergeStockEntriesResponse") = Неопределено) Тогда
			// Объединение Партий
			//seList = appResult.mergeStockEntriesResponse.StockEntry;
			seList = appResult.mergeStockEntriesResponse.stockEntryList.stockEntry;
		ИначеЕсли НЕ(appResult.Свойства().Получить("updateVeterinaryEventsResponse") = Неопределено) Тогда
			// Лаб исследования
			seList = appResult.updateVeterinaryEventsResponse.stockEntry;
		Иначе
			Возврат Ложь;
		КонецЕсли;
	Исключение
		
		ВетИС_APIСервер.СообщитьИнфо("Отсутствуют Партии");
		
		Если ЗначениеЗаполнено(ДокСсылка) Тогда
					
			Ошибка = "В ответе сервера отсутствуют данные по партиям. Проверьте результат в веб-интерфейсе.";
			ЗафиксироватьОшибку(Ошибка, ДокСсылка);
			
			ЗаписьЖурналаРегистрации(
				СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Ошибка при записи партий в документе %1'"), ДокСсылка),
				УровеньЖурналаРегистрации.Ошибка, , ,
				"В ответе сервера отсутствуют данные по партиям.");
			
		КонецЕсли;
		
		Возврат Ложь;
		
	КонецПопытки;
	
	Если ТипЗнч(seList) <> Тип("СписокXDTO") Тогда
		stockEntryList = Новый Массив;
		stockEntryList.Добавить(seList);
	Иначе
		stockEntryList = seList;
	КонецЕсли;
	
	СписокПартий = Новый Массив;
	ПараметрыФункции.Вставить("СписокПартий", СписокПартий);
	
	Для Каждого stockEntry ИЗ stockEntryList Цикл
		Партия = ВетИС_API_ПартииСервер.Партия_Заполнить(Параметры, stockEntry, докСсылка);
		
		Если Партия <> Неопределено И ПараметрыФункции.Свойство("СписокПартий") Тогда
			СтруктураСтроки = Новый Структура("Партия, Количество", Партия.Ссылка, Партия.Количество);
			ПараметрыФункции.СписокПартий.Добавить(СтруктураСтроки);
		КонецЕсли;
	КонецЦикла;
	
	Если ВетИС_ГашениеСервер.ФормироватьДвиженияПартий(ДокСсылка.Организация) Тогда
		РегистрыСведений.кб99_ОстаткиПартийВетис.ЗаписатьОстаткиПартий(ПараметрыФункции.СписокПартий, ДокСсылка);
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

Функция ЗагрузитьXML_ВСД2(ПараметрыФункции, xdto) Экспорт
	
	докОснование = ПараметрыФункции["ДокОснование"];
	Параметры = ПараметрыФункции["Параметры"];
	//xdto = ПараметрыФункции["xdto"];
	
	Если ПараметрыФункции.Свойство("ВсдРезультатМассив") Тогда
		ВсдРезультатМассив = ПараметрыФункции["ВсдРезультатМассив"];
	Иначе
		ВсдРезультатМассив = Новый Массив;
	КонецЕсли;
	
	Попытка 
		applicationId = xdto.Body.receiveApplicationResultResponse.application.applicationId;
	Исключение
		applicationId = "";
	КонецПопытки;
	
	Попытка 
		appResult = xdto.Body.receiveApplicationResultResponse.application.result;
	Исключение
		Возврат Ложь;
	КонецПопытки;
	
	Попытка
		ЗаписатьОтветXML = Ложь;
		Если НЕ(appResult.Свойства().Получить("prepareOutcomingConsignmentResponse") = Неопределено) Тогда
			seList = appResult.prepareOutcomingConsignmentResponse.vetDocument;
		ИначеЕсли НЕ(appResult.Свойства().Получить("prepareOutgoingConsignmentResponse") = Неопределено) Тогда
			// Транзакция
			seList = appResult.prepareOutgoingConsignmentResponse.vetDocument;
		ИначеЕсли НЕ(appResult.Свойства().Получить("processIncomingConsignmentResponse") = Неопределено) Тогда
			// Гашение
			seList = appResult.processIncomingConsignmentResponse.vetDocument;
		ИначеЕсли НЕ(appResult.Свойства().Получить("registerProductionOperationResponse") = Неопределено) Тогда
			seList = appResult.registerProductionOperationResponse.vetDocument;
			// Выпуск
		ИначеЕсли НЕ(appResult.Свойства().Получить("withdrawVetDocumentResponse") = Неопределено) Тогда
			// Аннулирование
			seList = appResult.withdrawVetDocumentResponse.vetDocument;
		ИначеЕсли НЕ(appResult.Свойства().Получить("getVetDocumentListResponse") = Неопределено) Тогда
			// Входящие
			seList = appResult.getVetDocumentListResponse.vetDocumentList.vetDocument;
			ЗаписатьОтветXML = Истина;
		ИначеЕсли НЕ(appResult.Свойства().Получить("resolveDiscrepancyResponse") = Неопределено) Тогда
			// Инвентаризация
			seList = appResult.resolveDiscrepancyResponse.vetDocumentList.vetDocument;
		ИначеЕсли НЕ(appResult.Свойства().Получить("getVetDocumentByUuidResponse") = Неопределено) Тогда
			// Запрос по UUID 
			seList = appResult.getVetDocumentByUuidResponse.vetDocument;
		ИначеЕсли НЕ(appResult.Свойства().Получить("updateTransportMovementDetailsResponse") = Неопределено) Тогда
			// Обновление транспорта 
			seList = appResult.updateTransportMovementDetailsResponse.vetDocument;
		ИначеЕсли НЕ(appResult.Свойства().Получить("checkShipmentRegionalizationResponse") = Неопределено) Тогда
			// Условия перевозки
			seList = appResult.checkShipmentRegionalizationResponse.r13nRouteSection;
			Возврат ЗагрузитьОтветУсловияПеревозки(seList, докОснование);
		Иначе
			ВетИС_APIСервер.СообщитьИнфо("Документы ВСД отсутствуют, не далось прочитать ВСД ");
			Возврат Ложь;
		КонецЕсли;
	Исключение
		Если Параметры.ВыводитьПодробнуюИнформацию Тогда
			ВетИС_APIСервер.СообщитьИнфо("Отсутствуют ВСД ");
		КонецЕсли;
		Возврат Ложь;
	КонецПопытки;
	
	Если ТипЗнч(seList) <> Тип("СписокXDTO") Тогда
		vetDocumentList = Новый Массив;
		vetDocumentList.Добавить(seList);
	Иначе
		vetDocumentList = seList;
	КонецЕсли;
	
	Для каждого vetDocument ИЗ vetDocumentList Цикл
		Попытка forma = vetDocument.vetDForm; Исключение forma = ""; КонецПопытки;
		
		ВсдСтруктура = Новый Структура("ДокументОснование, Организация, ФормаВСД, UUID, applicationId, Статус, СтатусВСД, Дата, ВСДДата, ТипВСД, ВсдСерия, ВсдНомер, ВидВСД,
		|ВладелецХС, Отправитель_ХозСубъект, Отправитель_Площадка, Получатель_ХозСубъект, Получатель_Площадка, Перевозчик_ХозСубъект, Производитель_Площадка, ТтнСерия, ТтнНомер, ТтнДата, номерАвто,
		|ттнТип, cargoInspected, ТермическиеУсловияПеревозки, номерПолуприцепа, номерКонтейнера, ТипТС, Продукция, ВидПродукции, Продукция_Элемент, НаименованиеПродукции, GTIN, Артикул,
		|ДатаИзготовления, ДатаИзготовления1, ДатаИзготовления2, ДатаСрокГодности, ДатаСрокГодности1, ДатаСрокГодности2, 
		|Количество, КоличествоПринять, КоличествоВозврат, ЕдиницаИзмерения, РезультатыИсследований,
		|НомерПартии, Скоропортящийся, Некачественный, ПроизводителиСписок, Страна, УровниУпаковки, ОсобыеОтметки, Местность, СвязанныеДокументы,
		|ДокВСД, Наименование, ВидПроисхожденияНеПищевойПродукции, Цель, НомерПартии, НаличиеЛабИсследований, ФасовкаНаименование, ФасовкаФормаУпаковки,
		|ФасовкаКоличество, ФасовкаОбъем, ФасовкаЕдиницаИзмерения");
		
		_uuid = vetDocument.uuid;
		
		ВсдСтруктура.ФормаВСД = forma;
		ВсдСтруктура.UUID = _uuid;
		
		ВсдСтруктура.applicationId = applicationId;
		Попытка ВсдСтруктура.Статус = xdto.Body.receiveApplicationResultResponse.application.status; Исключение КонецПопытки;
		Попытка ВсдСтруктура.СтатусВСД = Перечисления.кб99_СтатусВСД[vetDocument.vetDStatus]; Исключение КонецПопытки;
		ВсдСтруктура.Дата = ВетИС_APIСервер.СтрокаВДатаВремя(vetDocument.lastUpdateDate);
		Попытка ВсдСтруктура.ВСДДата = ВетИС_APIСервер.СтрокаВДату(vetDocument.issueDate); Исключение КонецПопытки;
		
		ВсдСтруктура.Организация = Параметры["Организация"];
		
		Попытка ВсдСтруктура.ТипВСД = vetDocument.vetDType; Исключение КонецПопытки;
		
		Попытка ВсдСтруктура.всдсерия = vetDocument.issueSeries; Исключение КонецПопытки;
		Попытка ВсдСтруктура.всдномер = vetDocument.issueNumber; Исключение КонецПопытки;
		ВсдСтруктура.всдсерия = ?(ВсдСтруктура.всдсерия = "ОбъектXDTO", "", ВсдСтруктура.всдсерия); //!!!!
		ВсдСтруктура.всдномер = ?(ВсдСтруктура.всдномер = "ОбъектXDTO", "", ВсдСтруктура.всдномер); //!!!!
		// Номер бланка бумажного ВСД Максимум 13 символов
		// При поступлении импортного ВСД в поле vetDocument.issueNumber указан UUID
		//ВсдСтруктура.ВидВСД = ЗначениеЗаполнено(ВсдСтруктура.ВСДНомер) И Не СтрДлина(ВсдСтруктура.ВСДНомер)= 36;
		ВсдСтруктура.ВидВСД = 0;
		
		ЭтоТранспортныйВСД = 0;
		Попытка
			batch = vetDocument.certifiedBatch.batch; // Продуктивный ВСД
		Исключение
			Попытка
				// Сертифицированная партия.
				// Сведения о партии продукции. 
				batch = vetDocument.certifiedConsignment.batch; // ЖД Транспортный ВСД -другая структура ответа буду делать отдельно
				ЭтоТранспортныйВСД = 1;
			Исключение
				batch = "";
			КонецПопытки;
		КонецПопытки;
		
		Если ЭтоТранспортныйВСД = 1 Тогда
			Попытка 
				ВсдСтруктура.Отправитель_ХозСубъект = ВетИС_API_ПлощадкиСервер.ХозСубъект_НайтиПоGUID(Параметры, vetDocument.certifiedConsignment.consignor.businessEntity.guid, Ложь, Истина);
			Исключение 
				ВсдСтруктура.Отправитель_ХозСубъект = "";
			КонецПопытки;
			
			Попытка 
				ВсдСтруктура.Отправитель_Площадка = ВетИС_API_ПлощадкиСервер.Площадка_НайтиПоGUID(Параметры, vetDocument.certifiedConsignment.consignor.enterprise.guid, ВсдСтруктура.Отправитель_ХозСубъект, Ложь, Истина);
			Исключение
			КонецПопытки;
			
			Попытка 
				ВсдСтруктура.Получатель_ХозСубъект = ВетИС_API_ПлощадкиСервер.ХозСубъект_НайтиПоGUID(Параметры, vetDocument.certifiedConsignment.consignee.businessEntity.guid, Ложь, Истина);
			Исключение 
				ВсдСтруктура.Получатель_ХозСубъект = "";
			КонецПопытки;
			
			Попытка 
				ВсдСтруктура.Получатель_Площадка = ВетИС_API_ПлощадкиСервер.Площадка_НайтиПоGUID(Параметры, vetDocument.certifiedConsignment.consignee.enterprise.guid, ВсдСтруктура.Получатель_ХозСубъект, Ложь, Истина);
			Исключение
			КонецПопытки;
			
			Попытка ВсдСтруктура.ВладелецХС = ВетИС_API_ПлощадкиСервер.ХозСубъект_НайтиПоGUID(Параметры, batch.owner.guid, Ложь, Истина); Исключение КонецПопытки;
			
			Попытка
				Если НЕ(ЗначениеЗаполнено(ВсдСтруктура.ВладелецХС)) Тогда
					ВсдСтруктура.ВладелецХС = ВсдСтруктура.Отправитель_ХозСубъект;
				КонецЕсли;
			Исключение
			КонецПопытки;
			
			Попытка ВсдСтруктура.Перевозчик_ХозСубъект = ВетИС_API_ПлощадкиСервер.ХозСубъект_НайтиПоGUID(Параметры, vetDocument.certifiedConsignment.broker.guid, Ложь, Истина); Исключение КонецПопытки;
			
			Попытка
				transportInfo = vetDocument.certifiedConsignment.transportInfo;
				ТипТС = transportInfo.transportType;
				Если ТипТС = "1" Тогда
					ВсдСтруктура.номеравто = transportInfo.transportNumber.vehicleNumber;
					Попытка ВсдСтруктура.номерПолуприцепа = transportInfo.transportNumber.trailerNumber; Исключение КонецПопытки;
					Попытка ВсдСтруктура.номерКонтейнера = transportInfo.transportNumber.containerNumber; Исключение КонецПопытки;
					Попытка ВсдСтруктура.номерПолуприцепа = ?(ВсдСтруктура.номерПолуприцепа = "ОбъектXDTO", "", ВсдСтруктура.номерПолуприцепа); Исключение КонецПопытки;
					Попытка ВсдСтруктура.номерКонтейнера = ?(ВсдСтруктура.номерКонтейнера = "ОбъектXDTO", "", ВсдСтруктура.номерКонтейнера); Исключение КонецПопытки;
				Иначеесли ТипТС = "2" Тогда
					ВсдСтруктура.номеравто = transportInfo.transportNumber.wagonNumber;
				Иначеесли ТипТС = "3" Тогда
					ВсдСтруктура.номеравто = transportInfo.transportNumber.flightNumber;
				Иначеесли (ТипТС = "4") ИЛИ (ТипТС = "5") ИЛИ (ТипТС = "6") Тогда
					ВсдСтруктура.номеравто = transportInfo.transportNumber.shipName;
				КонецЕсли;
				Попытка ВсдСтруктура.ТипТС = ТипТС; Исключение КонецПопытки;
			Исключение
			КонецПопытки;
			
			Попытка ВсдСтруктура.ТермическиеУсловияПеревозки = Перечисления.кб99_ТермическиеУсловияПеревозки[vetDocument.certifiedConsignment.transportStorageType]; Исключение КонецПопытки;
			
			Попытка МаршрутСледования = ВетИС_API_ПартииСервер.МаршрутСледования_из_XML(Параметры, vetDocument.certifiedConsignment.shipmentRoute.routePoint); Исключение МаршрутСледования = ""; КонецПопытки;
			
			Попытка
				ТочкиМаршрута = МаршрутСледования;
				// ЖД При гашении Нужно указать Тип И № последнего ТС в Маршруте Следования - запишем данные в соотв реквизиты.
				Если ТипЗнч(ТочкиМаршрута) = Тип("ТаблицаЗначений") Тогда
					ТочкиМаршрута.Сортировать("НомерТочки Убыв"); // Возьмем № последнего ТС в точке где была перегрузка, т.е. № Авто сменился
					Для каждого стрТочкаМаршрута ИЗ ТочкиМаршрута Цикл
						Если стрТочкаМаршрута.Перегрузка = 1 Тогда
							ВсдСтруктура.ТипТС = Строка(стрТочкаМаршрута.ТипТранспорта);
							ВсдСтруктура.номерКонтейнера = стрТочкаМаршрута.номерКонтейнера;
							ВсдСтруктура.номеравто = СокрЛП(стрТочкаМаршрута.номеравто) + СокрЛП(стрТочкаМаршрута.номерВагона) + СокрЛП(стрТочкаМаршрута.НомерАвиарейса) + СокрЛП(стрТочкаМаршрута.НазваниеСудна);
							ВсдСтруктура.номерПолуприцепа = стрТочкаМаршрута.номерПрицепа;
							Прервать;
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
			Исключение
			КонецПопытки;
		КонецЕсли; // транспортный ВСД
		
		Попытка ВсдСтруктура.ВидПроисхожденияНеПищевойПродукции = Перечисления.кб99_ВидПроисхожденияНепищевойПродукции[batch.applicableClassifications.nonFoodSource]; Исключение КонецПопытки;
		
		Попытка ВсдСтруктура.Продукция = ВетИС_API_НСИСервер.НайтиПродукцию(batch.product.guid); Исключение КонецПопытки;
		Попытка ВсдСтруктура.ВидПродукции = ВетИС_API_НСИСервер.НайтиВидПродукции(batch.subProduct.guid); Исключение КонецПопытки;
		ВсдСтруктура.Продукция_Элемент = ВетИС_API_НСИСервер.Продукция_Элемент_Найти(Параметры, batch.productItem, , ВсдСтруктура.ВидПроисхожденияНеПищевойПродукции, ВсдСтруктура.ТермическиеУсловияПеревозки);
		
		Попытка
			ВсдСтруктура.НаименованиеПродукции = batch.productItem.name;
		Исключение 
			ВсдСтруктура.НаименованиеПродукции = ВсдСтруктура.Продукция_Элемент.Наименование;
		КонецПопытки;
		
		ВсдСтруктура.Наименование = ВсдСтруктура.НаименованиеПродукции;
		
		// Trade Identification Number (GTIN) - идентификационный номер продукции производителя.
		Попытка ВсдСтруктура.GTIN = batch.productItem.globalID; Исключение КонецПопытки;
		// Артикул (код) продукции в соответствии с внутренним кодификатором производителя.
		Попытка ВсдСтруктура.Артикул = batch.productItem.code; Исключение КонецПопытки;
		
		// <dt:packaging> Фасовка.
		// Параметры фасовки привязаны к ВСД_ПродукцияЭлемент
		Попытка ВетИС_API_ПартииСервер.Фасовка_из_XML(batch.productItem.packaging, ВсдСтруктура.ФасовкаНаименование, ВсдСтруктура.ФасовкаФормаУпаковки,
			ВсдСтруктура.ФасовкаКоличество, ВсдСтруктура.ФасовкаОбъем, ВсдСтруктура.ФасовкаЕдиницаИзмерения); Исключение КонецПопытки;
		
		// Объем продукции
		Попытка ВсдСтруктура.Количество = Число(batch.volume); Исключение КонецПопытки;
		Попытка ВсдСтруктура.КоличествоПринять = ВсдСтруктура.Количество; Исключение КонецПопытки;
		Попытка ВсдСтруктура.КоличествоВозврат = 0; Исключение КонецПопытки;
		Попытка ВсдСтруктура.ЕдиницаИзмерения = ВетИС_API_НСИСервер.НайтиЕдИзмерения(batch.unit.guid); Исключение КонецПопытки;
		
		Попытка
			ВсдСтруктура.ДатаИзготовления1 = ВетИС_APIСервер.Преобразовать_ДатаXML_в_Строку(batch.dateOfProduction.firstDate);
		Исключение
			ВсдСтруктура.ДатаИзготовления1 = "";
		КонецПопытки;
		
		Попытка
			ВсдСтруктура.ДатаИзготовления2 = ВетИС_APIСервер.Преобразовать_ДатаXML_в_Строку(batch.dateOfProduction.secondDate);
		Исключение
			ВсдСтруктура.ДатаИзготовления2 = "";
		КонецПопытки;
		
		Попытка ВсдСтруктура.ДатаИзготовления = batch.dateOfProduction.informalDate; Исключение КонецПопытки;
		
		Попытка
			ВсдСтруктура.ДатаСрокГодности1 = ВетИС_APIСервер.Преобразовать_ДатаXML_в_Строку(batch.expiryDate.firstDate);
		Исключение
			ВсдСтруктура.ДатаСрокГодности1 = "";
		КонецПопытки;
		
		Попытка
			ВсдСтруктура.ДатаСрокГодности2 = ВетИС_APIСервер.Преобразовать_ДатаXML_в_Строку(batch.expiryDate.secondDate);
		Исключение
			ВсдСтруктура.ДатаСрокГодности2 = "";
		КонецПопытки;
		
		Попытка ВсдСтруктура.ДатаСрокГодности = batch.expiryDate.informalDate; Исключение КонецПопытки;
		
		Попытка ВсдСтруктура.Скоропортящийся = batch.perishable; Исключение КонецПопытки;
		Попытка ВсдСтруктура.Некачественный = batch.lowGradeCargo; Исключение КонецПопытки;
		
		Попытка 
			ВсдСтруктура.Страна = ВетИС_API_АдресаСервер.НайтиСтрануПоGUID(batch.origin.country.guid, batch.origin.country.guid);
		Исключение
		КонецПопытки;
		
		Попытка ВсдСтруктура.cargoInspected = vetDocument.authentication.cargoInspected; Исключение КонецПопытки;
		Попытка cargoExpertized = vetDocument.authentication.cargoExpertized; Исключение cargoExpertized = ""; КонецПопытки;
		Попытка ВсдСтруктура.РезультатыИсследований = Перечисления.кб99_РезультатИсследования[cargoExpertized]; Исключение КонецПопытки;
		Попытка ВсдСтруктура.особыеотметки = vetDocument.authentication.specialMarks; Исключение КонецПопытки;
		ВсдСтруктура.особыеотметки = ?(ВсдСтруктура.особыеотметки = "ОбъектXDTO", "", ВсдСтруктура.особыеотметки);
		
		Попытка ЦельGuid = vetDocument.authentication.purpose.guid; Исключение ЦельGuid = ""; КонецПопытки;
		
		Если ЗначениеЗаполнено(ЦельGuid) Тогда
			ВсдСтруктура.Цель = ВетИС_API_НСИСервер.ВСД_ЦельНайтиПоGuid(ЦельGuid);
		КонецЕсли;
		
		Попытка ВсдСтруктура.Местность = vetDocument.authentication.locationProsperity; Исключение КонецПопытки; //В гашении ВСДМестность
		
		Попытка
			Если Параметры.КонтролироватьНаличиеЛабИсследований Тогда
				тзЛабИсследования = ВетИС_API_ПартииСервер.ЛабораторныеИсследованияИзXML(vetDocument.authentication.laboratoryResearch);
			Иначе
				тзЛабИсследования = ВетИС_API_ПартииСервер.СоздатьТзЛабИсследования();
			КонецЕсли;
		Исключение
			тзЛабИсследования = ВетИС_API_ПартииСервер.СоздатьТзЛабИсследования();
		КонецПопытки;
		
		ВсдСтруктура.НаличиеЛабИсследований = тзЛабИсследования.Количество() > 0;
		
		Попытка 
			СвязанныеДокументы = ВетИС_API_ПартииСервер.СвязанныеДокументы_из_XML(vetDocument.referencedDocument);
			ЗаполнитьНомерТТН(ВсдСтруктура, СвязанныеДокументы);
		Исключение 
			СвязанныеДокументы = Новый Массив;
		КонецПопытки;
		
		ДокОбъект = ВетИС_API_ПартииСервер.НайтиВсдОбъектПоUUID(_uuid, "ВСД2");
		
		ВсдСтруктура.ДокументОснование = ДокОбъект.ДокументОснование; // не изменяем !
		ЗаполнитьЗначенияСвойств(ДокОбъект, ВсдСтруктура);
		ДокОбъект.ТочкиМаршрута.Очистить();
		
		Если ЗначениеЗаполнено(МаршрутСледования) Тогда 
			МаршрутСледования.Сортировать("НомерТочки");
			Для Каждого ТочкаПерегрузки ИЗ МаршрутСледования Цикл
				НоваяСтрока = ДокОбъект.ТочкиМаршрута.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, ТочкаПерегрузки);
				Если ТочкаПерегрузки.Перегрузка Тогда
					НоваяСтрока.ТипТранспорта = Перечисления.кб99_ТипыТранспорта[(ТочкаПерегрузки.ТипТранспорта - 1)];
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
		ДокОбъект.СвязанныеДокументы.Очистить();
		Для Каждого СвязныйДок из СвязанныеДокументы Цикл 
			НоваяСтрока = ДокОбъект.СвязанныеДокументы.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СвязныйДок);
		КонецЦикла;
		
		Попытка
			ВетИС_API_ПартииСервер.ЗаполнитьУровниУпаковки(ДокОбъект, batch.packageList.package);
		Исключение
		КонецПопытки;
		
		ДокОбъект.НомераПартий.Очистить();
		Попытка 
			НомерПартии = ВетИС_API_ПартииСервер.НомерПартий_из_XML(batch);
			Для Каждого строкаВСД из НомерПартии Цикл 
				НоваяСтрока = ДокОбъект.НомераПартий.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, строкаВСД);
				ВсдСтруктура.НомерПартии = НоваяСтрока.НомерПартии;
			КонецЦикла;
		Исключение
		КонецПопытки;
		
		//Информация о предприятие-производителе продукции.
		//возможен список предприятий
		Попытка 
			// Если импорт элемент producer будет отсутствовать в ответе сервиса
			ВетИС_API_ПартииСервер.ЗаполнитьПроизводителей(Параметры, ДокОбъект, batch.origin.producer);
		Исключение
		КонецПопытки;
		
		Если НЕ ЗначениеЗаполнено(ДокОбъект.ДокументОснование) и ЗначениеЗаполнено(докОснование) Тогда
			ДокОбъект.ДокументОснование = ДокОснование;
		КонецЕсли;
		
		ДокОбъект.ЛабораторныеИсследования.Очистить();
		ДокОбъект.ЛабораторныеИсследования.Загрузить(тзЛабИсследования);
		
		ДокОбъект.Записать();
		ВетИС_APIСервер.СообщитьИнфо("Записан ВСД2 " + ДокОбъект.Код + " [" + _uuid + "] " + ДокОбъект.Наименование, ДокОбъект.Ссылка);
		
		Если ЗначениеЗаполнено(ВсдСтруктура.Отправитель_Площадка) Тогда
			ВсдСтруктура.Вставить("СменаВладельцаБезПеревозки", ВсдСтруктура.Отправитель_Площадка.guid = ВсдСтруктура.Получатель_Площадка.guid);
		КонецЕсли;
		
		ВсдСтруктура.ДокВСД = ДокОбъект.Ссылка;
		ВсдРезультатМассив.Добавить(ВсдСтруктура);
		
		Если ЗаписатьОтветXML Тогда 
			ВетИС_APIСервер.СохранитьЗапросВРегистрСведений(Параметры, xdto, ВсдСтруктура.ДокВСД, applicationId, ВсдСтруктура.Статус);
		КонецЕсли;
		
	КонецЦикла;
	
	ПараметрыФункции.Вставить("ВсдРезультатМассив", ВсдРезультатМассив);
	ПараметрыФункции.Вставить("СтатусВСД", ВсдСтруктура.СтатусВСД);
	
	Возврат Истина;
	
КонецФункции

Процедура ЗаполнитьНомерТТН(ВсдСтруктура, СвязанныеДокументы) Экспорт
	
	// При поступлении импортного ВСД в приоритете номер бланка CMR
	СтруктураОтбора = Новый Структура("ТипДокумента", 3);
	НайденныеСтроки = СвязанныеДокументы.НайтиСтроки(СтруктураОтбора);
	Если НайденныеСтроки.Количество() = 0 Тогда
		// Товарно-транспортная накладная
		СтруктураОтбора = Новый Структура("ТипДокумента", 1);
		НайденныеСтроки = СвязанныеДокументы.НайтиСтроки(СтруктураОтбора);
		
		Если НайденныеСтроки.Количество() = 0 Тогда
			СтруктураОтбора = Новый Структура("ТипДокумента", 2);
			НайденныеСтроки = СвязанныеДокументы.НайтиСтроки(СтруктураОтбора);
			Если НайденныеСтроки.Количество() = 0 Тогда
				СтруктураОтбора = Новый Структура("ТипДокумента", 3);
				НайденныеСтроки = СвязанныеДокументы.НайтиСтроки(СтруктураОтбора);
				Если НайденныеСтроки.Количество() = 0 Тогда
					СтруктураОтбора = Новый Структура("ТипДокумента", 4);
					НайденныеСтроки = СвязанныеДокументы.НайтиСтроки(СтруктураОтбора);
					Если НайденныеСтроки.Количество() = 0 Тогда
						СтруктураОтбора = Новый Структура("ТипДокумента", 5);
						НайденныеСтроки = СвязанныеДокументы.НайтиСтроки(СтруктураОтбора);
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если НайденныеСтроки.Количество() > 0 Тогда
		ВсдСтруктура.ттнСерия = НайденныеСтроки[0].СерияДокумента;
		ВсдСтруктура.ттнномер = НайденныеСтроки[0].НомерДокумента;
		ВсдСтруктура.ттндата = НайденныеСтроки[0].ДатаДокумента;
		ВсдСтруктура.ттнТип = НайденныеСтроки[0].ТипДокумента;
	КонецЕсли;
	
КонецПроцедуры

Функция Запрос_МаршрутДоставки(ДокСсылка, НомерСтроки = 0) Экспорт
	
	запрос = "";
	
	Для Каждого СтрТочкаДоставки ИЗ ДокСсылка.ТочкиМаршрута Цикл
		
		запрос = запрос + "
		|<vd:routePoint>
		|<vd:sqnId>" + СтрТочкаДоставки.НомерСтроки + "</vd:sqnId>
		|";
		
		Если ЗначениеЗаполнено(СтрТочкаДоставки.Площадка) Тогда
			запрос = запрос + "
			|<vd:enterprise>
			|<bs:guid>" + СтрТочкаДоставки.Площадка.GUID + "</bs:guid>
			|</vd:enterprise>
			|";
		Иначе
			запрос = запрос + "
			|<vd:location>
			|<dt:name>" + СтрТочкаДоставки.Название + "</dt:name>
			|<dt:address>";
			
			Если ЗначениеЗаполнено(СтрТочкаДоставки.Страна) Тогда
				Запрос = Запрос + "
				|<dt:country>
				|<bs:guid>" + (СтрТочкаДоставки.Страна.guid) + "</bs:guid>
				|</dt:country>";
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СтрТочкаДоставки.Регион) Тогда
				Запрос = Запрос + "
				|<dt:region>
				|<bs:guid>" + (СтрТочкаДоставки.Регион.guid) + "</bs:guid>
				|</dt:region>";
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СтрТочкаДоставки.Район) Тогда
				Запрос = Запрос + "
				|<dt:district>
				|<bs:guid>" + (СтрТочкаДоставки.Район.guid) + "</bs:guid>
				|</dt:district>";
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СтрТочкаДоставки.Город) Тогда
				Запрос = Запрос + "
				|<dt:locality>
				|<bs:guid>" + СокрЛП(СтрТочкаДоставки.Город.guid) + "</bs:guid>
				|</dt:locality>";
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СтрТочкаДоставки.НаселенныйПункт.guid) Тогда
				Запрос = Запрос + "
				|<dt:subLocality>
				|<bs:guid>" + СокрЛП(СтрТочкаДоставки.НаселенныйПункт.guid) + "</bs:guid>
				|</dt:subLocality>";
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СтрТочкаДоставки.Улица) Тогда
				Запрос = Запрос + "
				|<dt:street>
				|<bs:guid>" + (СтрТочкаДоставки.Улица.guid) + "</bs:guid>
				|</dt:street>";
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СтрТочкаДоставки.Дом) Тогда
				Запрос = Запрос + "
				|<dt:house>" + (СтрТочкаДоставки.Дом) + "</dt:house>";
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СтрТочкаДоставки.Строение) Тогда
				Запрос = Запрос + "
				|<dt:building>" + (СтрТочкаДоставки.Строение) + "</dt:building>";
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СтрТочкаДоставки.Помещение) Тогда
				Запрос = Запрос + "
				|<dt:room>" + (СтрТочкаДоставки.Помещение) + "</dt:room>";
			КонецЕсли;
			
			Запрос = Запрос + "
			|</dt:address>
			|</vd:location>
			|";
		КонецЕсли;
		
		запрос = запрос + "
		|<vd:transshipment>" + ?(СтрТочкаДоставки.Перегрузка = 1, "true", "false") + "</vd:transshipment>";
		
		Если СтрТочкаДоставки.Перегрузка Тогда
			Запрос = Запрос + "
			|<vd:nextTransport>
			|<vd:transportType>" + (Перечисления["кб99_ТипыТранспорта"].Индекс(СтрТочкаДоставки.ТипТранспорта) + 1) + "</vd:transportType>
			|<vd:transportNumber>";
			
			Если ЗначениеЗаполнено(СтрТочкаДоставки.номерКонтейнера) Тогда
				Запрос = Запрос + "
				|<vd:containerNumber>" + (СтрТочкаДоставки.номерКонтейнера) + "</vd:containerNumber>";
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СтрТочкаДоставки.номерАвто) Тогда
				Запрос = Запрос + "
				|<vd:vehicleNumber>" + (СтрТочкаДоставки.номерАвто) + "</vd:vehicleNumber>";
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СтрТочкаДоставки.номерПрицепа) Тогда
				Запрос = Запрос + "
				|<vd:trailerNumber>" + (СтрТочкаДоставки.номерПрицепа) + "</vd:trailerNumber>";
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СтрТочкаДоставки.номерВагона) Тогда
				Запрос = Запрос + "
				|<vd:wagonNumber>" + (СтрТочкаДоставки.номерВагона) + "</vd:wagonNumber>";
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СтрТочкаДоставки.НазваниеСудна) Тогда
				Запрос = Запрос + "
				|<vd:shipName>" + (СтрТочкаДоставки.НазваниеСудна) + "</vd:shipName>";
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СтрТочкаДоставки.НомерАвиарейса) Тогда
				Запрос = Запрос + "
				|<vd:flightNumber>" + (СтрТочкаДоставки.НомерАвиарейса) + "</vd:flightNumber>";
			КонецЕсли;
			
			Запрос = Запрос + "
			|</vd:transportNumber>";
			
			запрос = запрос + "
			|</vd:nextTransport>";
		КонецЕсли;
		
		Запрос = Запрос + "
		|</vd:routePoint>
		|";
	КонецЦикла;
	
	Возврат Запрос;
	
КонецФункции

Функция ПроверитьНомерАвтомобиля(РезультатПроверки, Документ) Экспорт
	
	Отказ = Ложь;
	РазрешенныеСимволы = "АВЕКМНОРСТУХ0123456789 ";
	НомерАвто = СокрЛП(Документ.НомерАвто);
	
	ЗапрещенныеСимволы = "";
	КодСтраны = ВРег(Прав(НомерАвто, 3));
	Если КодСтраны = "RUS" ИЛИ ВРег(Прав(НомерАвто, 2)) = "RU" Тогда
		НомерБезКодаСтраны = Лев(НомерАвто, СтрДлина(НомерАвто) - СтрДлина(КодСтраны));
		
		Для сч = 1 По СтрДлина(НомерБезКодаСтраны) Цикл
			Если Найти(Врег(РазрешенныеСимволы), Врег(Сред(НомерБезКодаСтраны, сч, 1))) = 0 Тогда
				ЗапрещенныеСимволы = ЗапрещенныеСимволы + Сред(НомерБезКодаСтраны, сч, 1);
			КонецЕсли;
		КонецЦикла;
		
		Если ЗначениеЗаполнено(ЗапрещенныеСимволы) Тогда
			Отказ = Истина;
			стрОшибка = "Запрещенные символы в № автомобиля : " + ЗапрещенныеСимволы;
		КонецЕсли;
	Иначе
		Отказ = Истина;
		стрОшибка = "Неизвестный код страны в № автомобиля : " + КодСтраны;
	КонецЕсли;
	
	Если Отказ Тогда
		РезультатПроверки = Ложь;
		стрОшибка = стрОшибка + Символы.ПС;
	КонецЕсли;
	
	Возврат стрОшибка;
	
КонецФункции

