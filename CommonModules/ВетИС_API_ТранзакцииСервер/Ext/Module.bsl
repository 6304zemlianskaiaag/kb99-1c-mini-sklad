Процедура АннулироватьСписокВСД(Знач Параметры, Знач СписокОбъектов) Экспорт
	
	Если СписокОбъектов.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	СписокДляАннулирования = Новый Массив;
	
	// 1. Разрешаем типы объектов и обновляем транзакции локально
	Для Каждого Объект Из СписокОбъектов Цикл
		
		Если ТипЗнч(Объект) = Тип("ДокументСсылка.ВСД2_транзакция") Тогда
			
			тзВСД = Выбрать_ВСД2(Объект);
			Для Каждого Стр Из тзВСД Цикл
				Если СписокДляАннулирования.Найти(Стр.Док) = Неопределено Тогда
					СписокДляАннулирования.Добавить(Стр.Док);
				КонецЕсли;
			КонецЦикла;
			
			// Помечаем транзакцию локально
			ДокОбъект = Объект.ПолучитьОбъект();
			ДокОбъект.СтатусВСД = Перечисления.кб99_СтатусВСД.WITHDRAWN;
			ДокОбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);
			ДокОбъект.УстановитьПометкуУдаления(Истина);
			
		ИначеЕсли ТипЗнч(Объект) = Тип("СправочникСсылка.кб99_ВСД2") Тогда
			
			Если СписокДляАннулирования.Найти(Объект) = Неопределено Тогда
				СписокДляАннулирования.Добавить(Объект);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если СписокДляАннулирования.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	СписокДляПолученияОтвета = Новый Массив;
	
	// 2. Отправляем запросы на аннулирование без ожидания ответа
	Для Каждого СсылкаВСД Из СписокДляАннулирования Цикл
		
		Если СокрЛП(СсылкаВСД.ТипВСД) = "PRODUCTIVE" Тогда
			ВетИС_ЯдроСервер.СообщитьИнфо("Производственный невозможно аннулировать", СсылкаВСД);
			Продолжить;	
		КонецЕсли;
		
		ПараметрыАннулирования = Новый Структура;
		ПараметрыАннулирования.Вставить("ДокОснование", СсылкаВСД);
		ПараметрыАннулирования.Вставить("Параметры", Параметры);
		ПараметрыАннулирования.Вставить("ПолучитьОтветВетис", Ложь);
		
		Статус = ВСД2_Аннулировать(ПараметрыАннулирования);
		
		Если Статус = Перечисления.кб99_СтатусЗапроса.ACCEPTED Тогда
			СписокДляПолученияОтвета.Добавить(СсылкаВСД);
		КонецЕсли;
		
	КонецЦикла;
	
	Если СписокДляПолученияОтвета.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	// 3. Пауза и получение ответов
	ВетИС_APIСервер.Пауза(Параметры["ПаузаСек"]);
	
	Для Каждого СсылкаВСД Из СписокДляПолученияОтвета Цикл
		ApplicationID = ВетИС_УтилитыКлиентСервер.НайтиApplicationID(СсылкаВСД);
		Если ЗначениеЗаполнено(ApplicationID) Тогда
			ПараметрыОтвета = Новый Структура("ДокОснование, Параметры, СделатьПаузу, ApplicationID", 
				СсылкаВСД, Параметры, Ложь, ApplicationID);
			ПолучитьРезультат_ВСД2(ПараметрыОтвета);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Процедура АннулироватьСписокВСД_Фон(Знач Параметры, Знач АдресХранилища) Экспорт
	
	СписокОбъектов = Параметры.СписокВСД; // Это может быть массив ВСД2_транзакция или кб99_ВСД2
	ПараметрыОрганизации = ВетИС_ЯдроСервер.ЗагрузитьПараметры(Параметры.Организация);
	
	СписокВСД_ДляАннулирования = Новый Массив;
	
	Для Каждого Объект Из СписокОбъектов Цикл
		
		Если ТипЗнч(Объект) = Тип("ДокументСсылка.ВСД2_транзакция") Тогда
			
			// Для транзакции получаем все связанные оформленные ВСД (справочник)
			тзВСД = Выбрать_ВСД2(Объект);
			Для Каждого Стр Из тзВСД Цикл
				Если СписокВСД_ДляАннулирования.Найти(Стр.Док) = Неопределено Тогда
					СписокВСД_ДляАннулирования.Добавить(Стр.Док);
				КонецЕсли;
			КонецЦикла;
			
			// Помечаем саму транзакцию как отмененную (локально)
			ДокОбъект = Объект.ПолучитьОбъект();
			ДокОбъект.СтатусВСД = Перечисления.кб99_СтатусВСД.WITHDRAWN;
			ДокОбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);
			ДокОбъект.УстановитьПометкуУдаления(Истина);
			
		ИначеЕсли ТипЗнч(Объект) = Тип("СправочникСсылка.кб99_ВСД2") Тогда
			
			Если СписокВСД_ДляАннулирования.Найти(Объект) = Неопределено Тогда
				СписокВСД_ДляАннулирования.Добавить(Объект);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если СписокВСД_ДляАннулирования.Количество() > 0 Тогда
		АннулироватьСписокВСД(ПараметрыОрганизации, СписокВСД_ДляАннулирования);
	КонецЕсли;
	
	ПоместитьВоВременноеХранилище(Истина, АдресХранилища);
	
КонецПроцедуры

Процедура ВСД2_транзакция_Аннулировать( Знач Параметры, ВСД2_Транзакция_Ссылка ) Экспорт
	
	Если НЕ(ЗначениеЗаполнено(ВСД2_Транзакция_Ссылка)) Тогда
		Возврат;
	КонецЕсли;
	
	тзВСД = Выбрать_ВСД2(ВСД2_Транзакция_Ссылка);
	
	СписокВСД = Новый Массив;
	Для Каждого Стр Из тзВСД Цикл
		СписокВСД.Добавить(Стр.Док);
	КонецЦикла;
	
	АннулироватьСписокВСД(Параметры, СписокВСД);
	
	докОбъект = ВСД2_Транзакция_Ссылка.ПолучитьОбъект();
	ДокОбъект.СтатусВСД = Перечисления.кб99_СтатусВСД.WITHDRAWN;
	докОбъект.Записать( РежимЗаписиДокумента.ОтменаПроведения, );
	докОбъект.УстановитьПометкуУдаления(Истина);
	
КонецПроцедуры

Функция НайтиУсловияПеревозки(ДанныеЗаполнения) Экспорт
	
	Результат = Справочники.ВСД_УсловияПеревозки.ПустаяСсылка();
	
	Если Не ЗначениеЗаполнено(ДанныеЗаполнения.GUID) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВСД_УсловияПеревозки.Ссылка КАК УсловиеПеревозкиСсылка
	|ИЗ
	|	Справочник.ВСД_УсловияПеревозки КАК ВСД_УсловияПеревозки
	|ГДЕ
	|	ВСД_УсловияПеревозки.GUID ПОДОБНО &GUID
	|	И ВСД_УсловияПеревозки.ВидПродукции = &ВидПродукции
	|	И НЕ ВСД_УсловияПеревозки.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("GUID", ДанныеЗаполнения.GUID);
	Запрос.УстановитьПараметр("ВидПродукции", ДанныеЗаполнения.ВидПродукции);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Результат = ВыборкаДетальныеЗаписи.УсловиеПеревозкиСсылка;
	Иначе
		
		Условие = Справочники.ВСД_УсловияПеревозки.СоздатьЭлемент();
		ЗаполнитьЗначенияСвойств(Условие, ДанныеЗаполнения);
		Условие.Записать();
		
		Результат = Условие.Ссылка;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ВСД2_Транзакция_УсловияПеревозки_Отправить_ЗапросXML( Параметры, ДокСсылка) Экспорт
	
	GUID_запроса = Новый УникальныйИдентификатор;
	
	Запрос = "<SOAP-ENV:Envelope xmlns:dt='http://api.vetrf.ru/schema/cdm/dictionary/v2'
	|xmlns:bs='http://api.vetrf.ru/schema/cdm/base'
	|xmlns:merc='http://api.vetrf.ru/schema/cdm/mercury/g2b/applications/v2'
	|xmlns:apldef='http://api.vetrf.ru/schema/cdm/application/ws-definitions'
	|xmlns:apl='http://api.vetrf.ru/schema/cdm/application'
	|xmlns:vd='http://api.vetrf.ru/schema/cdm/mercury/vet-document/v2'
	|xmlns:SOAP-ENV='http://schemas.xmlsoap.org/soap/envelope/'>
	|<SOAP-ENV:Header/>
	|<SOAP-ENV:Body>
	|<apldef:submitApplicationRequest>
	|<apldef:apiKey>"+ СокрЛП( Параметры["param_api_key"] ) +"</apldef:apiKey>
	|<apl:application>
	|<apl:serviceId>mercury-g2b.service:2.1</apl:serviceId>
	|<apl:issuerId>"+ СокрЛП( Параметры["param_issuer_id"] ) +"</apl:issuerId>
	|<apl:issueDate>" + ВетИС_APIСервер.ДатаXML(ТекущаяДата(), "T00:00:00") + "</apl:issueDate>
	|<apl:data>
	|<merc:checkShipmentRegionalizationRequest>
	|<merc:localTransactionId>" + GUID_запроса + "</merc:localTransactionId>
	|<merc:initiator>
	|<vd:login>"+ СокрЛП( Параметры["param_intiator_login"] ) +"</vd:login>
	|</merc:initiator>
	|";
	
	Если (типЗнч(ДокСсылка) = тип("ДокументСсылка.ВСД2_входящий")) 
		Или (типЗнч(ДокСсылка) = тип("СправочникСсылка.кб99_ВСД2")) Тогда          
		Запрос = Запрос+"
		|<dt:cargoType>
		|<bs:guid>"+ ДокСсылка.Продукция_Элемент.ВидПродукции.GUID +"</bs:guid>       
		|</dt:cargoType>";	    
	Иначе
		тзТовары = ДокСсылка.Товары.Выгрузить();
		Для Каждого СтрокаТовары из тзТовары Цикл
			
			Если ЗначениеЗаполнено(СтрокаТовары.Партия.ВидПродукции.GUID) Тогда 
				ГУИДПродукции = СтрокаТовары.Партия.ВидПродукции.GUID;
			Иначе 
				ГУИДПродукции = СтрокаТовары.Продукция_Элемент.ВидПродукции.GUID;
			КонецЕсли;
			
			Запрос = Запрос+"
			|<dt:cargoType>
			|<bs:guid>"+ ГУИДПродукции +"</bs:guid>       
			|</dt:cargoType>";	    
		КонецЦикла;
	КонецЕсли;	
	// <vd:sqnId>1</vd:sqnId>
	// Порядовый номер точки маршрута.
	// Не обязателен Для заполнения, будет сгенерирован автоматически в ответе	
	
	// <vd:enterprise>
	// Сведения о предприятии, которое является точкой маршрута.
	// Указывается в случае, Если не указано значение location 	
	
	Если (типЗнч(ДокСсылка) = тип("СправочникСсылка.кб99_ВСД2")) Тогда          
		// перевертыш = получаем условия для возврата
		Запрос = Запрос+"
		|<vd:shipmentRoute>
		|<vd:routePoint>
		|<vd:sqnId>1</vd:sqnId>
		|<vd:enterprise>
		|<bs:guid>"+ СокрЛП(ДокСсылка.Получатель_Площадка.GUID) +"</bs:guid>
		|</vd:enterprise>
		|</vd:routePoint>
		|<vd:routePoint>
		|<vd:sqnId>2</vd:sqnId>
		|<vd:enterprise>
		|<bs:guid>"+ СокрЛП(ДокСсылка.Отправитель_Площадка.GUID) +"</bs:guid>
		|</vd:enterprise>
		|</vd:routePoint>
		|</vd:shipmentRoute>
		|</merc:checkShipmentRegionalizationRequest>
		|</apl:data>
		|</apl:application>
		|</apldef:submitApplicationRequest>
		|</SOAP-ENV:Body>
		|</SOAP-ENV:Envelope>	
		|";
	Иначе
		а = 1; // Порядковый номер точки маршрута.
		Запрос = Запрос+"
		|<vd:shipmentRoute>
		|<vd:routePoint>
		|<vd:sqnId>"+ а +"</vd:sqnId>
		|<vd:enterprise>
		|<bs:guid>"+ СокрЛП(ДокСсылка.Отправитель_Площадка.GUID) +"</bs:guid>
		|</vd:enterprise>
		|</vd:routePoint>";
		Если ДокСсылка.ТочкиМаршрута.Количество()>0 Тогда
			тзТочкиМаршрута = ДокСсылка.ТочкиМаршрута.Выгрузить();
			Для Каждого ТочкаМаршрута Из тзТочкиМаршрута Цикл
				а = а+1;
				Если ЗначениеЗаполнено(ТочкаМаршрута.Площадка) Тогда
					Запрос = Запрос+"
					|<vd:routePoint>
					|<vd:sqnId>"+ а +"</vd:sqnId>
					|<vd:enterprise>
					|<bs:guid>"+ СокрЛП(ТочкаМаршрута.Площадка.GUID) +"</bs:guid>
					|</vd:enterprise>
					|</vd:routePoint>";
				Иначе
					Запрос = Запрос+"
					|<vd:routePoint>
					|<vd:sqnId>"+ а +"</vd:sqnId>
					|<vd:location>
					|<dt:address>
					|<dt:country>
					|<bs:guid>"+ СокрЛП(ТочкаМаршрута.Страна.GUID) +"</bs:guid>
					|</dt:country>
					|<dt:region>
					|<bs:guid>"+ СокрЛП(ТочкаМаршрута.Регион.GUID) +"</bs:guid>
					|</dt:region>";
					Если ЗначениеЗаполнено(ТочкаМаршрута.Район) Тогда
						Запрос = Запрос+"
						|<dt:district>
						|<bs:guid>"+ СокрЛП(ТочкаМаршрута.Район.GUID) +"</bs:guid>
						|</dt:district>";
					КонецЕсли;
					Если ЗначениеЗаполнено(ТочкаМаршрута.Город) Тогда
						Запрос = Запрос+"
						|<dt:locality>
						|<bs:guid>"+ СокрЛП(ТочкаМаршрута.Город.GUID) +"</bs:guid>	
						|</dt:locality>";
					КонецЕсли;
					Запрос = Запрос+"	
					|</dt:address>
					|</vd:location>
					|</vd:routePoint>";
				КонецЕсли;			
			КонецЦикла;
		КонецЕсли;
		а = а+1;
		Запрос = Запрос+"
		|<vd:routePoint>
		|<vd:sqnId>"+ а +"</vd:sqnId>
		|<vd:enterprise>
		|<bs:guid>"+ СокрЛП(ДокСсылка.Получатель_Площадка.GUID) +"</bs:guid>
		|</vd:enterprise>
		|</vd:routePoint>
		|</vd:shipmentRoute>
		|</merc:checkShipmentRegionalizationRequest>
		|</apl:data>
