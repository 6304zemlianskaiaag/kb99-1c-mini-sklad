Функция ВСД2_Транзакция_УсловияПеревозки_ПолучитьОтвет(Параметры, appID, докСсылка, ИспользоватьПаузу=Истина ) Экспорт
	
	Если ПустаяСтрока(appID) Тогда
		ВетИС_APIСервер.СообщитьИнфо("Пустая ссылка applicationID");
		Возврат Ложь;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(ДокСсылка) Тогда 
		ВетИС_APIСервер.СообщитьИнфо("Не выбран документ ");
		Возврат Ложь;
	КонецЕсли;
	
	Если ИспользоватьПаузу Тогда 
		ВетИС_APIСервер.Пауза( Параметры["ПаузаСек"] );
	КонецЕсли;	
	
	xdto = кб99_ВСД_Отправка.ПолучитьРезультатСервер( Параметры, appID );
	Статус = ВетИС_APIСервер.СтатусЗапроса( xdto, докСсылка, Параметры ); 
	
	Если ВетИС_APIСервер.НайтиОшибки(xdto, докСсылка) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если Статус = Перечисления.кб99_СтатусЗапроса.COMPLETED Тогда 
		тзУсловия = ЗагрузитьXML_ПеревозкаРазрешена_2( xdto );
		Если ЗначениеЗаполнено(тзУсловия) Тогда
			докОбъект = докСсылка.ПолучитьОбъект();
			докОбъект.УсловияПеревозки.Очистить();
			докОбъект.УсловияПеревозки.Загрузить(тзУсловия);
			докОбъект.Записать();
			ВетИС_APIСервер.СообщитьИнфо( "Условия перевозки записаны в "+докСсылка, ДокСсылка );
		КонецЕсли;
	ИначеЕсли Статус = Перечисления.кб99_СтатусЗапроса.IN_PROCESS Тогда 
		ВСД2_Транзакция_УсловияПеревозки_ПолучитьОтвет(Параметры, appID, докСсылка, Истина)	
	КонецЕсли;
	
	Возврат Статус;
	
КонецФункции

Функция ВСД2_Транзакция_УсловияПеревозки_Отправить(Знач Параметры, ДокСсылка, ПолучитьОтветВетис=Истина ) Экспорт
	
	Организация = ДокСсылка.Организация; 
	
	Если НЕ ПроверитьЗаполнениеДокументаТранзакция( ДокСсылка, Параметры ) Тогда 		
		Возврат Ложь; 
	КонецЕсли;	
	
	ВетИС_APIСервер.СообщитьИнфо("Запрос условий перевозки Для "+ДокСсылка, ДокСсылка);
	ЗапросXML = ВСД2_Транзакция_УсловияПеревозки_Отправить_ЗапросXML(Параметры, ДокСсылка);
	Service = "platform/services/2.1/ApplicationManagementService";
	Action = "submitApplicationRequest";	
	
	ПараметрыОтправки = кб99_ВСД_Отправка.ПараметрыОтправкиИнициализация( Параметры );
	ПараметрыОтправки.ЗапросXML = ЗапросXML;
	ПараметрыОтправки.Service = Service;
	ПараметрыОтправки.Action = Action;
	xdto = кб99_ВСД_Отправка.ОтправитьSOAPНаСервере( ПараметрыОтправки );
	
	Ответ = ВетИС_APIСервер.СтатусЗапроса( xdto, докСсылка, ПараметрыОтправки );
	
	Если ВетИС_APIСервер.НайтиОшибки(xdto, ДокСсылка) Тогда
		Возврат Ложь;
	КонецЕсли;	
	
	Если ПолучитьОтветВетис Тогда
		appID = кб99_ВСД_Отправка.Получить_ApplicationID( xdto );
		Ответ =  ВСД2_Транзакция_УсловияПеревозки_ПолучитьОтвет( Параметры, appID, ДокСсылка );	
		Для А=1 По 10 Цикл
			Если Ответ = Перечисления.кб99_СтатусЗапроса.IN_PROCESS Тогда
				Ответ =  ВСД2_Транзакция_УсловияПеревозки_ПолучитьОтвет( Параметры, appID, ДокСсылка );	
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

