Процедура ХозСубъект_ПолучитьGuidПоИНН_ВФоне(Знач Параметры, АдресХранилища) Экспорт
	
	ВыбХозСубъект = Параметры["ВыбХозСубъект"];
	
	Ответ = ХозСубъект_ПолучитьGuidПоИНН(Параметры, ВыбХозСубъект);
	
	РезультатОбработки = Новый Структура();
	Если Ответ Тогда 
		РезультатОбработки.Вставить("ЗаданиеВыполнено", Истина);
	Иначе
		РезультатОбработки.Вставить("ЗаданиеВыполнено", Ложь);
	КонецЕсли;
	
	ПоместитьВоВременноеХранилище(РезультатОбработки, АдресХранилища);
	
КонецПроцедуры

Функция ХозСубъект_ПолучитьGuidПоИНН(Знач Параметры, ХозСубъект) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ХозСубъект.ИНН) Тогда
		ИНН = СокрЛП(ВетИС_APIСервер.ПолучитьИНН(ХозСубъект.Контрагент));
		Если НЕ ЗначениеЗаполнено(ИНН) Тогда 
			ВетИС_APIСервер.СообщитьИнфо("Не указан ИНН для контрагента: " + ХозСубъект.Контрагент.Наименование);
			Возврат Ложь;
		КонецЕсли;
	Иначе
		ИНН = ХозСубъект.ИНН;
	КонецЕсли;
	
	ВетИС_APIСервер.СообщитьИнфо(" Запрос GetBusinessEntityByINN [ " + ИНН + " ]");
	ЗапросXML = ХозСубъект_ПолучитьGuidПоИНН_Запрос(ИНН);
	Service = "platform/services/2.1/EnterpriseService";
	Action = "GetBusinessEntityList";
	
	ПараметрыОтправки = кб99_ВСД_Отправка.ПараметрыОтправкиИнициализация(Параметры);
	ПараметрыОтправки.ЗапросXML = ЗапросXML;
	ПараметрыОтправки.Service = Service;
	ПараметрыОтправки.Action = Action;
	xdto = кб99_ВСД_Отправка.ОтправитьSOAPНаСервере(ПараметрыОтправки);
	
	Если ВетИС_APIСервер.НайтиОшибки(xdto, ХозСубъект) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	//НачатьТранзакцию();
	Попытка
		Если Число(xdto.Body.getBusinessEntityListResponse.businessEntityList.total) > 0 Тогда
			Если Число(xdto.Body.getBusinessEntityListResponse.businessEntityList.total) > 1 Тогда
				List = xdto.Body.getBusinessEntityListResponse.businessEntityList.businessEntity;
				Если ТипЗнч(List) <> Тип("СписокXDTO") Тогда 
					businessEntityList = Новый Массив;
					businessEntityList.Добавить(List);
				Иначе
					businessEntityList = List;
				КонецЕсли;
				
				Для каждого businessEntity ИЗ businessEntityList Цикл
					_guid = businessEntity.guid;
					_uuid = businessEntity.uuid;
					active = businessEntity.active;
				КонецЦикла;
			Иначе
				_guid = xdto.Body.getBusinessEntityListResponse.businessEntityList.businessEntity.guid;
				_uuid = xdto.Body.getBusinessEntityListResponse.businessEntityList.businessEntity.uuid;
				active = xdto.Body.getBusinessEntityListResponse.businessEntityList.businessEntity.active;
			КонецЕсли;
			
			ОбъектХС = ХозСубъект.ПолучитьОбъект();
			ОбъектХС.GUID = _GUID;
			ОбъектХС.UUID = _uuid;
			ОбъектХС.Записать();
			ВетИС_APIСервер.СообщитьИнфо("Записан ХозСубъект [" + ХозСубъект + "] GUID = " + _GUID);
			
			ХозСубъект_ЗагрузитьПоGUID(Параметры, _GUID, ОбъектХС.Ссылка);
		Иначе
			ВетИС_APIСервер.СообщитьИнфо("ХозСубъект [" + ХозСубъект + "] с ИНН " + ИНН + " не найден в ГИС Меркурий");
		КонецЕсли;
		//ЗафиксироватьТранзакцию();
		
		Ответ = Истина;
	Исключение
		
		ЗаписьЖурналаРегистрации(
		НСтр("ru = 'Ошибка при получении ХозСубъект'"),
		УровеньЖурналаРегистрации.Ошибка, , ,
		ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		//ОтменитьТранзакцию();
		Ответ = Ложь;
		ВетИС_APIСервер.СообщитьИнфо("Ошибка при получении ХозСубъект " + ОписаниеОшибки());
	КонецПопытки;
	
	Возврат Ответ;
	
КонецФункции

Функция ХозСубъект_ЗагрузитьПоGUID_Запрос(guid) Экспорт
	
	ЗапросXML = "<soapenv:Envelope xmlns:bs='http://api.vetrf.ru/schema/cdm/base'
	|		  xmlns:ws='http://api.vetrf.ru/schema/cdm/registry/ws-definitions/v2'
	|		  xmlns:soapenv='http://schemas.xmlsoap.org/soap/envelope/'>
	|<soapenv:Header/>
	|<soapenv:Body>
	|<ws:getBusinessEntityByGuidRequest>
	|<bs:guid>" + GUID + "</bs:guid>
	|</ws:getBusinessEntityByGuidRequest>
	|</soapenv:Body>
	|</soapenv:Envelope>";
	
	Возврат ЗапросXML;
	
КонецФункции

Функция ХозСубъект_НайтиПоGUID(Знач Параметры, GUID, ОбновитьДанные = Ложь, СоздаватьНовый = Ложь) Экспорт
	
	Ответ = "";
	Если НЕ ПустаяСтрока(Guid) Тогда
		Запрос = Новый Запрос("ВЫБРАТЬ
		|	ВСД_ХозСубъект.Ссылка
		|ИЗ
		|	Справочник.ВСД_ХозСубъект КАК ВСД_ХозСубъект
		|ГДЕ
		|	ВСД_ХозСубъект.GUID = &GUID
		|	И Не ВСД_ХозСубъект.ПометкаУдаления");
		Запрос.УстановитьПараметр("GUID", Guid);
		
		Результат = Запрос.Выполнить().Выбрать();
		
		Если Результат.Следующий() Тогда 
			Если ОбновитьДанные Тогда
				Ответ = ХозСубъект_ЗагрузитьПоGUID(Параметры, GUID, Результат.Ссылка);
			Иначе
				Ответ = Результат.Ссылка;
			КонецЕсли;
		Иначе
			Если ОбновитьДанные ИЛИ СоздаватьНовый Тогда
				Ответ = ХозСубъект_ЗагрузитьПоGUID(Параметры, GUID);
			Иначе
				Ответ = Справочники.ВСД_ХозСубъект.ПустаяСсылка();
			КонецЕсли;
		КонецЕсли;
	Иначе
		ВетИС_APIСервер.СообщитьИнфо("Пустой Guid ХозСубъекта");
	КонецЕсли;
	
	Возврат Ответ;
	
КонецФункции

Функция ХозСубъект_ЗагрузитьПоGUID(Знач Параметры, GUID, Ссылка_ВСД_ХозСубъект = Неопределено) Экспорт
	
	Ответ = Неопределено;
	Если НЕ(ЗначениеЗаполнено(GUID)) Тогда 
		ВетИС_APIСервер.СообщитьИнфо("Пустой GUID Для поиска ХозСубъекта");
		Возврат Ответ;
	КонецЕсли;
	
	ВетИС_APIСервер.СообщитьИнфо(" Запрос GetBusinessEntityByGUID [ " + (GUID) + " ]");
	ПараметрыОтправки = кб99_ВСД_Отправка.ПараметрыОтправкиИнициализация(Параметры);
	ПараметрыОтправки.ЗапросXML = ХозСубъект_ЗагрузитьПоGUID_Запрос(GUID);
	ПараметрыОтправки.Service = "platform/services/2.1/EnterpriseService";
	ПараметрыОтправки.Action = "GetBusinessEntityByGUID";
	xdto = кб99_ВСД_Отправка.ОтправитьSOAPНаСервере(ПараметрыОтправки);
	
	Если ВетИС_APIСервер.НайтиОшибки(xdto, Ссылка_ВСД_ХозСубъект) Тогда
		Возврат Ответ;
	КонецЕсли;
	
	Попытка
		businessEntity = xdto.Body.getBusinessEntityByGuidResponse.businessEntity;
		
		Попытка _name = businessEntity.name; Исключение _name = ""; КонецПопытки;
		Если _name = "" Тогда
			Попытка _name = businessEntity.fio; Исключение _name = ""; КонецПопытки;
		КонецЕсли;
		
		Попытка _Fullname = businessEntity.fullname; Исключение _Fullname = ""; КонецПопытки;
		
		Если ЗначениеЗаполнено(Ссылка_ВСД_ХозСубъект) Тогда 
			ХозСубъект_Объект = Ссылка_ВСД_ХозСубъект.ПолучитьОбъект(); 
		Иначе
			Спр = Новый("СправочникМенеджер.ВСД_ХозСубъект");
			Ссылка_ВСД_ХозСубъект = Спр.НайтиПоРеквизиту("GUID", businessEntity.guid);
			Если Ссылка_ВСД_ХозСубъект = Справочники.ВСД_ХозСубъект.ПустаяСсылка() Тогда 
				ХозСубъект_Объект = Справочники.ВСД_ХозСубъект.СоздатьЭлемент();
			Иначе
				ХозСубъект_Объект = Ссылка_ВСД_ХозСубъект.ПолучитьОбъект(); 
			КонецЕсли;
		КонецЕсли;
		
		ХозСубъект_Объект.Наименование = _name;
		Попытка ХозСубъект_Объект.Адрес = businessEntity.juridicalAddress.addressView; Исключение КонецПопытки;
		ХозСубъект_Объект.GUID = businessEntity.guid;
		ХозСубъект_Объект.UUID = businessEntity.uuid;
		Попытка ХозСубъект_Объект.ИНН = businessEntity.inn; Исключение КонецПопытки;
		Попытка ХозСубъект_Объект.КПП = businessEntity.kpp; Исключение КонецПопытки;
		Попытка ХозСубъект_Объект.ОГРН = businessEntity.ogrn; Исключение КонецПопытки;
		ХозСубъект_Объект.Активен = businessEntity.active;
		Попытка ХозСубъект_Объект.Страна = ВетИС_API_АдресаСервер.НайтиСтрануПоGUID(businessEntity.juridicalAddress.country.GUID, businessEntity.juridicalAddress.country.name); Исключение КонецПопытки;
		Попытка ХозСубъект_Объект.Регион = ВетИС_API_АдресаСервер.НайтиРегионПоGUID(businessEntity.juridicalAddress.region.GUID, businessEntity.juridicalAddress.region.name, ХозСубъект_Объект.Страна); Исключение КонецПопытки;
		Попытка ХозСубъект_Объект.Район = ВетИС_API_АдресаСервер.НайтиРайонПоGUID(businessEntity.juridicalAddress.district.GUID, businessEntity.juridicalAddress.district.name, ХозСубъект_Объект.Регион); Исключение КонецПопытки;
		СубъектДляПоискаГорода = ?(ЗначениеЗаполнено(ХозСубъект_Объект.Район), ХозСубъект_Объект.Район, ХозСубъект_Объект.Регион);
		Попытка ХозСубъект_Объект.Город = ВетИС_API_АдресаСервер.НайтиГородПоGUID(businessEntity.juridicalAddress.locality.GUID, businessEntity.juridicalAddress.locality.name, СубъектДляПоискаГорода); Исключение КонецПопытки;
		Попытка ХозСубъект_Объект.НаселенныйПункт = ВетИС_API_АдресаСервер.НайтиНаселенныйПунктПоGUID(businessEntity.juridicalAddress.sublocality.GUID, businessEntity.juridicalAddress.sublocality.name, ХозСубъект_Объект.Город); Исключение КонецПопытки;
		
		Если Не ЗначениеЗаполнено(ХозСубъект_Объект.НаселенныйПункт) И Не ЗначениеЗаполнено(ХозСубъект_Объект.Город) 
			И ЗначениеЗаполнено(ХозСубъект_Объект.Регион) Тогда
			НаселенныйПункт = ХозСубъект_Объект.Регион;
		ИначеЕсли ЗначениеЗаполнено(ХозСубъект_Объект.НаселенныйПункт) Тогда
			НаселенныйПункт = ХозСубъект_Объект.НаселенныйПункт;
		ИначеЕсли ЗначениеЗаполнено(ХозСубъект_Объект.Город) Тогда
			НаселенныйПункт = ХозСубъект_Объект.Город;
		Иначе
			НаселенныйПункт = Неопределено;
		КонецЕсли;
		
		Попытка ХозСубъект_Объект.Улица = ВетИС_API_АдресаСервер.НайтиУлицуПоGUID(businessEntity.juridicalAddress.street.GUID, businessEntity.juridicalAddress.street.name, НаселенныйПункт); Исключение КонецПопытки;
		Попытка ХозСубъект_Объект.НомерДома = businessEntity.juridicalAddress.house; Исключение КонецПопытки;
		
		// Ищем контрагента
		Если Не ЗначениеЗаполнено(ХозСубъект_Объект.Контрагент) Тогда
			Спр = Новый("СправочникМенеджер.Контрагенты");
			Ссылка_Контрагент = Спр.НайтиПоРеквизиту("ИНН", ХозСубъект_Объект.ИНН);
			Если Ссылка_Контрагент = Справочники.Контрагенты.ПустаяСсылка() Тогда
				ВетИС_APIСервер.СообщитьИнфо("Не найден в справочнике Контрагент " + ХозСубъект_Объект + " ИНН " + ХозСубъект_Объект.ИНН + " ХС запишем без указания контрагента 1С");
			Иначе // Нашли по ИНН
				Если ВетИС_УтилитыКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Ссылка_Контрагент, "ГоловнойКонтрагент") Тогда
					ХозСубъект_Объект.Контрагент = ?(ЗначениеЗаполнено(Ссылка_Контрагент.ГоловнойКонтрагент),
					Ссылка_Контрагент.ГоловнойКонтрагент, Ссылка_Контрагент);
				Иначе
					ХозСубъект_Объект.Контрагент = Ссылка_Контрагент;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		ХозСубъект_Объект.Записать();
		Ответ = ХозСубъект_Объект.Ссылка;
		
		Если НЕ businessEntity.active Тогда 
			ВетИС_APIСервер.СообщитьИнфо("ХозСубъект НЕ АКТИВЕН!", ХозСубъект_Объект.Ссылка);
		КонецЕсли;
		ВетИС_APIСервер.СообщитьИнфо("Записан ВСД_Хозсубъект [" + ХозСубъект_Объект + "] GUID = " + businessEntity.guid + " Адрес: " + ХозСубъект_Объект.Адрес, ХозСубъект_Объект.Ссылка);
	Исключение
		
		ЗаписьЖурналаРегистрации(
		НСтр("ru = 'Ошибка при получении ХозСубъект'"),
		УровеньЖурналаРегистрации.Ошибка, , ,
		ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		Ответ = Неопределено;
		ВетИС_APIСервер.СообщитьИнфо("Ошибка при получении ХозСубъект " + ОписаниеОшибки());
	КонецПопытки;
	
	Возврат Ответ;
	
КонецФункции

Функция ХозСубъекты_ЗагрузитьСписокПоИнн(Знач Параметры) Экспорт
	
	Хозсубъекты = Новый Массив;
	
	Если НЕ ЗначениеЗаполнено(Параметры.Контрагент.ИНН) Тогда
		ВетИС_APIСервер.СообщитьИнфо("Не указан ИНН для контрагента: " + Параметры.Контрагент.Наименование);
		Возврат Хозсубъекты;
	Иначе
		ИНН = Параметры.Контрагент.ИНН;
	КонецЕсли;
	
	ВетИС_APIСервер.СообщитьИнфо(" Запрос GetBusinessEntityByINN [ " + ИНН + " ]");
	ЗапросXML = ХозСубъект_ПолучитьGuidПоИНН_Запрос(ИНН);
	Service = "platform/services/2.1/EnterpriseService";
	Action = "GetBusinessEntityList";
	
	ПараметрыОтправки = кб99_ВСД_Отправка.ПараметрыОтправкиИнициализация(Параметры);
	ПараметрыОтправки.ЗапросXML = ЗапросXML;
	ПараметрыОтправки.Service = Service;
	ПараметрыОтправки.Action = Action;
	xdto = кб99_ВСД_Отправка.ОтправитьSOAPНаСервере(ПараметрыОтправки);
	
	Если ВетИС_APIСервер.НайтиОшибки(xdto) Тогда
		Возврат Хозсубъекты;
	КонецЕсли;
	
	Если xdto = Неопределено Тогда
		Возврат Хозсубъекты;
	КонецЕсли;
	
	Если Число(xdto.Body.getBusinessEntityListResponse.businessEntityList.total) = 0 Тогда 
		ВетИС_APIСервер.СообщитьИнфо("ХозСубъекты с ИНН " + ИНН + " не найден в ГИС Меркурий");
		Возврат Хозсубъекты;
	КонецЕсли;
	
	List = xdto.Body.getBusinessEntityListResponse.businessEntityList.businessEntity;
	
	Если ТипЗнч(List) <> Тип("СписокXDTO") Тогда 
		businessEntityList = Новый Массив;
		businessEntityList.Добавить(List);
	Иначе
		businessEntityList = List;
	КонецЕсли;
	
	Для каждого businessEntity ИЗ businessEntityList Цикл
		
		ЭлементХозсубъект = Новый Структура("Наименование, UUID, GUID, ХозСубъект, Адрес, Активен, ПоследняяЗапись");
		ЭлементХозсубъект.GUID = businessEntity.guid;
		ЭлементХозсубъект.UUID = businessEntity.UUID;
		ЭлементХозсубъект.Активен = businessEntity.active;
		ЭлементХозсубъект.ПоследняяЗапись = businessEntity.last;
		
		Попытка _name = businessEntity.name; Исключение _name = ""; КонецПопытки;
		Если _name = "" Тогда
			Попытка _name = businessEntity.fio; Исключение _name = ""; КонецПопытки;
		КонецЕсли;
		
		ЭлементХозсубъект.Наименование = _name;
		
		Попытка 
			ЭлементХозсубъект.Адрес = businessEntity.juridicalAddress.addressView;
		Исключение 
			ЭлементХозсубъект.Адрес = "";
		КонецПопытки;
		
		ЭлементХозсубъект.ХозСубъект = ХозСубъект_НайтиПоGUID(Параметры, ЭлементХозсубъект.GUID, Истина, Ложь);
		Хозсубъекты.Добавить(ЭлементХозсубъект);
		
	КонецЦикла;
	
	Возврат Хозсубъекты;
	
КонецФункции

Функция ХозСубъект_НайтиПоИНН(Контрагент) Экспорт
	
	Попытка
		
		ПараметрыОрганизации = ВетИС_ЯдроСервер.ЗагрузитьПараметры(ВетИС_ПараметрыСервер.ПолучитьОрганизациюПоУмолчанию());
		
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		|	ВСД_ХозСубъект.Ссылка КАК ХозСубъектСсылка
		|ИЗ
		|	Справочник.ВСД_ХозСубъект КАК ВСД_ХозСубъект
		|ГДЕ
		|	(ВСД_ХозСубъект.ИНН ПОДОБНО &ИНН
		|			ИЛИ ВСД_ХозСубъект.Контрагент = &Контрагент)
		|	И НЕ ВСД_ХозСубъект.ПометкаУдаления
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Контрагенты.Ссылка КАК Контрагент,
		|	Контрагенты.Наименование КАК Наименование,
		|	Контрагенты.ИНН КАК ИНН
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|ГДЕ
		|	Контрагенты.Ссылка = &Контрагент";
		Запрос.УстановитьПараметр("ИНН", Контрагент.ИНН);
		Запрос.УстановитьПараметр("Контрагент", Контрагент);
		РезультатЗапроса = Запрос.ВыполнитьПакет();
		Если РезультатЗапроса[0].Пустой() Тогда
			
			ДанныеПоКонтрагенту = РезультатЗапроса[1].Выбрать();
			ДанныеПоКонтрагенту.Следующий();
			Хозсубъект = Справочники.ВСД_ХозСубъект.СоздатьЭлемент();
			ЗаполнитьЗначенияСвойств(Хозсубъект, ДанныеПоКонтрагенту);
			Хозсубъект.Записать();
			
			ХозСубъект_ПолучитьGuidПоИНН(ПараметрыОрганизации, Хозсубъект.Ссылка);
			
			Возврат Хозсубъект.Ссылка;
			
		Иначе
			
			ВыборкаПоХозсубъектам = РезультатЗапроса[0].Выбрать();
			ВыборкаПоХозсубъектам.Следующий();
			
			Возврат ВыборкаПоХозсубъектам.ХозСубъектСсылка;
			
		КонецЕсли;
		
	Исключение
		
		ЗаписьЖурналаРегистрации(
		НСтр("ru = 'Ошибка при создании хозсубъекта'"),
		УровеньЖурналаРегистрации.Ошибка, , ,
		ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		ВетИС_APIСервер.СообщитьИнфо("Ошибка при создании хозсубъекта " + ОписаниеОшибки());
		
	КонецПопытки;
	
КонецФункции

Функция ХозСубъект_Создать_Ответ(ПараметрыОрганизации, appID, ВыбХозСубъект) Экспорт
	
	Если Не (ЗначениеЗаполнено(appID)) Тогда
		ВетИС_ЯдроСервер.СообщитьИнфо("Не указано applicationID");
		Возврат Ложь;
	КонецЕсли;
	
	ВетИС_APIСервер.Пауза(ПараметрыОрганизации["ПаузаСек"]);
	
	ВетИС_ЯдроСервер.СообщитьИнфо(" Запрос CreateBusinessEntityResult [ " + (appID) + " ]");
	
	xdto = кб99_ВСД_Отправка.ПолучитьРезультатСервер(ПараметрыОрганизации, appID);
	
	Статус = ВетИС_APIСервер.СтатусЗапроса(xdto);
	Если ВетИС_APIСервер.НайтиОшибки(xdto, ВыбХозСубъект) Тогда
		Возврат Статус;
	КонецЕсли;
	
	//Если Статус = "COMPLETED" Тогда
	Если Статус = Перечисления.кб99_СтатусЗапроса.COMPLETED Тогда 
		Попытка
			be = xdto.Body.receiveApplicationResultResponse.application.result.modifyBusinessEntityResponse.businessEntity;
			guid = be.guid;
			_uuid = be.uuid;
			ОбъектХС = ВыбХозСубъект.ПолучитьОбъект();
			ОбъектХС.GUID = guid;
			ОбъектХС.UUID = _uuid;
			ОбъектХС.Записать();
			ВетИС_ЯдроСервер.СообщитьИнфо("Записан ХозСубъект [" + ВыбХозСубъект + "] GUID = " + GUID, ВыбХозСубъект);
		Исключение
			ЗаписьЖурналаРегистрации(
			НСтр("ru = 'Ошибка при получении ответа Ветис'"),
			УровеньЖурналаРегистрации.Ошибка, , ,
			ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			ВетИС_ЯдроСервер.СообщитьИнфо("Ошибка ХозСубъект [" + ВыбХозСубъект + "] " + ОписаниеОшибки());
		КонецПопытки;
	КонецЕсли;
	
КонецФункции

Функция ХозСубъект_Создать_Запрос(ПараметрыОрганизации, ВыбХозСубъект) Экспорт
	
	_guid = Новый УникальныйИдентификатор;
	ЗапросXML = "<SOAP-ENV:Envelope xmlns:dt='http://api.vetrf.ru/schema/cdm/dictionary/v2'
	|xmlns:bs='http://api.vetrf.ru/schema/cdm/base'
	|xmlns:merc='http://api.vetrf.ru/schema/cdm/mercury/g2b/applications/v2'
	|xmlns:apldef='http://api.vetrf.ru/schema/cdm/application/ws-definitions'
	|xmlns:apl='http://api.vetrf.ru/schema/cdm/application'
	|xmlns:vd='http://api.vetrf.ru/schema/cdm/mercury/vet-document/v2'
	|xmlns:SOAP-ENV='http://schemas.xmlsoap.org/soap/envelope/'>
	|<SOAP-ENV:Header/>
	|<SOAP-ENV:Body>
	|<apldef:submitApplicationRequest>
	|<apldef:apiKey>" + СокрЛП(ПараметрыОрганизации["param_api_key"]) + "</apldef:apiKey>
	|<apl:application>
	|<apl:serviceId>mercury-g2b.service:2.1</apl:serviceId>
	|<apl:issuerId>" + СокрЛП(ПараметрыОрганизации["param_issuer_id"]) + "</apl:issuerId>
	|<apl:issueDate>" + ВетИС_APIСервер.ДатаXML(Текущаядата(), "T00:00:00") + "</apl:issueDate>
	|<apl:data>
	|<merc:modifyBusinessEntityRequest>
	|<merc:localTransactionId>" + _guid + "</merc:localTransactionId>
	|<merc:initiator>
	|<vd:login>" + СокрЛП(ПараметрыОрганизации["param_intiator_login"]) + "</vd:login>
	|</merc:initiator>
	|<merc:modificationOperation>
	|<vd:type>FIND_OR_CREATE</vd:type>
	|<vd:resultingList>
	|<dt:businessEntity>";
	
	Если СтрДлина(ВыбХозСубъект.ИНН) = 12 Тогда
		// ИП Тип = 3 ФЛ тип = 2
		ЗапросXML = ЗапросXML + "		
		|<dt:type>3</dt:type>
		|<dt:fio>" + ВетИС_APIСервер.ЗаменитьСпецСимволы(ВыбХозСубъект.НаименованиеПолное) + "</dt:fio>
		|<dt:inn>" + ВыбХозСубъект.ИНН + "</dt:inn>";
	Иначе
		ЗапросXML = ЗапросXML + "		
		|<dt:type>1</dt:type>
		|<dt:name>" + ВетИС_APIСервер.ЗаменитьСпецСимволы(ВыбХозСубъект.Наименование) + "</dt:name>
		|<dt:incorporationForm>
		|<dt:code>12300</dt:code>
		|</dt:incorporationForm>
		|<dt:fullName>" + ВетИС_APIСервер.ЗаменитьСпецСимволы(ВыбХозСубъект.НаименованиеПолное) + "</dt:fullName>
		|<dt:inn>" + ВыбХозСубъект.ИНН + "</dt:inn>";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ВыбХозСубъект.КПП) Тогда
		ЗапросXML = ЗапросXML + "
		|<dt:kpp>" + ВыбХозСубъект.КПП + "</dt:kpp>";
	КонецЕсли;
	
	ЗапросXML = ЗапросXML + "
	|<dt:ogrn>" + ВыбХозСубъект.ОГРН + "</dt:ogrn>
	|<dt:juridicalAddress>
	|<dt:country>
	|<bs:guid>" + ВыбХозСубъект.Страна.GUID + "</bs:guid>
	|</dt:country>
	|<dt:region>
	|<bs:guid>" + ВыбХозСубъект.Регион.GUID + "</bs:guid>
	|</dt:region>";
	
	Если ЗначениеЗаполнено(ВыбХозСубъект.Район.guid) Тогда
		ЗапросXML = ЗапросXML + " 
		|<dt:district>
		|<bs:guid>" + ВыбХозСубъект.Район.guid + "</bs:guid>
		|</dt:district>";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ВыбХозСубъект.Город.GUID) Тогда
		ЗапросXML = ЗапросXML + "
		|<dt:locality>
		|<bs:guid>" + ВыбХозСубъект.Город.GUID + "</bs:guid>
		|</dt:locality>";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ВыбХозСубъект.НаселенныйПункт.guid) Тогда
		ЗапросXML = ЗапросXML + "
		|<dt:subLocality>
		|<bs:guid>" + ВыбХозСубъект.НаселенныйПункт.guid + "</bs:guid>
		|</dt:subLocality>";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ВыбХозСубъект.Улица.guid) Тогда
		ЗапросXML = ЗапросXML + "
		|<dt:street>
		|<bs:guid>" + ВыбХозСубъект.Улица.guid + "</bs:guid>
		|</dt:street>";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ВыбХозСубъект.НомерДома) Тогда
		ЗапросXML = ЗапросXML + "
		|<dt:house>" + ВыбХозСубъект.НомерДома + "</dt:house>";
	КонецЕсли;
	
	ЗапросXML = ЗапросXML + "
	|<dt:addressView>" + ВыбХозСубъект.Адрес + "</dt:addressView>
	|</dt:juridicalAddress>
	|</dt:businessEntity>
	|</vd:resultingList>
	|<vd:reason>Добавление субъекта в реестр.</vd:reason>
	|</merc:modificationOperation>
	|</merc:modifyBusinessEntityRequest>
	|</apl:data>
	|</apl:application>
	|</apldef:submitApplicationRequest>
	|</SOAP-ENV:Body>
	|</SOAP-ENV:Envelope>";
	
	Возврат ЗапросXML;
	
КонецФункции

Процедура ХозСубъект_Создать(ПараметрыОрганизации, ВыбХозСубъект) Экспорт
	
	Если не(ЗначениеЗаполнено(ВыбХозСубъект.ИНН)) Тогда
		ВетИС_ЯдроСервер.СообщитьИнфо("Неправильно указан ИНН");
		Возврат;
	КонецЕсли;
	
	Если НЕ(ЗначениеЗаполнено(ВыбХозСубъект.ОГРН)) Тогда
		ВетИС_ЯдроСервер.СообщитьИнфо("Не указан ОГРН");
		Возврат;
	КонецЕсли;
	
	Если НЕ(ЗначениеЗаполнено(ВыбХозСубъект.Адрес)) Тогда
		ВетИС_ЯдроСервер.СообщитьИнфо("Не указан Адрес");
		Возврат;
	КонецЕсли;
	
	ВетИС_ЯдроСервер.СообщитьИнфо(" Запрос CreateBusinessEntity [ " + ВыбХозСубъект.ИНН + " ]");
	ЗапросXML = ХозСубъект_Создать_Запрос(ПараметрыОрганизации, ВыбХозСубъект);
	Service = "platform/services/ApplicationManagementService"; //"platform/cerberus/services/EnterpriseService";
	Action = "modifyBusinessEntity";
	
	ПараметрыОтправки = кб99_ВСД_Отправка.ПараметрыОтправкиИнициализация(ПараметрыОрганизации);
	ПараметрыОтправки.ЗапросXML = ЗапросXML;
	ПараметрыОтправки.Service = Service;
	ПараметрыОтправки.Action = Action;
	xdto = кб99_ВСД_Отправка.ОтправитьSOAPНаСервере(ПараметрыОтправки);
	
	Статус = ВетИС_APIСервер.СтатусЗапроса(xdto);
	Если ВетИС_APIСервер.НайтиОшибки(xdto, ВыбХозСубъект) Тогда
		Возврат;
	КонецЕсли;
	
	appID = кб99_ВСД_Отправка.Получить_ApplicationID(xdto);
	
	Если ЗначениеЗаполнено(appID) Тогда
		ХозСубъект_Создать_Ответ(ПараметрыОрганизации, appID, ВыбХозСубъект)
	КонецЕсли;
	
КонецПроцедуры


