		Для А=1 По 10 Цикл
			//Если (Ответ="IN_PROCESS") Тогда
			Если Статус = Перечисления.кб99_СтатусЗапроса.IN_PROCESS Тогда 
				Статус =  ВСД2_Входящий_ГашениеПолучитьОтвет( Параметры, appID, ДокСсылка, ВСД_Партия );	
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат Статус;
	
КонецФункции 

Процедура ВСД2_Входящий_ОтправитьГашение_Параллельно( Знач Параметры, АдресХранилища=Неопределено ) Экспорт
	
	ВетИС_APIСервер.СообщитьИнфо("Начало отправки ВСД в Ветис");	
	
	ДокСсылка = Неопределено;
	СписокДокументов = Неопределено;
	Параметры.Свойство("СписокДокументов", СписокДокументов);
	
	// отправка
	СписокДокументовПолучитьОтвет = Новый Массив;
	Для Каждого ДокВСД Из СписокДокументов Цикл
		Параметры.Отправитель_Площадка = ДокВСД.Получатель_Площадка;
		Статус = ВСД2_Входящий_ОтправитьГашение(Параметры, ДокВСД,, Ложь );
		
		//Если Статус="ACCEPTED" Тогда 			
		Если Статус = Перечисления.кб99_СтатусЗапроса.ACCEPTED Тогда 
			СписокДокументовПолучитьОтвет.Добавить( ДокВСД );		
		КонецЕсли;
	КонецЦикла;
	ВетИС_APIСервер.Пауза( Параметры["ПаузаСек"] );
	
	// ответ 
	Результаты = Новый Соответствие;
	Для Каждого ДокСсылка Из СписокДокументовПолучитьОтвет Цикл
		Параметры.Отправитель_Площадка = ДокСсылка.Получатель_Площадка;
		appID =  ВетИС_УтилитыКлиентСервер.НайтиApplicationID( ДокСсылка );
		Статус = ВСД2_Входящий_ГашениеПолучитьОтвет( Параметры, appID, ДокСсылка,,Ложь );	
		Для А=1 По 10 Цикл
			//Если (Статус="IN_PROCESS") Тогда
			Если Статус = Перечисления.кб99_СтатусЗапроса.IN_PROCESS Тогда 
				Статус =  ВСД2_Входящий_ГашениеПолучитьОтвет( Параметры, appID, ДокСсылка );	
			КонецЕсли;
		КонецЦикла;
		
		РезультатСтроки = Новый Структура;
		РезультатСтроки.Вставить("СтатусВСД", ДокСсылка.СтатусВСД);
		Результаты.Вставить(ДокСсылка, РезультатСтроки);
	КонецЦикла;	
	
	РезультатОбработки = Новый Структура();
	РезультатОбработки.Вставить("Статус", "Выполнено");
	РезультатОбработки.Вставить("ЗаданиеВыполнено", Истина);
	РезультатОбработки.Вставить("Результаты", Результаты);
	
	Если ЗначениеЗаполнено( АдресХранилища ) Тогда 
		ПоместитьВоВременноеХранилище(РезультатОбработки, АдресХранилища);	
	КонецЕсли;
	
	ВетИС_APIСервер.СообщитьИнфо("Отправка ВСД в Ветис завершена");	
	
КонецПроцедуры

Функция ВСД2_Входящий_ГашениеПолучитьОтвет(Параметры, appID, докСсылка, ВСД_Партия = Неопределено, СделатьПаузу = Истина ) Экспорт
	
	ВСД_Партия = Справочники.ВСД_Партия.ПустаяСсылка();
	
	Если НЕ(ЗначениеЗаполнено(appID)) Тогда
		ВетИС_APIСервер.СообщитьИнфо("Пустая ссылка applicationID","!");
		Возврат Ложь;
	КонецЕсли;
	
	Если СделатьПаузу Тогда 
		ВетИС_APIСервер.Пауза( Параметры["ПаузаСек"] );
	КонецЕсли;
	
	xdto = кб99_ВСД_Отправка.ПолучитьРезультатСервер( Параметры, appID );
	
	Ответ = ВетИС_APIСервер.СтатусЗапроса( xdto, докСсылка, Параметры );
	
	Если ВетИС_APIСервер.НайтиОшибки(xdto, докСсылка) Тогда
		Возврат Ответ;
	КонецЕсли;
	
	ПараметрыФункции = Новый Структура;
	ПараметрыФункции.Вставить("Параметры", Параметры);
	//ПараметрыФункции.Вставить("xdto", xdto);
	ПараметрыФункции.Вставить("ДокОснование", ДокСсылка);
	Параметры.Вставить("ЭтоВходящийВСД", ДокСсылка);
	ВетИС_API_ТранзакцииСервер.ЗагрузитьXML_ВСД2( ПараметрыФункции, xdto );
	
	ПартияОтвет = ВетИС_API_ПартииСервер.Партии_Ответ_ЗагрузитьXML( Параметры, xdto);
	ВСД_Партия = ПартияОтвет.Ссылка;
	
	Если ВетИС_ГашениеСервер.ФормироватьДвиженияПартий(ДокСсылка.Организация) И ЗначениеЗаполнено(ВСД_Партия) Тогда
		
		ДокВСДВходящий = Документы.ВСД2_входящий.СоздатьДокумент();
		ЗаполнитьЗначенияСвойств(ДокВСДВходящий, докСсылка);
		Если Не ЗначениеЗаполнено(ДокВСДВходящий.Получатель_Площадка) Тогда
			ДокВСДВходящий.Получатель_Площадка = Параметры.Отправитель_Площадка;;
		КонецЕсли;
		ДокВСДВходящий.Дата = ТекущаяДатаСеанса();
		ДокВСДВходящий.Партия = ВСД_Партия;
		ДокВСДВходящий.КоличествоПринять = ВСД_Партия.Количество;
		ДокВСДВходящий.КоличествоВозврат = ДокВСДВходящий.Количество - ДокВСДВходящий.КоличествоПринять;
		ДокВСДВходящий.Записать(РежимЗаписиДокумента.Проведение);
		
		СписокПартий = Новый Массив;
		СтруктураСтроки = Новый Структура("Партия, Количество", ВСД_Партия, ВСД_Партия.Количество);
		СписокПартий.Добавить(СтруктураСтроки);
		РегистрыСведений.кб99_ОстаткиПартийВетис.ЗаписатьОстаткиПартий(СписокПартий, ДокВСДВходящий.Ссылка);
		
	КонецЕсли;
	
	Возврат Ответ;
	
КонецФункциИ

Функция ВСД2_Входящий_НайтиПоUUID( _uuid ) экспорт 
	
	Если ЗначениеЗаполнено(_uuid) Тогда			
		Запрос = Новый Запрос("ВЫБРАТЬ
		|	ВСД2_входящий.Ссылка
		|ИЗ
		|	Документ.ВСД2_входящий КАК ВСД2_входящий
		|ГДЕ
		|	ВСД2_входящий.UUID = &UUID");
		
		Запрос.УстановитьПараметр("UUID", _Uuid );
		
		Результат = Запрос.Выполнить().Выбрать();
		
		Если Результат.Следующий() Тогда 
			ДокОб = Результат.Ссылка.ПолучитьОбъект();		
			ДокОб.Записать( РежимЗаписиДокумента.ОтменаПроведения, );
			ДокОб.УстановитьПометкуУдаления(Ложь);
			
			ВетИС_APIСервер.СообщитьИнфо("Найден "+ДокОб, ДокОб.Ссылка );			
		Иначе
			ДокОб = Документы.ВСД2_входящий.СоздатьДокумент();
			ВетИС_APIСервер.СообщитьИнфо("Создан новый "+ДокОб+" № "+ДокОб.Номер);
		КонецЕсли;	
	Иначе
		ВетИС_APIСервер.СообщитьИнфо("Пустой UUID");
	КонецЕсли;
	
	Возврат ДокОб;
	
КонецФункции

// @grace-contract: ПогаситьВсдОтИмениПолучателяСписком
//   Вход: ДокСсылка (ДокументСсылка.ВСД2_транзакция) — исходящая транзакция
//   Вход: СписокВСД (Массив) — массив структур с данными входящих ВСД
//   Выход: нет
//   GRACE:CONTRACT function="ПогаситьВсдОтИмениПолучателяСписком"
Процедура ПогаситьВсдОтИмениПолучателяСписком(ДокСсылка, СписокВСД) Экспорт
	
	Для Каждого строкаВсдВходящие Из СписокВСД Цикл 
		
		// LLM_NOTE: Гашению подлежат только транспортные ВСД (тип "TRANSPORT"). Фильтрация по типу - требование API ВетИС.
		Если строкаВсдВходящие.ТипВСД <> "TRANSPORT" Тогда 
			Продолжить;
		// LLM_NOTE: Гашение возможно только для ВСД со статусом CONFIRMED. Статусы "В работе" или "Черновик" не подлежат гашению.
		ИначеЕсли строкаВсдВходящие.СтатусВСД <> ПредопределенноеЗначение("Перечисление.кб99_СтатусВСД.CONFIRMED") Тогда 
			Продолжить;
		КонецЕсли;			
		
		Организация = ВетИС_ЯдроСервер.ПолучитьЗначениеРевизитаОбъекта_НаСервере(ДокСсылка, "Организация");
		ПараметрыОрганизации = ВетИС_ЯдроСервер.ЗагрузитьПараметры(Организация);
		
		// Настраиваем параметры для гашения от имени получателя
		ПараметрыОрганизации.Отправитель_ХозСубъект = ДокСсылка.Получатель_ХозСубъект;
		ПараметрыОрганизации.Отправитель_Площадка = ДокСсылка.Получатель_Площадка;
		
		// Создаем временный объект для гашения (т.к. API требует ДокументОбъект.ВСД2_входящий или аналогичный по структуре)
		// ВАЖНО: Мы не записываем этот документ, он нужен только как контейнер данных для формирования XML
		//ДокГашения = Документы.ВСД2_входящий.СоздатьДокумент();
		//ДокГашения.Дата = ТекущаяДатаСеанса();
		//ДокГашения.UUID = строкаВсдВходящие.UUID;
		//ДокГашения.Количество = строкаВсдВходящие.Количество;
		//ДокГашения.КоличествоПринять = строкаВсдВходящие.Количество;
		//ДокГашения.КоличествоВозврат = 0;
		//
		//// Копируем реквизиты из входящего ВСД для формирования XML
		//ЗаполнитьЗначенияСвойств(ДокГашения, строкаВсдВходящие);
		
		// Выполняем гашение
		ВСД2_Входящий_ОтправитьГашение(ПараметрыОрганизации, строкаВсдВходящие.ДокВСД);
		
	КонецЦикла;	
	
КонецПроцедуры

// GRACE:MODULE_END name="ВетИС_API_ВходящиеСервер"