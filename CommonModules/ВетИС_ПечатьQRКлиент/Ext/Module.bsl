// GRACE:MODULE_START name="ВетИС_ПечатьQRКлиент"
// @grace-module: ВетИС_ПечатьQRКлиент
// @grace-purpose: Формирование QR-кодов для печатных форм ВСД через внешнюю компоненту или ГенерацияШтрихкода
// @grace-depends: ВетИС_ЯдроСервер, ВетИС_УтилитыКлиентСервер
// @grace-version: 2.0
// @grace-contract-ref: docs/Contracts.xml -> module="ВетИС_ПечатьQRКлиент"
// GRACE:DEPENDENCY target="ВетИС_ЯдроСервер"
// GRACE:DEPENDENCY target="ВетИС_УтилитыКлиентСервер"

Функция КомпонентаФормированияQRКода(Отказ)
	
	СистемнаяИнформация = Новый СистемнаяИнформация;
	Платформа = СистемнаяИнформация.ТипПлатформы;
	
	ТекстОшибки = НСтр("ru = 'Не удалось подключить внешнюю компоненту для генерации QR-кода'");
	
	// LLM_NOTE: Подключение внешней компоненты для генерации QR-кода. Используется безопасный механизм
	// подключения через общий макет, что позволяет избежать проблем с развертыванием на клиентских машинах.
	// При ошибке подключения компоненты устанавливается флаг Отказ и возвращается Неопределено.
	Попытка
		Если ПодключитьВнешнююКомпоненту("ОбщийМакет.КомпонентаПечатиQRКода", "QR") Тогда
			QRCodeGenerator = Новый("AddIn.QR.QRCodeExtension");
		Иначе
			ВетИС_ЯдроСервер.СообщитьПользователю(ТекстОшибки, , , , Отказ);
		КонецЕсли
	Исключение
		ПодробноеПредставлениеОшибки = ПодробноеПредставлениеОшибки(ОписаниеОшибки());
		ВетИС_ЯдроСервер.СообщитьПользователю(ТекстОшибки + Символы.ПС + ПодробноеПредставлениеОшибки, , , , Отказ);
	КонецПопытки;
	
	Возврат QRCodeGenerator;
	
КонецФункции

// Возвращает двоичные данные для формирования QR кода
//
// Параметры:
//  QRСтрока         - Строка - данные, которые необходимо разместить в QR-коде.
//
//  УровеньКоррекции - Число - уровень погрешности изображения при котором данный QR-код все еще возможно 100% распознать.
//                     Параметр должен иметь тип целого и принимать одно из 4 допустимых значений:
//                     0(7% погрешности), 1(15% погрешности), 2(25% погрешности), 3(35% погрешности).
//
//  Размер           - Число - определяет длину стороны выходного изображения в пикселях.
//                     Если минимально возможный размер изображения больше этого параметра – код сформирован не будет.
//
//  ТекстОшибки      - Строка - в этот параметр помещается описание возникшей ошибки (если возникла).
//
// Возвращаемое значение:
//  Двоичные данные  - буфер, содержащий байты PNG-изображения QR-кода.
// 
// Пример:
//  
//  //Выводим на печать QR-код, содержащий в себе информацию зашифрованную по УФЭБС
//
//  QRСтрока = УправлениеПечатью.ФорматнаяСтрокаУФЭБС(РеквизитыПлатежа);
//  ТекстОшибки = "";
//  ДанныеQRКода = УправлениеПечатью.ДанныеQRКода(QRСтрока, 0, 190, ТекстОшибки);
//  Если Не ПустаяСтрока(ТекстОшибки)
//      ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
//  КонецЕсли;
//
//  КартинкаQRКода = Новый Картинка(ДанныеQRКода);
//  ОбластьМакета.Рисунки.QRКод.Картинка = КартинкаQRКода;
//
// GRACE:CONTRACT function="ДанныеQRКода"
Функция ДанныеQRКода(QRСтрока, УровеньКоррекции, Размер) Экспорт
	
	Отказ = Ложь;
	
	мГенерацииШК = ВетИС_УтилитыКлиентСервер.ОбщийМодуль("ГенерацияШтрихкода");
	
	Если мГенерацииШК <> Неопределено Тогда
		
		ДвоичныеДанныеКартинки = мГенерацииШК.ДанныеQRКода(QRСтрока, УровеньКоррекции, Размер);
		Если НЕ ТипЗнч(ДвоичныеДанныеКартинки) = Тип("ДвоичныеДанные") Тогда
			Возврат Неопределено;
		КонецЕсли;
		
    Иначе
		
		ГенераторQRКода = КомпонентаФормированияQRКода(Отказ);
		Если Отказ Тогда
			Возврат Неопределено;
		КонецЕсли;
		
		// LLM_NOTE: Генерация QR-кода через внешнюю компоненту. При ошибке генерации записывается
		// в журнал регистрации для диагностики, но функция возвращает Неопределено вместо исключения,
		// чтобы не прерывать процесс печати документа.
		Попытка
			ДвоичныеДанныеКартинки = ГенераторQRКода.GenerateQRCode(QRСтрока, УровеньКоррекции, Размер);
		Исключение
			// LLM_NOTE: #Если обязателен — ЗаписьЖурналаРегистрации и УровеньЖурналаРегистрации
			// недоступны в тонком клиенте, а модуль компилируется в 3 контекстах (Server + Client*).
			#Если Сервер ИЛИ ТолстыйКлиентОбычноеПриложение Тогда
			ЗаписьЖурналаРегистрации("Формирование QR-кода", УровеньЖурналаРегистрации.Ошибка, , ,
				ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			#КонецЕсли
			ДвоичныеДанныеКартинки = Неопределено;
		КонецПопытки;
								  
	КонецЕсли;
	
	Возврат ДвоичныеДанныеКартинки;
	
КонецФункции

// GRACE:MODULE_END name="ВетИС_ПечатьQRКлиент"
