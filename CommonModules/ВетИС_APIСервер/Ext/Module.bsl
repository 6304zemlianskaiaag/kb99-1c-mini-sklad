	КонецПопытки;
	//ЗафиксироватьТранзакцию();
	
КонецПроцедуры

Процедура СтатусЗапросаВПроцессе(ДокСсылка) Экспорт
	
	МенеджерЗаписи = РегистрыСведений.кб99_Запросы.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.Период = ТекущаяДата();
	МенеджерЗаписи.Объект = ДокСсылка;
	МенеджерЗаписи.СтатусЗапроса = "IN_PROCESS";
	МенеджерЗаписи.СтатусЗапросаПеречисление = Перечисления.кб99_СтатусЗапроса.IN_PROCESS;
	МенеджерЗаписи.Пользователь = ВетИС_ПараметрыСервер.ПолучитьТекущегоПользователя();
	МенеджерЗаписи.Записать();
	
КонецПроцедуры

// GRACE:CONTRACT function="СтатусЗапроса"
// LLM_NOTE: Обработка ответа XDTO от API ВетИС. Записывает статус в регистр сведений кб99_Запросы.
Функция СтатусЗапроса(xdto, ДокСсылка = Неопределено, Параметры = Неопределено) Экспорт
	
	Если xdto = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ВсеОшибки = "";
	Ответ = Ложь;
	Попытка
		response = xdto.Body.Последовательность().ПолучитьЗначение(0);
		
		Если ТипЗнч(response.application.errors.error)=Тип("СписокXDTO") Тогда
			errorsList = response.application.errors.error;
			КолвоОшибок = response.application.errors.error.Количество();
		Иначе
			КолвоОшибок = 1;
			errorsList = Новый Массив;
			errorsList.Добавить(response.application.errors.error);
		КонецЕсли;
		
		Для каждого errorItem ИЗ errorsList Цикл
			
			ТекстОшибки = errorItem.Последовательность().ПолучитьТекст(0);
			кодОшибки = errorItem.code;
			Попытка 
				НомерСтроки = " в строке " + errorItem.qualifier;
			Исключение
				НомерСтроки = "";
			КонецПопытки;
			
			Ответ = Истина;
			СтрОшибки = "ОШИБКА " + КодОшибки + НомерСтроки + " : " + ТекстОшибки + Символы.ПС;
			ВсеОшибки = ВсеОшибки + СтрОшибки;
		КонецЦикла;
	Исключение
		Ответ = Ложь;
	КонецПопытки;
	
	Попытка
		application = xdto.Body.Последовательность().ПолучитьЗначение(0).application;
		applicationID = application.applicationID;
		Статус = Перечисления.кб99_СтатусЗапроса[application.Status];
		
		Если ЗначениеЗаполнено(ДокСсылка) Тогда
			СообщитьИнфо("" + ДокСсылка + " статус = " + Статус, ДокСсылка);
		Иначе 
			СообщитьИнфо("Ответ = "+ Статус + " applicationID = " + applicationID);
		КонецЕсли;
		
	Исключение
		applicationID = "";
		Статус = "";
	КонецПопытки;
	
	МенеджерЗаписи = РегистрыСведений.кб99_Запросы.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.Период = ТекущаяДата();
	МенеджерЗаписи.Объект = ДокСсылка;
	//МенеджерЗаписи.Регистратор = ДокСсылка;
	МенеджерЗаписи.ApplicationID = ApplicationID;
	МенеджерЗаписи.СтатусЗапроса = Статус;
	МенеджерЗаписи.СтатусЗапросаПеречисление = Статус;
	МенеджерЗаписи.Пользователь = ВетИС_ПараметрыСервер.ПолучитьТекущегоПользователя();
	
	Если НЕ ЗначениеЗаполнено(applicationID) Тогда
		
		Фабрика = Новый ФабрикаXDTO;
		ЗаписьXML = Новый ЗаписьXML;
		ЗаписьXML.УстановитьСтроку();
		Фабрика.ЗаписатьXML(ЗаписьXML, xdto);
		МенеджерЗаписи.Ошибки = ЗаписьXML.Закрыть();
		
	Иначе
		
		МенеджерЗаписи.Ошибки = ВсеОшибки;
		
	КонецЕсли;
	
	Если (ЗначениеЗаполнено(Параметры) И Параметры["ОтладкаЗапросовXML"]) Тогда
		
		Параметры.Свойство("XML_Запрос", МенеджерЗаписи.Запрос);
		Параметры.Свойство("XML_Ответ", МенеджерЗаписи.Ответ);
		
		МенеджерЗаписи.Записать();
		
	ИначеЕсли ЗначениеЗаполнено(ДокСсылка) Тогда
		
		МенеджерЗаписи.Записать();
		
	КонецЕсли;
	
	Возврат Статус;
	
КонецФункции

// GRACE:CONTRACT function="СохранитьЗапросВРегистрСведений"
// LLM_NOTE: Сохранение HTTP-запросов в регистр сведений кб99_Запросы для аудита и отладки.
Процедура СохранитьЗапросВРегистрСведений(Параметры, xdto, ДокСсылка, applicationId, СтатусЗапроса)Экспорт
	
	Фабрика = Новый ФабрикаXDTO;
	ЗаписьXML = Новый ЗаписьXML;
	ЗаписьXML.УстановитьСтроку();
	Фабрика.ЗаписатьXML(ЗаписьXML, xdto);
	СтрокаXML = ЗаписьXML.Закрыть();
	
	МенеджерЗаписи = РегистрыСведений.кб99_Запросы.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.Период = ТекущаяДата();
	МенеджерЗаписи.Объект = ДокСсылка;
	МенеджерЗаписи.ApplicationID = ApplicationID;
	МенеджерЗаписи.СтатусЗапроса = СтатусЗапроса;
	МенеджерЗаписи.Пользователь = ВетИС_ПараметрыСервер.ПолучитьТекущегоПользователя();
	Если ЗначениеЗаполнено( Параметры ) И Параметры["ОтладкаЗапросовXML"] Тогда
		МенеджерЗаписи.Ответ = СтрокаXML;
	КонецЕсли;
	МенеджерЗаписи.Записать();
	
КонецПроцедуры

// GRACE:CONTRACT function="ЗаменитьСпецСимволы"
// LLM_NOTE: Экранирование специальных символов для корректного формирования XML-запросов к API Меркурий.
Функция ЗаменитьСпецСимволы(Стр) Экспорт
	
	Рез = СокрЛП(Стр);
	Рез = СтрЗаменить(Рез,"&" ,"&amp;" );
	Рез = СтрЗаменить(Рез,"""","&quot;");
	Рез = СтрЗаменить(Рез,"<" ,"&lt;"  );
	Рез = СтрЗаменить(Рез,">" ,"&gt;"  );
	Рез = СтрЗаменить(Рез,"'" ,"&#039;");
	Рез = СтрЗаменить(Рез,"№" ,"&#8470;");
	
	Возврат Рез;
	
КонецФункции

// GRACE:CONTRACT function="НайтиОшибки"
// LLM_NOTE: Парсинг ошибок из XDTO-ответа API ВетИС. Возвращает Истина при наличии ошибок.
Функция НайтиОшибки( xdto, ДокСсылка = Неопределено ) Экспорт
	
	Ответ = Ложь;
	
	Если xdto = Неопределено Тогда
		СтрОшибки = "Ошибка отправки запроса в ВетИС. Получен не корректный ответ сервера.";
		СообщитьИнфо(СтрОшибки);
		Возврат Истина;
	КонецЕсли;
	
	ВсеОшибки = "";
	Попытка
		response = xdto.Body.Последовательность().ПолучитьЗначение(0);
		
		Если ТипЗнч(response.application.errors.error)=Тип("СписокXDTO") Тогда
			errorsList = response.application.errors.error;
			КолвоОшибок = response.application.errors.error.Количество();
		Иначе
			КолвоОшибок = 1;
			errorsList = Новый Массив;
			errorsList.Добавить(response.application.errors.error);
		КонецЕсли;
		
		СообщитьИнфо("Ошибок = "+КолвоОшибок);
		Для каждого errorItem ИЗ errorsList Цикл
			
			ТекстОшибки = errorItem.Последовательность().ПолучитьТекст(0);
			кодОшибки = errorItem.code;
			Попытка
				НомерСтроки = " в строке " + errorItem.qualifier;
			Исключение
				НомерСтроки = "";
			КонецПопытки;
			
			Ответ = Истина;
			СтрОшибки = "ОШИБКА " + КодОшибки + НомерСтроки + " : " + ТекстОшибки;
			СообщитьИнфо(СтрОшибки);
			ВсеОшибки = ВсеОшибки + СтрОшибки;
		КонецЦикла;
		
	Исключение
		Ответ = Ложь;
	КонецПопытки;
	
	Возврат Ответ;
	
КонецФункции

