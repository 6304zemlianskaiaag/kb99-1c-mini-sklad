// GRACE:CONTRACT function="Сериализовать"
// LLM_NOTE: Сериализация объекта XDTO в XML-строку для отправки в API Меркурий.
Функция Сериализовать(ОбъектСериализации) Экспорт
	
	ДеревоВОбъектеXDTO = СериализаторXDTO.ЗаписатьXDTO(ОбъектСериализации);
	МойXML = Новый ЗаписьXML;
	МойXML.УстановитьСтроку();
	ФабрикаXDTO.ЗаписатьXML(МойXML, ДеревоВОбъектеXDTO);
	
	Возврат МойXML.Закрыть();
	
КонецФункции

// GRACE:CONTRACT function="Десериализовать"
// LLM_NOTE: Десериализация XML-строки в объект XDTO для обработки ответа от API Меркурий.
Функция Десериализовать(XMLСтруктураСериализованногоОбъекта) Экспорт
	
	ЧтениеXMLДанных = Новый ЧтениеXML;
	ЧтениеXMLДанных.УстановитьСтроку(XMLСтруктураСериализованногоОбъекта);
	Результат = СериализаторXDTO.ПрочитатьXML(ЧтениеXMLДанных);
	ЧтениеXMLДанных.Закрыть();
	
	Возврат Результат;
	
КонецФункции

#Область Функции_Дата

Функция ДатаXML(ВыбДата, Время="") Экспорт
	
	стрДата = формат(ВыбДата, "ДФ=""гггг-ММ-дд""") + Время;
	Возврат стрДата;
	
КонецФункции

Функция ДатаВремяXML(ВыбДата) Экспорт
	
	стрДата = формат(ВыбДата, "ДФ=""гггг-ММ-дд""")+"T" + Формат(ВыбДата,"ДФ=ЧЧ:мм:сс");
	Возврат стрДата;
	
КонецФункции

Функция ДатаСтрокаГод(ВыбДата) Экспорт
	
	Если ТипЗнч(ВыбДата) = Тип("Строка") Тогда
		зн = Лев(ВыбДата, 4);
	ИначеЕсли ТипЗнч(ВыбДата) = Тип("Дата") Тогда
		зн = Формат(ВыбДата, "ДФ=yyyy");
	Иначе
		зн = "";
		СообщитьИнфо("Неизвестный тип в параметрах функции")
	КонецЕсли;
	
	Если ЗначениеЗаполнено(зн) Тогда
		Ответ = "<dt:year>" + зн + "</dt:year>";
	Иначе
		Ответ = "";
	КонецЕсли;
	
	Возврат ответ;
	
КонецФункции

