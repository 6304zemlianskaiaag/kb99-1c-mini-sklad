Функция ДатаСтрокаЧас(ВыбДата) Экспорт
	
	Если ТипЗнч(ВыбДата) = Тип("Строка") Тогда
		зн = Сред(ВыбДата, 12, 2);
	ИначеЕсли ТипЗнч(ВыбДата) = Тип("Дата") Тогда
		зн = Формат(ВыбДата, "ДФ=HH");
	Иначе
		зн = "";
