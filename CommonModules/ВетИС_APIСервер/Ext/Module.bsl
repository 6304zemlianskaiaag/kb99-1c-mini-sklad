// GRACE:CONTRACT function="ПаузаCom"
// LLM_NOTE: Реализация паузы через COM-объект WScript.Shell (только для Windows). Используется как fallback.
Процедура ПаузаCom(ЗадержкаСекунд = 5) Экспорт
	
	Если Не ЗначениеЗаполнено(ЗадержкаСекунд) Тогда
		ЗадержкаСекунд = 5;
	КонецЕсли;
	СообщитьИнфо("Пауза " + ЗадержкаСекунд + " сек");
	СтрокаЗапроса = "Timeout /T " + Формат(ЗадержкаСекунд, "ЧГ=0") + " /NoBreak";
	WshShell = Новый COMОбъект("WScript.Shell");
	WshShell.Run(СтрокаЗапроса, 0, -1);
	
КонецПроцедуры 

Процедура Пауза(Секунд = 5) Экспорт
	
	Попытка
		ТекущийСеансИнформационнойБазы = ПолучитьТекущийСеансИнформационнойБазы();
		ФоновоеЗадание = ТекущийСеансИнформационнойБазы.ПолучитьФоновоеЗадание();
		
		Если ФоновоеЗадание = Неопределено Тогда
			//ЗаписьЖурналаРегистрации(
			//	НСтр("ru = 'Ошибка выполнения'"), 
			//	УровеньЖурналаРегистрации.Ошибка, 
			//	, 
			//	, 
			//	НСтр("ru = 'ВетИС_APIСервер.Пауза() разрешается использовать только в фоновом задании.'"));
			Параметры = Новый Массив;
			Параметры.Добавить(Секунд);
			ФоновоеЗадание = ФоновыеЗадания.Выполнить("ВетИС_APIСервер.Пауза", Параметры);
		КонецЕсли;
		
		ФоновоеЗадание.ОжидатьЗавершенияВыполнения(Секунд);
	Исключение
		ПаузаCom(Секунд);
	КонецПопытки;
	
КонецПроцедуры

