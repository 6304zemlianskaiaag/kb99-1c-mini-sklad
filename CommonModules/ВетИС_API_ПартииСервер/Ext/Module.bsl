Процедура УдалитьПартии(Параметры) Экспорт
	
	Если ЗначениеЗаполнено(Параметры["УдалятьПартии"]) Тогда
		УдалятьПартии = Параметры["УдалятьПартии"];
	Иначе
		УдалятьПартии = Ложь;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Параметры["ТолькоАктуальныеПартии"]) Тогда
		ТолькоАктуальныеПартии = Параметры["ТолькоАктуальныеПартии"];
	Иначе
		ТолькоАктуальныеПартии = Ложь;
	КонецЕсли;
	
	Предприятие = Параметры["ВыбПлощадка"];
	ПартияНачПериода = Параметры["ПартияНачПериода"];
	ПартияКонПериода = Параметры["ПартияКонПериода"];
	
	// При объединении партий в Меркурии - старые партии пропадают, появляются новые
	// поэтому в 1С остаются "остатки", которые нужно удалять
	колвоПартий = 0;
	Если УдалятьПартии И ТолькоАктуальныеПартии Тогда
		Выборка = Справочники.ВСД_Партия.Выбрать();
		Пока Выборка.Следующий() Цикл
			
			Если Выборка.Получатель_Площадка = Предприятие Тогда
				Если ЗначениеЗаполнено(ПартияНачПериода) Тогда
					Если (Выборка.ВСДДата < ПартияНачПериода) ИЛИ (Выборка.ВСДДата > ПартияКонПериода) Тогда
						Продолжить;
					КонецЕсли;
				КонецЕсли;
				СпрОбъект = Выборка.ПолучитьОбъект();
				СпрОбъект.УстановитьПометкуУдаления(Истина);
				колвоПартий = КолвоПартий + 1;
			КонецЕсли;
			
		КонецЦикла;
	КонецЕсли;
	
	ВетИС_APIСервер.СообщитьИнфо("Помечены на удаление " + колвоПартий + " ВСД_Партии");
	
КонецПроцедуры

Функция Партии2_Ответ_Получить(Знач Параметры, appID) Экспорт
	
	Если НЕ (ЗначениеЗаполнено(appID)) Тогда
		ВызватьИсключение("Пустая ссылка applicationID");
	КонецЕсли;
	
	ВетИС_APIСервер.Пауза(Параметры["ПаузаСек"]);
	
	xdto = кб99_ВСД_Отправка.ПолучитьРезультатСервер(Параметры, appID);
	
	Статус = ВетИС_APIСервер.СтатусЗапроса(xdto);
	Если ВетИС_APIСервер.НайтиОшибки(xdto) Тогда
		Возврат Статус;
	КонецЕсли;
	
	//Если Статус = "COMPLETED" Тогда
	Если Статус = Перечисления.кб99_СтатусЗапроса.COMPLETED Тогда
		Партии_Ответ_ЗагрузитьXML(Параметры, xdto);
	КонецЕсли;
	
	Возврат Статус;
	
КонецФункции

Функция Партии_Ответ_ЗагрузитьXML(Параметры, xdto) Экспорт
	
	Партия = Справочники.ВСД_Партия.ПустаяСсылка();
	
	Если ВетИС_APIСервер.НайтиОшибки(xdto) Тогда
		Возврат Партия;
	КонецЕсли;
	
	//Попытка
	//	ПришлоПартий = Число(xdto.Body.receiveApplicationResultResponse.application.result.getStockEntryListResponse.stockEntryList.count);
	//исключение
	//	ПришлоПартий = 1;
	//КонецПопытки;
	
	Попытка
		Response = xdto.Body.receiveApplicationResultResponse.application.result;
		Если НЕ (Response.Свойства().Получить("getStockEntryListResponse") = Неопределено) Тогда
			
			ПришлоПартий = Число(Response.getStockEntryListResponse.stockEntryList.count);
			Если ПришлоПартий > 0 Тогда
				
				seList = Response.getStockEntryListResponse.stockEntryList.StockEntry;
				
			КонецЕсли;
			
		ИначеЕсли НЕ (Response.Свойства().Получить("processIncomingConsignmentResponse") = Неопределено) Тогда
			Если Response.processIncomingConsignmentResponse.Свойства().Получить("stockEntry") <> Неопределено Тогда
				seList = Response.processIncomingConsignmentResponse.stockEntry;
				ПришлоПартий = 1;
			Иначе
				Возврат Партия;
			КонецЕсли
		ИначеЕсли НЕ(Response.Свойства().Получить("getStockEntryChangesListResponse") = Неопределено) Тогда
			Если Response.getStockEntryChangesListResponse.Свойства().Получить("stockEntryList") <> Неопределено Тогда
				ПришлоПартий = Число(Response.getStockEntryChangesListResponse.stockEntryList.count);
				
				Если ПришлоПартий > 0 Тогда
					
					seList = Response.getStockEntryChangesListResponse.stockEntryList.StockEntry;
					
				КонецЕсли;
				
			Иначе
				Возврат Партия;
			КонецЕсли
		ИначеЕсли НЕ (Response.Свойства().Получить("getStockEntryByGuidResponse") = Неопределено) Тогда
			seList = Response.getStockEntryByGuidResponse.stockEntry;
			ПришлоПартий = 1;
		Иначе
			ВетИС_APIСервер.СообщитьИнфо("В партия получили не обработанные ветки -> " + Response.Свойства().Получить(0));
			Возврат Партия;
		КонецЕсли;
		
	Исключение
		ВетИС_APIСервер.СообщитьИнфо(ОписаниеОшибки());
		Возврат Партия;
	КонецПопытки;
	
	Если Параметры["ВыводитьПодробнуюИнформацию"] Тогда
		ВетИС_APIСервер.СообщитьИнфо("Получено партий по запросу -> " + ПришлоПартий + " текущее смещение: " + Параметры["Смещение"]);
	КонецЕсли;
	
	Если ПришлоПартий > 0 Тогда // Иначе возникает ошибка если получено 0 партий
		
		УдалятьПартии = Ложь;
		Если Параметры.Свойство("УдалятьПартии", УдалятьПартии) Тогда
			Если УдалятьПартии Тогда
				УдалитьПартии(Параметры);
			КонецЕсли;
		КонецЕсли;
		
		Если ТипЗнч(seList) <> Тип("СписокXDTO") Тогда
			stockEntryList = Новый Массив;
			stockEntryList.Добавить(seList);
		Иначе
			stockEntryList = seList;
		КонецЕсли;
		
		СписокПартий = Новый Массив;
		
		Для Каждого stockEntry ИЗ stockEntryList Цикл
			
			Партия = Партия_Заполнить(Параметры, stockEntry);
			
			Если Партия <> Неопределено Тогда
				СписокПартий.Добавить(Партия.Ссылка);
			КонецЕсли;
			
		КонецЦикла;
		// входящий ВСД запишет движения в процедуре ВСД2_Входящий_ГашениеПолучитьОтвет
		Если ВетИС_ГашениеСервер.ФормироватьДвиженияПартий(Параметры.Организация) И Не Параметры.Свойство("ЭтоВходящийВСД") Тогда
			Параметры.Вставить("СписокПартий", СписокПартий);
			ВетИС_ЯдроСервер.ОформитьДокументПартииВСД(Параметры);
		КонецЕсли;
		
		Если ПришлоПартий = 1000 Тогда
			Если ЗначениеЗаполнено(Параметры["Смещение"]) Тогда
				Параметры["Смещение"] = Параметры["Смещение"] + 1000;
			Иначе
				Параметры["Смещение"] = 1000;
			КонецЕсли;
			Параметры["УдалятьПартии"] = Ложь;
			Если Параметры["ЗапросПартийСИзменениями"] Тогда
				
				Партии2_СИзменениями_Запрос_Отправить(Параметры);
				
			Иначе
				
				Партии2_Запрос_Отправить(Параметры);
				
			КонецЕсли;
			
		КонецЕсли;
	КонецЕсли;
	
	ВетИС_APIСервер.СообщитьИнфо("Загружено " + ПришлоПартий + " партий");
	
	Возврат Партия;
	
КонецФункции

Функция СписокПроизводителей_из_XML(Параметры, ProducerList) Экспорт
	
	Если ТипЗнч(ProducerList) = Тип("ОбъектXDTO") Тогда
		ProdList = Новый Массив;
		ProdList.Добавить(ProducerList);
	ИначеЕсли ТипЗнч(ProducerList) = Тип("СписокXDTO") Тогда
		ProdList = ProducerList;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
	ТзПроизводителей = Новый ТаблицаЗначений;
	ТзПроизводителей.Колонки.Добавить("Площадка", новый ОписаниеТипов("СправочникСсылка.ВСД_Площадка"));
	ТзПроизводителей.Колонки.Добавить("Роль", новый ОписаниеТипов("Строка"));
	ТзПроизводителей.Колонки.Добавить("Имя", новый ОписаниеТипов("Строка"));
	
	Попытка
		Для каждого producer ИЗ ProdList Цикл
			Попытка
				Если НЕ ЗначениеЗаполнено(producer.enterprise.guid) Тогда
					// Продолжить;
				КонецЕсли;
			Исключение
				ВетИС_APIСервер.СообщитьИнфо("Не указан ГУИД Производителя во входящем ВСД, возможно импортный. Гашение без ГУИД производителя м.б. Невозможно.");
				// Продолжить;
			КонецПопытки;
			
			СтрокаТЗ = ТзПроизводителей.Добавить();
			Попытка СтрокаТЗ.Имя = producer.enterprise.name; Исключение КонецПопытки;
			Попытка СтрокаТЗ.Площадка = ВетИС_API_ПлощадкиСервер.Площадка_НайтиПоGUID(Параметры, producer.enterprise.guid, Неопределено, Ложь, Истина); Исключение КонецПопытки;
			Попытка СтрокаТЗ.Роль = producer.role; Исключение СтрокаТЗ.Роль = "PRODUCER"; КонецПопытки;
		КонецЦикла;
	Исключение
	КонецПопытки;
	
	Возврат ТзПроизводителей;
	
КонецФункции

Процедура ЗаполнитьПроизводителей(Параметры, ДокОбъект, XdtoProducer) Экспорт
	
	ДокОбъект.Производители.Очистить();
	
	Производители = СписокПроизводителей_из_XML(Параметры, XdtoProducer);
	//Запишем одного ИЗ производителей в Реквизит
	Попытка
		ДокОбъект.Производитель_Площадка = Производители[0].Площадка;
	Исключение
	КонецПопытки;
	
	Для Каждого строкаВСД из Производители Цикл
		НоваяСтрока = ДокОбъект.Производители.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, строкаВСД);
	КонецЦикла;
	
КонецПроцедуры

Функция УровниУпаковки_из_XML(PList, Партия = "") Экспорт
	
	ТЗУровни = Новый ТаблицаЗначений;
	ТЗУровни.Колонки.Добавить("НомерУровня");
	ТЗУровни.Колонки.Добавить("ФормаУпаковки", новый ОписаниеТипов("СправочникСсылка.ВСД_ФормыУпаковки"));
	ТЗУровни.Колонки.Добавить("Количество", новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(12, 3)));
	ТЗУровни.Колонки.Добавить("тзМаркировки");
	
	Если ТипЗнч(Партия) = Тип("СправочникОбъект.ВСД_Партия") Тогда
		Партия.УровниУпаковки.Очистить();
		Партия.Маркировка.Очистить();
	КонецЕсли;
	
	Если ТипЗнч(PList) = Тип("ОбъектXDTO") Тогда
		PListArray = Новый Массив;
		PListArray.Добавить(PList);
	ИначеЕсли ТипЗнч(PList) = Тип("СписокXDTO") Тогда
		PListArray = PList;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
	Попытка
		Для каждого Узел ИЗ PListArray Цикл
			СтрУровня = ТЗУровни.Добавить();
			Попытка 
				СтрУровня.ФормаУпаковки = ВетИС_API_НСИСервер.НайтиФормуУпаковки(Узел.packingType.guid, Узел.packingType.name); 
			Исключение 
				КонецПопытки;
			СтрУровня.НомерУровня = Перечисления.кб99_УровниУпаковки.Получить(Узел.level - 1);
			Попытка 
				СтрУровня.Количество = Число(Узел.quantity);
			Исключение 
				КонецПопытки;
			
			тзМаркировка = Новый ТаблицаЗначений;
			тзМаркировка.Колонки.Добавить("НомерУровня");
			тзМаркировка.Колонки.Добавить("Класс");
			тзМаркировка.Колонки.Добавить("Маркировка");
			
			Попытка
				Маркировки = Узел.productMarks;
				Если ТипЗнч(Маркировки) = Тип("ОбъектXDTO") Тогда
					МаркМассив = Новый Массив;
					МаркМассив.Добавить(Маркировки);
				ИначеЕсли ТипЗнч(Маркировки) = Тип("СписокXDTO") Тогда
					МаркМассив = Маркировки;
				КонецЕсли;
				
				Для каждого МаркН ИЗ МаркМассив Цикл
					МаркЗнач = МаркН.Последовательность().ПолучитьТекст(0);
					МаркКласс = МаркН.class;
					строкаМаркировка = тзМаркировка.Добавить();
					строкаМаркировка.НомерУровня = Перечисления.кб99_УровниУпаковки.Получить(Узел.level - 1);
					строкаМаркировка.Класс = Перечисления.кб99_Маркировка[МаркКласс];
					строкаМаркировка.Маркировка = МаркЗнач;
				КонецЦикла;
			Исключение 
				КонецПопытки;
			СтрУровня.тзМаркировки = тзМаркировка;
		КонецЦикла;
	Исключение
		КонецПопытки;
	
	Возврат ТЗУровни;
	
КонецФункции

Процедура ЗаполнитьУровниУпаковки(ДокОбъект, XdtoPackage) Экспорт
	
	ДокОбъект.УровниУпаковки.Очистить();
	ДокОбъект.Маркировка.Очистить();
	
	УровниУпаковки = УровниУпаковки_из_XML(XdtoPackage);
	
	Для Каждого строкаУровень из УровниУпаковки Цикл
		НоваяСтрока = ДокОбъект.УровниУпаковки.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, строкаУровень);
		
		Для каждого стрМаркировка из строкаУровень.тзМаркировки Цикл
			НоваяСтрокаМаркировка = ДокОбъект.Маркировка.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрокаМаркировка, стрМаркировка);
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

Функция НайтиПартиюПоGUID(Guid) Экспорт
	
	Если ПустаяСтрока(Guid) = 0 Тогда
		Запрос = Новый Запрос("ВЫБРАТЬ
		|	ВСД_Партия.Ссылка
		|ИЗ
		|	Справочник.ВСД_Партия КАК ВСД_Партия
		|ГДЕ
		|	ВСД_Партия.GUID = &GUID");
		Запрос.УстановитьПараметр("GUID", Guid);
		
		Результат = Запрос.Выполнить().Выбрать();
		Если Результат.Следующий() Тогда
			Ответ = Результат.Ссылка.ПолучитьОбъект();
		Иначе
			Ответ = Справочники.ВСД_Партия.СоздатьЭлемент();
		КонецЕсли;
	Иначе
		ВетИС_APIСервер.СообщитьИнфо("Пустой Guid ВСД_Партия");
		Ответ = Справочники.ВСД_Партия.СоздатьЭлемент();
	КонецЕсли;
	
	Возврат Ответ;
	
КонецФункции

Функция Партия_Заполнить(Параметры, stockEntry, докСсылка = Неопределено) Экспорт
	
	Если Параметры.Свойство("ВыбПлощадка") Тогда
		ВыбПлощадка = Параметры["ВыбПлощадка"];
	Иначе
		ВыбПлощадка = Параметры["Отправитель_Площадка"];
	КонецЕсли;
	
	active = stockEntry.active;
	guid = stockEntry.guid;
	uuid = stockEntry.uuid;
	Статус = stockEntry.status;
	batch = stockEntry.batch;
	Количество = Число(batch.volume);
	
	Партия = НайтиПартиюПоGUID(guid);
	ЭтоНоваяПартия = Партия.ЭтоНовый();
	
	Если active = "false" Или Статус = "201" Или Количество = 0 Тогда
		Если Не ЗначениеЗаполнено(Партия.Ссылка) Тогда
			ВетИС_APIСервер.СообщитьИнфо("ВСД_Партия [" + stockEntry.batch.productItem.name + "] guid [" + guid + "] не активна. Партия пропущена.");
			Возврат Неопределено;
		Иначе
			ВетИС_APIСервер.СообщитьИнфо("ВСД_Партия [" + Партия + "] guid [" + guid + "] не активна. Партия удалена", Партия);
			Партия.Количество = Количество;
			Партия.Статус = Статус;
			Партия.ДатаИзменения = ВетИС_APIСервер.СтрокаВДату(stockEntry.updateDate);
			Партия.ПометкаУдаления = Истина;
			Партия.Записать();
			Возврат Партия;
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(докСсылка) Тогда
		Партия.докОснование = докСсылка;
	КонецЕсли;
	
	Партия.Статус = Статус;
	Партия.GUID = guid;
	Партия.UUID = stockEntry.uuid;
	Партия.НомерЗаписи = stockEntry.entryNumber;
	Партия.ДатаИзменения = ВетИС_APIСервер.СтрокаВДату(stockEntry.updateDate);
	Партия.ВсдДата = ВетИС_APIСервер.СтрокаВДату(stockEntry.createDate);
	Партия.Количество = Количество;
	
	Попытка
		Партия.ДатаИзготовления1 = ВетИС_APIСервер.Преобразовать_ДатаXML_в_Строку(batch.dateOfProduction.firstDate);
	Исключение
		Партия.ДатаИзготовления1 = "";
	КонецПопытки;
	
	Попытка
		Партия.ДатаИзготовления2 = ВетИС_APIСервер.Преобразовать_ДатаXML_в_Строку(batch.dateOfProduction.secondDate);
	Исключение
		Партия.ДатаИзготовления2 = "";
	КонецПопытки;
	
	Попытка Партия.ДатаИзготовления = batch.dateOfProduction.informalDate; Исключение КонецПопытки;
	
	Попытка
		Партия.ДатаСрокГодности1 = ВетИС_APIСервер.Преобразовать_ДатаXML_в_Строку(batch.expiryDate.firstDate);
	Исключение
		Партия.ДатаСрокГодности1 = "";
	КонецПопытки;
	
	Попытка
		Партия.ДатаСрокГодности2 = ВетИС_APIСервер.Преобразовать_ДатаXML_в_Строку(batch.expiryDate.secondDate);
	Исключение
		Партия.ДатаСрокГодности2 = "";
	КонецПопытки;
	
	Попытка Партия.ДатаСрокГодности = batch.expiryDate.informalDate; Исключение КонецПопытки;
	
	Попытка Партия.Получатель_ХозСубъект = ВетИС_API_ПлощадкиСервер.ХозСубъект_НайтиПоGUID(Параметры, batch.owner.guid, Ложь, Истина); Исключение КонецПопытки;
	
	Партия.Получатель_Площадка = ВыбПлощадка; //Отправитель_Площадка;
	
	Попытка Партия.vetDocument = НайтиВсдПоUUID(stockEntry.vetDocument.uuid); Исключение КонецПопытки;
	Если ЗначениеЗаполнено(Партия.vetDocument) Тогда
		Партия.ДокументПрихода = Партия.vetDocument.ДокументПрихода;
		Партия.НеКонтролироватьНаличиеДокументаПоступление = Партия.Получатель_ХозСубъект = Партия.vetDocument.Отправитель_ХозСубъект
			ИЛИ Партия.vetDocument.Отправитель_ХозСубъект.НеКонтролироватьНаличиеДокументаПоступление;
	КонецЕсли;
	// Номер Партии - м.б. несколько
	ВремНомерПартии = "";
	Попытка
		Если ТипЗнч(batch.batchID) <> Тип("СписокXDTO") Тогда
			ListbatchID = Новый Массив;
			ListbatchID.Добавить(batch.batchID);
		Иначе
			ListbatchID = batch.batchID;
		КонецЕсли;
		к = 0;
		Для Каждого batchID ИЗ ListbatchID Цикл
			Если к > 0 Тогда
				ВремНомерПартии = ВремНомерПартии + "; ";
			КонецЕсли;
			ВремНомерПартии = ВремНомерПартии + batchID;
			к = к + 1;
		КонецЦикла;
	Исключение КонецПопытки;
	
	Попытка Партия.НомерПартии = ВремНомерПартии; Исключение КонецПопытки;
	
	Продукция_Элемент = ВетИС_API_НСИСервер.Продукция_Элемент_Найти(Параметры, stockEntry.batch.productItem, Истина);
	Партия.Продукция_Элемент = Продукция_Элемент;
	
	// evg уровни упаковки можно поправить инвентаризацией
	Попытка
		ЗаполнитьУровниУпаковки(Партия, batch.packageList.package);
	Исключение
		КонецПопытки;
	
	Попытка
		Если ТипЗнч(stockEntry.vetEventList.laboratoryResearch) = Тип("ОбъектXDTO") Тогда
			тзЛабы = Новый Массив;
			тзЛабы.Добавить(stockEntry.vetEventList.laboratoryResearch);
		ИначеЕсли ТипЗнч(stockEntry.vetEventList.laboratoryResearch) = Тип("СписокXDTO") Тогда
			тзЛабы = stockEntry.vetEventList.laboratoryResearch;
		Иначе
			Возврат "";
		КонецЕсли;
		
		ПартияЛабы = Партия.ЛабораторныеИсследования;
		ПартияЛабы.Очистить();
		Для Каждого строкаЛаб ИЗ тзЛабы Цикл
			новстр = ПартияЛабы.добавить();
			Попытка новстр.наименованиеЛаборатории = строкалаб.operator.name; Исключение КонецПопытки;
			Попытка новстр.НомерЭкспертизы = строкалаб.expertiseID; Исключение КонецПопытки;
			Попытка новстр.заключение = строкалаб.conclusion; Исключение КонецПопытки;
			Попытка новстр.НаименованиеПоказателя = строкалаб.indicator.name; Исключение КонецПопытки;
			Попытка новстр.методИсследования = строкалаб.method.name; Исключение КонецПопытки;
			Попытка РезультатИсследования = Строкалаб.result; Исключение РезультатИсследования = ""; КонецПопытки;
			новстр.РезультатИсследования = Перечисления.кб99_РезультатИсследования[РезультатИсследования];
			Попытка новстр.ДатаРезультата = ВетИС_APIСервер.СтрокаВДату(строкалаб.actualDateTime); Исключение КонецПопытки;
			Попытка новстр.НомерАктаОтбораПроб = строкалаб.referencedDocument.issueNumber; Исключение КонецПопытки;
			Попытка новстр.ДатаОтбораПроб = ВетИС_APIСервер.СтрокаВДату(строкалаб.referencedDocument.issueDate); Исключение КонецПопытки;
		КонецЦикла;
	Исключение
	КонецПопытки;
	
	Партия.Продукция = ВетИС_API_НСИСервер.НайтиПродукцию(batch.product.guid);
	Партия.ВидПродукции = ВетИС_API_НСИСервер.НайтиВидПродукции(batch.subProduct.guid);
	Партия.НаименованиеПродукции = Партия.Продукция_Элемент.Наименование; //НаименованиеПродукции;
	Партия.Наименование = Партия.Продукция_Элемент.Наименование;
	Партия.ЕдиницаИзмерения = ВетИС_API_НСИСервер.НайтиЕдИзмерения(batch.unit.guid);
	
	Попытка
		Если ЗначениеЗаполнено(Партия.докОснование) И ТипЗнч(Партия.докОснование) = Тип("ДокументСсылка.ВСД2_Производство") Тогда
			Партия.Производитель_Площадка = Партия.докОснование.Производитель_Площадка;
		Иначе
			ЗаполнитьПроизводителей(Параметры, Партия, batch.origin.producer);
		КонецЕсли;
	Исключение КонецПопытки;
	
	Если Параметры.Свойство("ИсключитьИзПодбораПригашении") Тогда
		Партия.ИсключенаИзПодбора = Параметры.ИсключитьИзПодбораПригашении;
	КонецЕсли;
	
	Если ВетИС_УтилитыКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(batch.origin, "country") Тогда
		СтранаПроисхожденияGuid = batch.origin.country.guid;
		СтранаПроисхожденияName = batch.origin.country.name;
		Партия.СтранаПроисхождения = ВетИС_API_АдресаСервер.НайтиСтрануПоGUID(СтранаПроисхожденияGuid, СтранаПроисхожденияName);
		
		Если ЭтоНоваяПартия И ЗначениеЗаполнено(Партия.СтранаПроисхождения) Тогда
			Партия.ИсключенаИзПодбора = Партия.СтранаПроисхождения.ПомещатьПартииНаКарантин;
			Если Партия.ИсключенаИзПодбора Тогда
				ВетИС_APIСервер.СообщитьИнфо(" ВСД_Партия от " + Партия.ВсдДата + " # " + Партия.НомерЗаписи + " помещена на карантин.", Партия);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если active И Не Статус = "201" Тогда
		Партия.ПометкаУдаления = Ложь;
	КонецЕсли;
	
	Партия.Записать();
	
	ПоказатьНовыеПартии = Ложь;
	Если Параметры.Свойство("СписокНовыхПартий") И Параметры.Свойство("ПоказатьНовыеПартии", ПоказатьНовыеПартии) Тогда
		Если ПоказатьНовыеПартии И ЭтоНоваяПартия Тогда
			Параметры.СписокНовыхПартий.Добавить(Партия.Ссылка);
		КонецЕсли;
	КонецЕсли;
	
	ВетИС_APIСервер.СообщитьИнфо(" ВСД_Партия от " + Партия.ВсдДата + " # " + Партия.НомерЗаписи, Партия);
	
	Возврат Партия;
	
КонецФункции

Функция ProductItem_в_XML(СтрПартии, ПроверятьВидПродукцииПартииИProductItem = 0) Экспорт
	
	Запрос = "
	|<vd:productItem>";
	
	Если ЗначениеЗаполнено(СтрПартии.Продукция_Элемент.GUID) И НЕ(СтрПартии.Продукция_Элемент.ПометкаУдаления) Тогда
		// ПРОИЗВОДСТВО Обязательно должно быть заполнено хотя бы одно ИЗ полей: либо UUID, либо GUID. При указании обоих полей приоритет у UUID.
		Попытка
			Если ПроверятьВидПродукцииПартииИProductItem = 1 Тогда
				// При изменении Вида продукции у ProductItem возникнет ошибка при списании ранее полученной партии
				// Указанное наименование продукции относится к другому виду продукции.
				Если ЗначениеЗаполнено(СтрПартии.Партия) И (СтрПартии.Продукция_Элемент.ВидПродукции = СтрПартии.Партия.ВидПродукции) Тогда
					Запрос = Запрос + "
					|<bs:guid>" + СокрЛП(СтрПартии.Продукция_Элемент.GUID) + "</bs:guid>";
				КонецЕсли;
			Иначе
				Запрос = Запрос + "
				|<bs:guid>" + СокрЛП(СтрПартии.Продукция_Элемент.GUID) + "</bs:guid>";
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;
	
	Попытка
		Если ЗначениеЗаполнено(СтрПартии.GTIN) Тогда
			Запрос = Запрос + " <dt:globalID>" + СокрЛП(СтрПартии.GTIN) + "</dt:globalID>";
		КонецЕсли
	Исключение
	КонецПопытки;
	
	//Момент ниже возможно упростить
	Попытка //Производство
		Запрос = Запрос + ?(ЗначениеЗаполнено(СтрПартии.НаименованиеПродукции), "
		|<dt:name>" + ВетИС_APIСервер.ЗаменитьСпецСимволы(СтрПартии.НаименованиеПродукции) + "</dt:name>", "");
	Исключение // транзакция 
		Запрос = Запрос + ?(ЗначениеЗаполнено(СтрПартии.Продукция_Элемент), "
		|<dt:name>" + ВетИС_APIСервер.ЗаменитьСпецСимволы(СтрПартии.Продукция_Элемент.Наименование) + "</dt:name>", "");
	КонецПопытки;
	
	Попытка
		Запрос = Запрос + ?(ЗначениеЗаполнено(СтрПартии.Артикул), "
		|<dt:code>" + СокрЛП(СтрПартии.КодПродукции) + "</dt:code>", "");
	Исключение
	КонецПопытки;
	
	//Фасовка
	Попытка
		Если ЗначениеЗаполнено(СтрПартии.ФасовкаФормаУпаковки) Тогда
			Запрос = Запрос + "
			|<dt:packaging>
			|<dt:packagingType>
			|<bs:guid>" + СокрЛП(СтрПартии.ФасовкаФормаУпаковки.GUID) + "</bs:guid>
			//						<dt:globalID>BE</dt:globalID> 	dt:PackingCodeType 	[0..1] 	Уникальный идентификатор упаковки.
			|</dt:packagingType>
			|<dt:quantity>" + Формат(СтрПартии.ФасовкаКоличество, "ЧРД=.; ЧГ=0;ЧН=0") + "</dt:quantity>
			|<dt:volume>" + Формат(СтрПартии.ФасовкаОбъем, "ЧРД=.; ЧГ=0;ЧН=0") + "</dt:volume>
			|<dt:unit>
			|<bs:guid>" + СокрЛП(СтрПартии.ФасовкаЕдиницаИзмерения.GUID) + "</bs:guid>
			|</dt:unit>
			|</dt:packaging>";
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	Запрос = Запрос + "
	|</vd:productItem>";
	
	Возврат Запрос;
	
КонецФункции

Функция НомерПартий_из_XML(batch) Экспорт
	
	тзНомераПартий = Новый ТаблицаЗначений;
	тзНомераПартий.Колонки.Добавить("НомерПартии");
	
	Если ТипЗнч(batch.batchID) <> Тип("СписокXDTO") Тогда
		ListbatchID = Новый Массив;
		ListbatchID.Добавить(batch.batchID);
	Иначе
		ListbatchID = batch.batchID;
	КонецЕсли;
	
	Для Каждого batchID ИЗ ListbatchID Цикл
		СтрокаТЗ = тзНомераПартий.Добавить();
		СтрокаТЗ.НомерПартии = batchID;
	КонецЦикла;
	
	Возврат тзНомераПартий;
	
