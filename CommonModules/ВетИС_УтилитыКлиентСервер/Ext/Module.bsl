// Проверяет наличие метода в общем модуле
// 
// Параметры:
//  ИмяМодуля - Строка - имя общего модуля
//  ИмяМетода - Строка - имя метода (процедуры или функции)
// 
// Возвращаемое значение:
//  Булево - Истина, если метод существует и доступен
//
// GRACE:CONTRACT function="ЕстьМетодОбщегоМодуля"
// LLM_NOTE: Проверяет наличие метода в общем модуле через попытку вызова. Используется для динамической проверки API типовых конфигураций.
Функция ЕстьМетодОбщегоМодуля(ИмяМодуля, ИмяМетода) Экспорт
	
	Модуль = ОбщийМодуль(ИмяМодуля);
	Если Модуль = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Попытка
		// Используем Вычислить для проверки наличия метода
		// Если метода нет, будет вызвано исключение
		//@skip-check server-execution-safe-mode
		Результат = Вычислить(ИмяМодуля + "." + ИмяМетода + "()");
		Возврат Истина;
	Исключение
		// Ошибка может быть вызвана отсутствием метода или ошибкой в самом методе (если он не принимает 0 параметров)
		// Но для большинства методов БСП/типовых этого достаточно для проверки существования, 
		// либо нужно использовать более сложную проверку через метаданные (если это не общий модуль)
		
		// Для общих модулей в 1С нет штатного способа проверить наличие экспортного метода через метаданные
		// Поэтому используем проверку через описание ошибки
		ТекстОшибки = ОписаниеОшибки();
		Если Найти(ТекстОшибки, "Метод объекта не обнаружен") > 0 
			Или Найти(ТекстОшибки, "Процедура или функция с указанным именем не определена") > 0 Тогда
			Возврат Ложь;
		КонецЕсли;
		
		// Если ошибка другая (например, недостаточно фактических параметров), значит метод существует
		Возврат Истина;
	КонецПопытки;
	
КонецФункции

// Сворачивает массив, удаляя дубликаты
// 
// Параметры:
//  Массив - Массив - исходный массив
// 
// Возвращаемое значение:
//  Массив - массив без дубликатов
//
// GRACE:CONTRACT function="СвернутьМассив"
// LLM_NOTE: Удаляет дубликаты из массива. Использует промежуточную таблицу значений для свертки, что является платформенным методом.
Функция СвернутьМассив(Знач Массив) Экспорт
	
	Если Массив = Неопределено Тогда
		Возврат Новый Массив;
	КонецЕсли;
	
	// Используем ТаблицаЗначений для свертки (платформенный метод)
	ТаблицаЗначений = Новый ТаблицаЗначений;
	ТаблицаЗначений.Колонки.Добавить("Значение");
	
	Для Каждого ЗначениеМассива Из Массив Цикл
		НоваяСтрока = ТаблицаЗначений.Добавить();
		НоваяСтрока.Значение = ЗначениеМассива;
	КонецЦикла;
	
	ТаблицаЗначений.Свернуть("Значение");
	
	Возврат ТаблицаЗначений.ВыгрузитьКолонку("Значение");
	
КонецФункции

// Формирует строку из массива подстрок
// 
// Параметры:
//  Массив - Массив - массив строк
//  Разделитель - Строка - разделитель, по умолчанию ","
//  СокращатьНепечатаемыеСимволы - Булево - сокращать ли непечатаемые символы
// 
// Возвращаемое значение:
//  Строка - объединенная строка
//
// GRACE:CONTRACT function="СтрокаИзМассиваПодстрок"
// LLM_NOTE: Объединяет массив строк в одну строку с разделителем. Поддерживает опциональное сокращение непечатаемых символов.
Функция СтрокаИзМассиваПодстрок(Массив, Разделитель = ",", СокращатьНепечатаемыеСимволы = Ложь) Экспорт
	
	Результат = "";
	
	Для Каждого Элемент Из Массив Цикл
		
		Подстрока = Строка(Элемент);
		
		Если СокращатьНепечатаемыеСимволы Тогда
			Подстрока = СокрЛП(Подстрока);
		КонецЕсли;
		
		Если ПустаяСтрока(Результат) Тогда
			Результат = Подстрока;
		Иначе
			Результат = Результат + Разделитель + Подстрока;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Формирует представление периода для API ВЕТИС
// 
// Параметры:
//  НачалоПериода - Дата - начало периода
//  КонецПериода - Дата - конец периода
// 
// Возвращаемое значение:
//  Строка - представление периода в формате ВЕТИС
//
// GRACE:CONTRACT function="ПредставлениеПериодаВЕТИС"
// LLM_NOTE: Формирует представление периода для API ВЕТИС. Использует ТекущаяДатаСеанса для значений по умолчанию.
Функция ПредставлениеПериодаВЕТИС(Знач НачалоПериода = Неопределено, Знач КонецПериода = Неопределено) Экспорт 
	
	Если НачалоПериода = Неопределено Тогда
		НачалоПериода = ТекущаяДатаСеанса();
	КонецЕсли;
	
	Если КонецПериода = Неопределено Тогда
		КонецПериода = НачалоПериода;
	КонецЕсли;
	
	Если НачалоПериода = КонецПериода Тогда
		// Формат даты для ВЕТИС: YYYY-MM-DDThh:mm:ss (ISO 8601)
		Возврат Формат(НачалоПериода, "ДФ=yyyy-MM-ddTHH:mm:ss");
	Иначе
		Возврат Формат(НачалоПериода, "ДФ=yyyy-MM-ddTHH:mm:ss") + " - " + Формат(КонецПериода, "ДФ=yyyy-MM-ddTHH:mm:ss");
	КонецЕсли;
	
КонецФункции

