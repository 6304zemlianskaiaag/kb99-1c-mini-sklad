// GRACE:MODULE_START name="ВетИС_КомандыСервер"
// @grace-module: ВетИС_КомандыСервер
// @grace-purpose: Серверный командный слой UI: выполнение операций над элементами продукции (CREATE/UPDATE/DELETE) через вызов ВетИС_APIСервер
// @grace-depends: ВетИС_ЯдроСервер, ВетИС_ПараметрыСервер, ВетИС_APIСервер
// @grace-version: 2.0
// @grace-contract-ref: docs/Contracts.xml -> module="ВетИС_КомандыСервер"
// GRACE:DEPENDENCY target="кб99_ВСД"
// GRACE:DEPENDENCY target="ВетИС_ПараметрыСервер"
// GRACE:DEPENDENCY target="ВетИС_APIСервер"

// @grace-contract: кб99_ВыполнитьНаСервере
//   Вход: ПараметрКоманды (Массив/КоллекцияСтрок) — список элементов продукции с реквизитами (Площадка, и др.)
//   Вход: ВыбКоманда (Строка, необязат.) — код операции: "CREATE", или иное для UPDATE/DELETE
//   Выход: нет (результат применяется через ВетИС_APIСервер.Продукция_Элемент_Изменить)
//   Исключение: не бросает; при незаполненной Площадке выводит сообщение и пропускает элемент
//   Инвариант: каждый элемент обрабатывается независимо; ошибка одного не прерывает цикл
//   GRACE-лог: нет собственных точек — логирование делегировано вызываемым модулям
// GRACE:CONTRACT function="кб99_ВыполнитьНаСервере"
Процедура кб99_ВыполнитьНаСервере(ПараметрКоманды, ВыбКоманда = Неопределено) Экспорт
	
	Для Каждого Элемент Из ПараметрКоманды Цикл
		Если ВыбКоманда = "CREATE" Тогда
			
			// LLM_NOTE: Для операции CREATE организация берётся из ХозСубъекта Площадки, а не из настроек по умолчанию.
			// Это принципиально: производственная транзакция привязана к конкретному предприятию-производителю.
			// При незаполненной Площадке — мягкий Продолжить (не исключение), чтобы остальные элементы цикла обработались.
			Если ЗначениеЗаполнено(Элемент.Площадка) Тогда
				Организация = ВетИС_ЯдроСервер.ПолучитьОрганизациюПоХС(Элемент.Площадка.ХозСубъект);
			Иначе
				ВетИС_ЯдроСервер.СообщитьИнфо("Проверьте заполнение площадки производителя");
				Продолжить;
			КонецЕсли;
		Иначе
			Организация = ВетИС_ПараметрыСервер.ПолучитьОрганизациюПоУмолчанию();
		КонецЕсли;
		
		ПараметрыОрганизации = ВетИС_ЯдроСервер.ЗагрузитьПараметры(Организация);
		ВетИС_APIСервер.Продукция_Элемент_Изменить(ПараметрыОрганизации, Элемент, ВыбКоманда);
		
	КонецЦикла;
	
КонецПроцедуры

// @grace-contract: ОбновитьСтатусВСД_Фон
//   Вход: Параметры (Структура) — содержит ДокСсылка
//   Вход: АдресРезультата (Строка) — адрес во временном хранилище для результата
//   Выход: нет
//   GRACE:CONTRACT function="ОбновитьСтатусВСД_Фон"
Процедура ОбновитьСтатусВСД_Фон(Параметры, АдресРезультата) Экспорт
	
	ВетИС_ЯдроСервер.ОбновитьСтатусВСД(Параметры.ДокСсылка);
	
КонецПроцедуры

// @grace-contract: ПолучитьОтветВетис_Фон
//   Вход: Параметры (Структура) — содержит СписокДокументов
//   Вход: АдресРезультата (Строка) — адрес во временном хранилище для результата
//   Выход: нет
//   GRACE:CONTRACT function="ПолучитьОтветВетис_Фон"
Процедура ПолучитьОтветВетис_Фон(Параметры, АдресРезультата) Экспорт
	
	Для Каждого ДокСсылка Из Параметры.СписокДокументов Цикл
		
		ПараметрыОрганизации = ВетИС_ЯдроСервер.ЗагрузитьПараметры( ДокСсылка.Организация );

		Если ВетИС_УтилитыКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта( ДокСсылка, "Отправитель_Площадка" ) Тогда
			ПараметрыОрганизации.Отправитель_Площадка = ДокСсылка.Отправитель_Площадка;
		ИначеЕсли ВетИС_УтилитыКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта( ДокСсылка, "Производитель_Площадка" ) Тогда
			ПараметрыОрганизации.Отправитель_Площадка = ДокСсылка.Производитель_Площадка;
		ИначеЕсли ВетИС_УтилитыКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта( ДокСсылка, "Владелец_Площадка" ) Тогда
			ПараметрыОрганизации.Отправитель_Площадка = ДокСсылка.Владелец_Площадка;
		КонецЕсли;

		applicationID = ВетИС_УтилитыКлиентСервер.НайтиApplicationID( ДокСсылка );

		ПараметрФункции = Новый Структура();
		ПараметрФункции.Вставить("applicationID", applicationID);
		ПараметрФункции.Вставить("Параметры", ПараметрыОрганизации );
		ПараметрФункции.Вставить("ДокОснование", ДокСсылка );
		ПараметрФункции.Вставить("СделатьПаузу", Ложь );

		ВетИС_APIСервер.ПолучитьРезультат_ВСД2( ПараметрФункции );

	КонецЦикла;
	
КонецПроцедуры

// @grace-contract: ОтправитьВСДсГашением_Фон
//   Вход: Параметры (Структура) — содержит ДокСсылка
//   Вход: АдресРезультата (Строка) — адрес во временном хранилище для результата
//   Выход: нет
//   GRACE:CONTRACT function="ОтправитьВСДсГашением_Фон"
Процедура ОтправитьВСДсГашением_Фон(Параметры, АдресРезультата) Экспорт
	
	ДокСсылка = Параметры.ДокСсылка;
	Организация = ВетИС_ЯдроСервер.ПолучитьЗначениеРевизитаОбъекта_НаСервере(ДокСсылка, "Организация");
	ПараметрыОрганизации = ВетИС_ЯдроСервер.ЗагрузитьПараметры(Организация);
    ПараметрыОрганизации.Отправитель_Площадка = ДокСсылка.Отправитель_Площадка;
	
	ПараметрыФункции = Новый Структура;
	ПараметрыФункции.Вставить("ДокОснование", ДокСсылка);
	ПараметрыФункции.Вставить("СписокПартий", Новый Массив);
    ПараметрыФункции.Вставить("Отправитель_Площадка", ДокСсылка.Отправитель_Площадка);
	
	Ответ = ВетИС_APIСервер.ВСД2_транзакция_Отправить(ПараметрыФункции);

	Если Строка(Ответ) = "Завершен" Тогда
		ТаблицаВсдДляГашения = Новый Массив;
		Если ПараметрыФункции.Свойство("ВсдРезультатМассив", ТаблицаВсдДляГашения) Тогда
			// Выполняем гашение на сервере. 
			// ВАЖНО: В фоне мы не можем открыть форму гашения (UI), 
			// поэтому используем серверный метод API напрямую.
			ВетИС_API_ВходящиеСервер.ПогаситьВсдОтИмениПолучателяСписком(ДокСсылка, ТаблицаВсдДляГашения);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

// @grace-contract: ПогаситьВсдОтИмениПолучателя_Фон
//   Вход: Параметры (Структура) — содержит ДокСсылка
//   Вход: АдресРезультата (Строка) — адрес во временном хранилище для результата
//   Выход: нет
//   GRACE:CONTRACT function="ПогаситьВсдОтИмениПолучателя_Фон"
Процедура ПогаситьВсдОтИмениПолучателя_Фон(Параметры, АдресРезультата) Экспорт
	
	ДокСсылка = Параметры.ДокСсылка;
	
	мВсдВходящие = Новый Массив;
	Организация = ВетИС_ЯдроСервер.ПолучитьЗначениеРевизитаОбъекта_НаСервере(ДокСсылка, "Организация");
	ПараметрыОрганизации = ВетИС_ЯдроСервер.ЗагрузитьПараметры( Организация );				
	applicationID = ВетИС_УтилитыКлиентСервер.НайтиApplicationID( ДокСсылка );
	
	ПараметрФункции = Новый Структура();
	ПараметрФункции.Вставить("applicationID", applicationID);
	ПараметрФункции.Вставить("Параметры", ПараметрыОрганизации );
	ПараметрФункции.Вставить("ДокОснование", ДокСсылка );
	ПараметрФункции.Вставить("СделатьПаузу", Ложь );
	ПараметрФункции.Вставить("ВсдРезультатМассив", мВсдВходящие);
	
	// Получаем результат обработки ВСД (входящие ВСД)
	Ответ = ВетИС_APIСервер.ПолучитьРезультат_ВСД2( ПараметрФункции );	
	
	Если Ответ = ПредопределенноеЗначение("Перечисление.кб99_СтатусЗапроса.COMPLETED") Тогда
		ВетИС_API_ВходящиеСервер.ПогаситьВсдОтИмениПолучателяСписком( ДокСсылка, мВсдВходящие );
	КонецЕсли;
	
КонецПроцедуры

// @grace-contract: ПолучитьСписокВСД_Фон
//   Вход: Параметры (Структура) — содержит ПараметрыЗапроса
//   Вход: АдресРезультата (Строка) — адрес во временном хранилище для результата
//   Выход: нет
//   GRACE:CONTRACT function="ПолучитьСписокВСД_Фон"
Процедура ПолучитьСписокВСД_Фон(Параметры, АдресРезультата) Экспорт
	
	ПараметрыЗапроса = Параметры.ПараметрыЗапроса;
	
	Результат = ВетИС_APIСервер.ПолучитьСписокВСД(ПараметрыЗапроса);
	
	РезультатОбработки = Новый Структура;
	РезультатОбработки.Вставить("ВсдРезультатМассив", ПараметрыЗапроса.ВсдРезультатМассив);
	РезультатОбработки.Вставить("Статус", "Выполнено");
	
	ПоместитьВоВременноеХранилище(РезультатОбработки, АдресРезультата);
	
КонецПроцедуры

// @grace-contract: ПолучитьСписокВСДПоВсемПлощадкам_Фон
//   Вход: Параметры (Структура) — содержит СписокПлощадок, ПараметрыЗапросаШаблон
//   Вход: АдресРезультата (Строка) — адрес во временном хранилище для результата
//   Выход: нет
//   GRACE:CONTRACT function="ПолучитьСписокВСДПоВсемПлощадкам_Фон"
Процедура ПолучитьСписокВСДПоВсемПлощадкам_Фон(Параметры, АдресРезультата) Экспорт
	
	СписокПлощадок = Параметры.СписокПлощадок;
	ПараметрыЗапросаШаблон = Параметры.ПараметрыЗапросаШаблон;
	
	МассивВходящихВСД = Новый Массив;
	
	Для Каждого Площадка Из СписокПлощадок Цикл
		
		ПараметрыЗапроса = Новый Структура;
		Для Каждого КлючИЗначение Из ПараметрыЗапросаШаблон Цикл
			ПараметрыЗапроса.Вставить(КлючИЗначение.Ключ, КлючИЗначение.Значение);
		КонецЦикла;
		
		ПараметрыЗапроса.Вставить("ПолучательПлощадка", Площадка);
		ПараметрыЗапроса.Вставить("ВсдРезультатМассив", МассивВходящихВСД);
		
		ВетИС_APIСервер.ПолучитьСписокВСД(ПараметрыЗапроса);
		
	КонецЦикла;
	
	РезультатОбработки = Новый Структура;
	РезультатОбработки.Вставить("ВсдРезультатМассив", МассивВходящихВСД);
	РезультатОбработки.Вставить("Статус", "Выполнено");
	
	ПоместитьВоВременноеХранилище(РезультатОбработки, АдресРезультата);
	
КонецПроцедуры

// @grace-contract: ГашениеВСД_Фон
//   Вход: Параметры (Структура) — содержит СписокВСД, ПараметрыОрганизации, флАктНесоответствия, тПричинаАкта, тОписаниеНесоответствия, ИсключитьИзПодбораПригашении
//   Вход: АдресРезультата (Строка) — адрес во временном хранилище для результата
//   Выход: нет
//   GRACE:CONTRACT function="ГашениеВСД_Фон"
Процедура ГашениеВСД_Фон(Параметры, АдресРезультата) Экспорт
	
	СписокВСД = Параметры.СписокВСД;
	ПараметрыОрганизации = Параметры.ПараметрыОрганизации;
	
	Результаты = Новый Соответствие;
	
	Для Каждого СтрокаВСД Из СписокВСД Цикл
		
		ДокВСД = СтрокаВСД.ДокВСД;
		
		// Настраиваем параметры для конкретного документа
		ПараметрыОрганизации.Отправитель_Площадка = ДокВСД.Получатель_Площадка;
		ПараметрыОрганизации.Вставить("флАктНесоответствия", Параметры.флАктНесоответствия);
		ПараметрыОрганизации.Вставить("тПричинаАкта", Параметры.тПричинаАкта);
		ПараметрыОрганизации.Вставить("тОписаниеНесоответствия", Параметры.тОписаниеНесоответствия);
		ПараметрыОрганизации.Вставить("ИсключитьИзПодбораПригашении", Параметры.ИсключитьИзПодбораПригашении);
		
		// Выполняем гашение
		СтатусЗапроса = ВетИС_API_ВходящиеСервер.ВСД2_Входящий_ОтправитьГашение(ПараметрыОрганизации, ДокВСД, СтрокаВСД.ВСД_Партия);
		
		РезультатСтроки = Новый Структура;
		РезультатСтроки.Вставить("СтатусЗапроса", СтатусЗапроса);
		РезультатСтроки.Вставить("СтатусВСД", ДокВСД.СтатусВСД);
		РезультатСтроки.Вставить("ВСД_Партия", СтрокаВСД.ВСД_Партия);
		
		Результаты.Вставить(ДокВСД, РезультатСтроки);
		
	КонецЦикла;
	
	РезультатОбработки = Новый Структура;
	РезультатОбработки.Вставить("Статус", "Выполнено");
	РезультатОбработки.Вставить("Результаты", Результаты);
	
	ПоместитьВоВременноеХранилище(РезультатОбработки, АдресРезультата);
	
КонецПроцедуры

// @grace-contract: ОбновитьТранспорт_Фон
//   Вход: Параметры (Структура) — содержит СписокДокументов, ПараметрыОрганизации
//   Вход: АдресРезультата (Строка) — адрес во временном хранилище для результата
//   Выход: нет
//   GRACE:CONTRACT function="ОбновитьТранспорт_Фон"
Процедура ОбновитьТранспорт_Фон(Параметры, АдресРезультата) Экспорт
	
	СписокДокументов = Параметры.СписокДокументов;
	ПараметрыОрганизации = Параметры.ПараметрыОрганизации;
	
	Результаты = Новый Соответствие;
	
	Для Каждого ДокОбновитьТранспорт Из СписокДокументов Цикл
		
		ПараметрыФункции = Новый Структура();
		ПараметрыФункции.Вставить("ДокОснование", ДокОбновитьТранспорт);
		ПараметрыФункции.Вставить("Параметры", ПараметрыОрганизации);
		
		СтатусЗапроса = ВетИС_APIСервер.ВСД2_ОбновитьТранспорт_Отправить(ПараметрыФункции);
		
		РезультатСтроки = Новый Структура;
		РезультатСтроки.Вставить("СтатусЗапроса", СтатусЗапроса);
		
		Результаты.Вставить(ДокОбновитьТранспорт, РезультатСтроки);
		
	КонецЦикла;
	
	РезультатОбработки = Новый Структура;
	РезультатОбработки.Вставить("Статус", "Выполнено");
	РезультатОбработки.Вставить("Результаты", Результаты);
	
	ПоместитьВоВременноеХранилище(РезультатОбработки, АдресРезультата);
	
КонецПроцедуры

// @grace-contract: ПроверитьУсловияПеревозки_Фон
//   Вход: Параметры (Структура) — содержит ДокСсылка
//   Вход: АдресРезультата (Строка) — адрес во временном хранилище для результата
//   Выход: нет
//   GRACE:CONTRACT function="ПроверитьУсловияПеревозки_Фон"
Процедура ПроверитьУсловияПеревозки_Фон(Параметры, АдресРезультата) Экспорт
	
	ДокСсылка = Параметры.ДокСсылка;
	
	Если НЕ (ЗначениеЗаполнено(ДокСсылка.Отправитель_Площадка)
						И ЗначениеЗаполнено(ДокСсылка.Получатель_Площадка)
						И ДокСсылка.Получатель_Площадка.Регион <> ДокСсылка.Отправитель_Площадка.Регион) Тогда 
		Возврат;
	КонецЕсли;

	ПараметрыОрганизации = ВетИС_ЯдроСервер.ЗагрузитьПараметры(ДокСсылка.Организация);
	ВетИС_APIСервер.ВСД2_Транзакция_УсловияПеревозки_Отправить(ПараметрыОрганизации, ДокСсылка, Истина);
	
КонецПроцедуры
// GRACE:MODULE_END name="ВетИС_КомандыСервер"