// GRACE:MODULE_START name="ВетИС_КомандыКлиент"
// @grace-module: ВетИС_КомандыКлиент
// @grace-purpose: Клиентский командный слой UI: подтверждение операций пользователем и делегирование выполнения серверному модулю
// @grace-depends: ВетИС_КомандыСервер
// @grace-version: 2.0
// @grace-contract-ref: docs/Contracts.xml -> module="ВетИС_КомандыКлиент"
// GRACE:DEPENDENCY target="ВетИС_КомандыСервер"

// @grace-contract: кб99_ОбработкаОтвета
//   Вход: Ответ (КодВозвратаДиалога) — ответ пользователя на диалог подтверждения
//   Вход: ДопПараметры (Структура) — содержит ПараметрФункции.ПараметрКоманды, ПараметрФункции.ПараметрыВыполненияКоманды, СтруктураКоманды
//   Выход: нет (побочный эффект: вызов сервера и обновление формы)
//   Исключение: не бросает явно; при отмене (Ответ <> Да) — ничего не делает
//   Инвариант: серверный вызов происходит только при явном подтверждении пользователем
//   GRACE-лог: нет собственных точек — логирование делегировано ВетИС_КомандыСервер
// GRACE:CONTRACT function="кб99_ОбработкаОтвета"
Процедура кб99_ОбработкаОтвета(Ответ, ДопПараметры) Экспорт

	Если Ответ = КодВозвратаДиалога.Да Тогда
		Состояние(ДопПараметры.СтруктураКоманды.ТекстСостояния,, "Ожидайте...", БиблиотекаКартинок.kb99_wrench);

		// LLM_NOTE: Вызов серверного модуля происходит здесь, а не в кб99_ОбработкаКоманды,
		// потому что ПоказатьВопрос — асинхронный. Прямой вызов сервера до подтверждения невозможен.
		// Архитектура: клиент → диалог → callback → сервер.
		ВетИС_КомандыСервер.кб99_ВыполнитьНаСервере(ДопПараметры.ПараметрФункции.ПараметрКоманды, ДопПараметры.СтруктураКоманды.ВыбКоманда);

		ДопПараметры.ПараметрФункции.ПараметрыВыполненияКоманды.Источник.ЭтаФорма.ОбновитьОтображениеДанных();
		ПоказатьОповещениеПользователя("Операция завершена");
	КонецЕсли;

КонецПроцедуры

// @grace-contract: кб99_ОбработкаКоманды
//   Вход: ПараметрКоманды (Массив/КоллекцияСтрок) — список элементов продукции для операции
//   Вход: ПараметрыВыполненияКоманды (СтруктураПараметровВыполненияКоманды) — контекст выполнения команды из UI
//   Вход: СтруктураКоманды (Структура) — содержит ТекстВопроса, ТекстСостояния, ВыбКоманда
//   Выход: нет (запускает асинхронный диалог подтверждения)
//   Исключение: не бросает
//   Инвариант: всегда показывает диалог "Да/Нет" перед выполнением — пользователь должен явно подтвердить
//   GRACE-лог: нет собственных точек
// GRACE:CONTRACT function="кб99_ОбработкаКоманды"
Процедура кб99_ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды, СтруктураКоманды) Экспорт

	// LLM_NOTE: ДопПараметры упакованы в Структуру, чтобы передать несколько значений
	// через единственный параметр ОписаниеОповещения. Это стандартный паттерн асинхронных вызовов 1С.
	// Не заменять на глобальные переменные — модуль может вызываться параллельно из нескольких форм.
	ПараметрФункции = Новый Структура("ПараметрКоманды, ПараметрыВыполненияКоманды", ПараметрКоманды, ПараметрыВыполненияКоманды);

	ДопПараметры = Новый Структура;
	ДопПараметры.Вставить("ПараметрФункции" , ПараметрФункции);
	ДопПараметры.Вставить("СтруктураКоманды", СтруктураКоманды);

	Оповещение = Новый ОписаниеОповещения("кб99_ОбработкаОтвета", ВетИС_КомандыКлиент, ДопПараметры);
	ПоказатьВопрос(Оповещение, СтруктураКоманды.ТекстВопроса, РежимДиалогаВопрос.ДаНет,, КодВозвратаДиалога.Да);

КонецПроцедуры
// GRACE:MODULE_END name="ВетИС_КомандыКлиент"
