// GRACE:CONTRACT function="УстановитьОтборыДинамическихСписковПриОткрытии"
Процедура УстановитьОтборыДинамическихСписковПриОткрытии(Форма) Экспорт
	
	Если Форма.Элементы.Найти("Запросы") <> Неопределено Тогда
		ЭлементОтбора = Форма.дсЗапросы.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект");
		ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно; 
		ЭлементОтбора.РежимОтображения = РежимОтображенияЭлементаНастройкиКомпоновкиДанных.БыстрыйДоступ; 
		ЭлементОтбора.ПравоеЗначение = Форма.Объект.Ссылка;
	КонецЕсли;
	
	Если Форма.Элементы.Найти("дсОстаткиПартий") <> Неопределено Тогда
		ЭлементОтбора = Форма.дсОстаткиПартий.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ДокументДвижения");
		ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно; 
		ЭлементОтбора.РежимОтображения = РежимОтображенияЭлементаНастройкиКомпоновкиДанных.БыстрыйДоступ; 
		ЭлементОтбора.ПравоеЗначение = Форма.Объект.Ссылка;
	КонецЕсли;
	
	Если Форма.Элементы.Найти("ТаблицаВСД") <> Неопределено Тогда
		ЭлементОтбора = Форма.дсВСД.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ДокументОснование");
		ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно; 
		ЭлементОтбора.РежимОтображения = РежимОтображенияЭлементаНастройкиКомпоновкиДанных.БыстрыйДоступ; 
		ЭлементОтбора.ПравоеЗначение = Форма.Объект.Ссылка;
	КонецЕсли;

КонецПроцедуры

// GRACE:CONTRACT function="СоздатьИлиОткрытьКорректировкуВСД"
Процедура СоздатьИлиОткрытьКорректировкуВСД( ДокОснование ) Экспорт
	
	// LLM_NOTE: Поиск существующего документа корректировки ВСД. Если документ уже создан,
	// открывается существующий, иначе создается новый на основании.
	// Проверяем наличие существующего документа
	ДокументКорректировкиВСД = ВетИС_ЯдроСервер.НайтиСуществующийДокументКорректировкаВСД(ДокОснование);
	
	ПараметрыФормы = Новый Структура;
	Если ЗначениеЗаполнено(ДокументКорректировкиВСД) Тогда
		ПараметрыФормы.Вставить("Ключ", ДокументКорректировкиВСД);
	Иначе
		ПараметрыФормы.Вставить("Основание", ДокОснование);
	КонецЕсли;
	
	ОткрытьФорму("Документ.ВСД2_КорректировкаРеализации.ФормаОбъекта", ПараметрыФормы);
		
КонецПроцедуры

// GRACE:CONTRACT function="СоздатьИлиОткрытьПроизводственныйВСД"
Процедура СоздатьИлиОткрытьПроизводственныйВСД( ДокОснование ) Экспорт
	
	Организация = ВетИС_ЯдроСервер.ПолучитьЗначениеРевизитаОбъекта_НаСервере(ДокОснование, "Организация");
	ПараметрыОрганизации = ВетИС_ЯдроСервер.ЗагрузитьПараметры( Организация );

	Если НЕ ЗначениеЗаполнено(ПараметрыОрганизации["ПарамРазрешитьВводНаОснованииБолееОдногоВСД"] ) Тогда
		ВетИС_ЯдроСервер.СообщитьИнфо("Сохраните параметры для Организации " + Организация);
		Возврат;
	КонецЕсли;			
	
	Если НЕ ПараметрыОрганизации["ПарамРазрешитьВводНаОснованииБолееОдногоВСД"] Тогда		
		ДокВСД = ВетИС_ЯдроСервер.НайтиВСД_Производство( ДокОснование );
		Если ЗначениеЗаполнено(ДокВСД) Тогда
			ВетИС_ЯдроСервер.СообщитьИнфо("Уже создан "+ДокВСД, ДокВСД);				
			мНеОткрыватьФормуДокумента = Истина;
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	Если ПараметрыОрганизации["ПроизводствоРазбиватьПострочно"] Тогда
		мсДокументов = ВетИС_ПроизводствоСервер.ОформитьПроизводствоПострочно(ПараметрыОрганизации, ДокОснование);
		Для Каждого Документ Из мсДокументов Цикл
			ОткрытьФорму("Документ.ВСД2_Производство.ФормаОбъекта", Новый Структура("Ключ", Документ));	
		КонецЦикла;
	Иначе
		ОткрытьФорму("Документ.ВСД2_Производство.ФормаОбъекта", Новый Структура("Основание", ДокОснование));
