				СпрОбъект.Записать();
			Иначе
				ВетИС_APIСервер.СообщитьИнфо("ВСД_Регион [" + name + "] GUID [" + guid + "] добавлена");
				Спр = Справочники.ВСД_Регион.СоздатьЭлемент();
				Спр.Наименование = name;
				Спр.GUID = guid;
				Спр.UUID = _UUID;
				Спр.Владелец = _Страна;
				Спр.Записать();
				Ответ = Спр.Ссылка;
			КонецЕсли;
		КонецЦикла;
		
