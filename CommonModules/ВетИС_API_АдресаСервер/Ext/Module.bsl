	Возврат Ответ;
	
КонецФункции

Функция Список_Улиц_ЗапросXML(guid, Параметры) Экспорт
	
	Запрос = "<SOAP-ENV:Envelope xmlns:SOAP-ENV='http://schemas.xmlsoap.org/soap/envelope/'
	|xmlns:ws='http://api.vetrf.ru/schema/cdm/registry/ws-definitions/v2'
	|xmlns:base='http://api.vetrf.ru/schema/cdm/base'
	|xmlns:ikar='http://api.vetrf.ru/schema/cdm/dictionary/v2'>
	|<SOAP-ENV:Header/>
	|<SOAP-ENV:Body>
	|<ws:getStreetListByLocalityRequest>
	|<base:listOptions>
	|<base:count>1000</base:count>
	|<base:offset>" + Формат(Параметры["Смещение"], "ЧДЦ=0; ЧН=0; ЧГ=") + "</base:offset>
	|</base:listOptions>
	|<ikar:localityGuid>" + guid + "</ikar:localityGuid>
	|</ws:getStreetListByLocalityRequest>
	|</SOAP-ENV:Body>
	|</SOAP-ENV:Envelope>
	|";
	
	Возврат Запрос;
	
КонецФункции

Процедура ИнициализацияХС_ЗагрузитьУлицы_ВФоне(Знач Параметры, АдресХранилища) Экспорт
	
	Если Не ЗначениеЗаполнено(Параметры["НаселенныйПункт"]) И Не ЗначениеЗаполнено(Параметры["Город"])
		И ЗначениеЗаполнено(Параметры["Регион"]) Тогда
		_Город = Параметры["Регион"];
	ИначеЕсли ЗначениеЗаполнено(Параметры["НаселенныйПункт"]) Тогда
		_Город = Параметры["НаселенныйПункт"];
	ИначеЕсли ЗначениеЗаполнено(Параметры["Город"]) Тогда
		_Город = Параметры["Город"];
	Иначе
		_Город = Неопределено;
	КонецЕсли;
	
	Ответ = ИнициализацияХС_ЗагрузитьУлицы(Параметры, _Город);
	
	РезультатОбработки = Новый Структура();
	Если Ответ Тогда
		РезультатОбработки.Вставить("ЗаданиеВыполнено", Истина);
	Иначе
		РезультатОбработки.Вставить("ЗаданиеВыполнено", Ложь);
	КонецЕсли;
	
	ПоместитьВоВременноеХранилище(РезультатОбработки, АдресХранилища);
	
КонецПроцедуры

Функция ИнициализацияХС_ЗагрузитьУлицы(Знач Параметры, _Город) Экспорт
	
	Если НЕ ЗначениеЗаполнено(_Город.GUID) Тогда
		ВызватьИсключение("Пустое значение Город.GUID");
	КонецЕсли;
	
	ВетИС_APIСервер.СообщитьИнфо(" Запрос GetStreetListByLocality " + _Город + " [" + СокрЛП(_Город.GUID) + "]");
	ЗапросXML = Список_Улиц_ЗапросXML(_Город.GUID, Параметры);
	Service = "platform/services/2.1/IkarService";
	Action = "GetStreetListByLocality";
	
	ПараметрыОтправки = кб99_ВСД_Отправка.ПараметрыОтправкиИнициализация(Параметры);
	ПараметрыОтправки.ЗапросXML = ЗапросXML;
	ПараметрыОтправки.Service = Service;
	ПараметрыОтправки.Action = Action;
	xdto = кб99_ВСД_Отправка.ОтправитьSOAPНаСервере(ПараметрыОтправки);
	
	Если ВетИС_APIСервер.НайтиОшибки(xdto, _Город) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ПолучилиУлиц = Число(xdto.Body.GetStreetListByLocalityResponse.StreetList.count);
	//НачатьТранзакцию();
	Попытка
		
		Если ПолучилиУлиц = 0 Тогда
			ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("По населенному пункту %1 в классификаторе отсутствуют улицы", _город.Наименование);
			ВетИС_APIСервер.СообщитьИнфо(ТекстСообщения);
			Возврат Истина;
		КонецЕсли;
		
		StreetList = xdto.Body.GetStreetListByLocalityResponse.StreetList.Street;
		
		Если ТипЗнч(StreetList) = Тип("ОбъектXDTO") Тогда
			ДобавитьУлицу(StreetList, _Город);
		Иначе
			Для каждого Street ИЗ StreetList Цикл
				ДобавитьУлицу(Street, _Город);
			КонецЦикла;
		КонецЕсли;
		
		//ЗафиксироватьТранзакцию();
		
		Если ПолучилиУлиц = 1000 Тогда
			Параметры["Смещение"] = Параметры["Смещение"] + 1000;
			ИнициализацияХС_ЗагрузитьУлицы(Параметры, _Город);
		КонецЕсли;
		Ответ = Истина;
		ВетИС_APIСервер.СообщитьИнфо("ВСД_Улицы загрузка завершена");
	Исключение
		
		ЗаписьЖурналаРегистрации(
		НСтр("ru = 'Ошибка при получении ВСД_Улицы'"),
		УровеньЖурналаРегистрации.Ошибка, , ,
		ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		//ОтменитьТранзакцию();
		Ответ = Ложь;
		ВетИС_APIСервер.СообщитьИнфо("Ошибка при получении ВСД_Улицы " + ОписаниеОшибки());
	КонецПопытки;
	
	Возврат Ответ;
	
КонецФункции

Процедура ДобавитьУлицу(Street, _Город) Экспорт
	
	guid = Street.guid;
	_uuid = Street.uuid;
	name = Street.view;
	
	Запрос = Новый Запрос("ВЫБРАТЬ
	|	ВСД_Улица.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ВСД_Улица КАК ВСД_Улица
	|ГДЕ
	|	ВСД_Улица.GUID = &GUID
	|	И ВСД_Улица.Владелец = &Владелец");
	Запрос.УстановитьПараметр("GUID", guid);
	Запрос.УстановитьПараметр("Владелец", _Город);
	
	Результат = Запрос.Выполнить().Выбрать();
	
	Если Не Результат.Следующий() Тогда
		
		Спр = Справочники.ВСД_Улица.СоздатьЭлемент();
		Спр.Наименование = name;
		Спр.GUID = guid;
		Спр.UUID = _UUID;
		Спр.Владелец = _Город;
		Спр.Записать();
		ВетИС_APIСервер.СообщитьИнфо("ВСД_Улица [" + name + "] GUID [" + guid + "] добавлена");
		
	КонецЕсли;
	
КонецПроцедуры


