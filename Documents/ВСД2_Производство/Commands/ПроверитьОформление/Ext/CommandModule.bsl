// GRACE:MODULE_START name="ПроизводствоВСД"
// @grace-module: ПроизводствоВСД
// @grace-purpose: Команда проверки оформления документа ВСД2_Производство через отчёт СКД
// @grace-depends: ПроизводствоВСД
// @grace-version: 1.0
// @grace-contract-ref: docs/Contracts.xml -> module="ПроизводствоВСД"
// GRACE:DEPENDENCY target="Документы.ВСД2_Производство"
// GRACE:DEPENDENCY target="СтроковыеФункцииКлиентСервер"

&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)

	ТабДок = Новый ТабличныйДокумент;
	СформироватьОтчет(ПараметрКоманды, ТабДок);

	ТабДок.ОтображатьСетку = Ложь;
	ТабДок.ТолькоПросмотр = Истина;
	ТабДок.Показать(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("Проверка документа ""%1""", ПараметрКоманды));

КонецПроцедуры

&НаСервере
Процедура СформироватьОтчет(ПараметрКоманды, ТабДок)
	Документы.ВСД2_Производство.ПроверитьОформление(ПараметрКоманды, ТабДок);
КонецПроцедуры
// GRACE:MODULE_END name="ПроизводствоВСД"
