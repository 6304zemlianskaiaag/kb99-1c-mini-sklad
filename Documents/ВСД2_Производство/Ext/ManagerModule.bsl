// GRACE:MODULE_START name="ПроизводствоВСД"
// @grace-module: ПроизводствоВСД
// @grace-purpose: Менеджер документа ВСД2_Производство — проверка оформления через СКД
// @grace-depends: ДокументооборотВСД, ИнтеграцияВетИС_API
// @grace-version: 1.0
// @grace-contract-ref: docs/Contracts.xml -> module="ПроизводствоВСД"
// GRACE:DEPENDENCY target="Документы.ВСД2_Производство"

// @grace-contract: ПроверитьОформление
//   Вход: Документ (ДокументСсылка.ВСД2_Производство) — ссылка на проверяемый документ
//   Вход: ТабДок (ТабличныйДокумент) — выходной табличный документ
//   Выход: нет
//   Исключение: нет
//   Инвариант: Макет "ПроверкаОформления" должен существовать в документе
//   GRACE-лог: нет
// GRACE:CONTRACT function="ПроверитьОформление"

Процедура ПроверитьОформление(Документ, ТабДок) Экспорт

	Макет = Документы.ВСД2_Производство.ПолучитьМакет("ПроверкаОформления");

	КомпоновщикНастроек = Новый КомпоновщикНастроекКомпоновкиДанных;
	КомпоновщикНастроек.ЗагрузитьНастройки(Макет.НастройкиПоУмолчанию);
	КомпоновщикНастроек.Настройки.ПараметрыДанных.УстановитьЗначениеПараметра("Документ", Документ);

	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетКомпоновки = КомпоновщикМакета.Выполнить(Макет, КомпоновщикНастроек.Настройки);
	ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновки.Инициализировать(МакетКомпоновки);

	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВТабличныйДокумент;
	ПроцессорВывода.УстановитьДокумент(ТабДок);
	ПроцессорВывода.Вывести(ПроцессорКомпоновки);

КонецПроцедуры
// GRACE:MODULE_END name="ПроизводствоВСД"
