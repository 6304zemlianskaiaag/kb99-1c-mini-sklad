
// GRACE:MODULE_START name="КорректировкаРеализации"
// @grace-module: КорректировкаРеализации
// @grace-purpose: Объектный модуль документа ВСД2_КорректировкаРеализации — заполнение из документа-основания и установка признака обработанности перед записью
// @grace-depends: КорректировкаРеализации, ЯдроВСД
// @grace-version: 1.0
// @grace-contract-ref: docs/Contracts.xml -> module="КорректировкаРеализации"
// GRACE:DEPENDENCY target="ВетИС_УтилитыКлиентСервер"

// LLM_NOTE: ПередЗаписью устанавливает реквизит Обработан на основе состояния строк ТЧ ВСДКАннулированию и ВСДКГашению.
// Это управляет доступностью формы (ТолькоПросмотр). НЕ изменять логику — она связана с UI формы.

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)

	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.КорректировкаРеализации") Тогда

		ДокументОснование = ДанныеЗаполнения;
		Организация = ДокументОснование.Организация;

		Если ВетИС_УтилитыКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДанныеЗаполнения, "ДокументРеализации") Тогда
			ДокументРеализации = ДанныеЗаполнения.ДокументРеализации;
		ИначеЕсли ВетИС_УтилитыКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДанныеЗаполнения, "ДокументОснование") Тогда
			ДокументРеализации = ДанныеЗаполнения.ДокументОснование;
		КонецЕсли;

	КонецЕсли;

КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)

	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;

	// Проверяем, все ли строки в табличных частях обработаны
	ВсеСтрокиОбработаны = Истина;

	Для Каждого Стр Из ВСДКАннулированию Цикл
		Если Не Стр.Обработан Тогда
			ВсеСтрокиОбработаны = Ложь;
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Если ВсеСтрокиОбработаны Тогда
		Для Каждого Стр Из ВСДКГашению Цикл
			Если Не Стр.Обработан Тогда
				ВсеСтрокиОбработаны = Ложь;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	//Если ВСДКАннулированию.Количество() И ВсеСтрокиОбработаны Тогда
	//	Для Каждого Стр Из ОформленныеКорректировки Цикл
	//		Если Не Стр.ВСД2_транзакция.СтатусВСД = Перечисления.кб99_СтатусВСД.CONFIRMED Тогда
	//			ВсеСтрокиОбработаны = Ложь;
	//			Прервать;
	//		КонецЕсли;
	//	КонецЦикла;
	//КонецЕсли;

	// Устанавливаем признак в шапке
	Обработан = ВсеСтрокиОбработаны;

КонецПроцедуры
// GRACE:MODULE_END name="КорректировкаРеализации"
