&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)

	ТабДок = Новый ТабличныйДокумент;
	ПечатьНаборныйЛист(ТабДок, ПараметрКоманды);

	ТабДок.ОтображатьСетку = Ложь;
	ТабДок.Защита = Ложь;
	ТабДок.ТолькоПросмотр = Истина;
	ТабДок.ОтображатьЗаголовки = Ложь;
	ТабДок.Показать();

КонецПроцедуры

&НаСервере
Процедура ПечатьНаборныйЛист(ТабДок, ПараметрКоманды)
	Документы.ВСД2_транзакция.ПечатьНаборныйЛист(ТабДок, ПараметрКоманды);
КонецПроцедуры
