// GRACE:MODULE_START name="ТранзакцияВСД"
// @grace-module: ТранзакцияВСД
// @grace-purpose: Команда гашения ВСД от имени получателя для документа ВСД2_транзакция
// @grace-depends: ТранзакцияВСД, ГашениеВСД
// @grace-version: 1.0
// @grace-contract-ref: docs/Contracts.xml -> module="ТранзакцияВСД"
// GRACE:DEPENDENCY target="ВетИС_КлиентскийСлойКлиент"
// GRACE:DEPENDENCY target="ВетИС_УтилитыКлиентСервер"

// @grace-contract: ОбработкаОтвета
//   Вход: Ответ (КодВозвратаДиалога) — ответ пользователя на вопрос о гашении
//   Вход: Парам (Структура) — содержит ДокСсылка
//   Выход: нет
//   Исключение: нет
//   Инвариант: статус последнего запроса должен быть "COMPLETED"
//   GRACE-лог: нет
// GRACE:CONTRACT function="ОбработкаОтвета"

&НаКлиенте
Процедура ОбработкаОтвета(Ответ, Парам) Экспорт

	ДокСсылка = Парам.ДокСсылка;

	Если Ответ = КодВозвратаДиалога.Да Тогда
		Состояние("Выполняем гашение ВСД",, "Ожидайте...", БиблиотекаКартинок.kb99_wrench);

		РезультатЗапуска = ПогаситьВсдОтИмениПолучателя_НаСервере(ДокСсылка);

		Если РезультатЗапуска <> Неопределено Тогда
			Если РезультатЗапуска.Свойство("ИдентификаторЗадания") Тогда
				ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(Парам.ПараметрыВыполненияКоманды.Источник);
				ПараметрыОжидания.ТекстСообщения = "Гашение ВСД...";
				
				ДопПараметры = Новый Структура("Источник, ДокСсылка", Парам.ПараметрыВыполненияКоманды.Источник, ДокСсылка);
				ОповещениеОЗавершении = Новый ОписаниеОповещения("ЗавершитьГашение", ЭтотОбъект, ДопПараметры);
				ДлительныеОперацииКлиент.ОжидатьЗавершение(РезультатЗапуска, ОповещениеОЗавершении, ПараметрыОжидания);
			Иначе
				ПоказатьОповещениеПользователя("Выполнено");
				ОповеститьОбИзменении(ДокСсылка);
				
				Попытка
					Парам.ПараметрыВыполненияКоманды.Источник.Прочитать();
				Исключение
				КонецПопытки;
			КонецЕсли;
		КонецЕсли;

	КонецЕсли;

КонецПроцедуры

// @grace-contract: ЗавершитьГашение
//   Вход: см. сигнатуру
//   Выход: нет
&НаКлиенте
Процедура ЗавершитьГашение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
		ПоказатьОповещениеПользователя("Гашение ВСД завершено");
		
		// Перечитываем форму, если она еще открыта
		Если ДополнительныеПараметры <> Неопределено И ДополнительныеПараметры.Свойство("Источник") Тогда
			Попытка
				ДополнительныеПараметры.Источник.Прочитать();
			Исключение
			КонецПопытки;
		КонецЕсли;
		
		ОповеститьОбИзменении(ДополнительныеПараметры.ДокСсылка);
		
	ИначеЕсли Результат.Статус = "Ошибка" Тогда
		ВетИС_ЯдроСервер.СообщитьПользователю(Результат.КраткоеПредставлениеОшибки);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)

	ДокСсылка = ПараметрКоманды;
	Статус = ВетИС_УтилитыКлиентСервер.НайтиПоследнийЗапрос(ДокСсылка).СтатусЗапроса;
	Если Статус = "Завершен" Тогда

		ТВопроса = "Погасить ВСД от имени Получателя?";
		Парам = Новый Структура("ДокСсылка, ПараметрыВыполненияКоманды", ДокСсылка, ПараметрыВыполненияКоманды);
	    Оповещение = Новый ОписаниеОповещения("ОбработкаОтвета", ЭтотОбъект, Парам);
	    ПоказатьВопрос(Оповещение, ТВопроса, РежимДиалогаВопрос.ДаНет, 0, КодВозвратаДиалога.Да, "");

	Иначе
		ВетИС_ЯдроСервер.СообщитьИнфо("Статус последнего запросы = " + Статус + " гашение не запущено.");
	КонецЕсли

КонецПроцедуры

&НаСервере
Функция ПогаситьВсдОтИмениПолучателя_НаСервере(Знач ДокСсылка)
	
	ПараметрыОрганизации = ВетИС_ЯдроСервер.ЗагрузитьПараметры(ДокСсылка.Организация);
	
	Если ПараметрыОрганизации.ОтправлятьВФоне Тогда
		
		НаименованиеЗадания = НСтр("ru = 'Ветис гашение ВСД'");
		
		ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(Новый УникальныйИдентификатор);
		ПараметрыВыполнения.НаименованиеФоновогоЗадания = НаименованиеЗадания;
		
		Результат = ДлительныеОперации.ВыполнитьВФоне("ВетИС_КомандыСервер.ПогаситьВсдОтИмениПолучателя_Фон", 
			Новый Структура("ДокСсылка", ДокСсылка),
			ПараметрыВыполнения);
			
		Возврат Результат;
		
	Иначе
		
		мВсдВходящие = Новый Массив;
		applicationID = ВетИС_УтилитыКлиентСервер.НайтиApplicationID( ДокСсылка );
		
		ПараметрФункции = Новый Структура();
		ПараметрФункции.Вставить("applicationID", applicationID);
		ПараметрФункции.Вставить("Параметры", ПараметрыОрганизации );
		ПараметрФункции.Вставить("ДокОснование", ДокСсылка );
		ПараметрФункции.Вставить("СделатьПаузу", Ложь );
		ПараметрФункции.Вставить("ВсдРезультатМассив", мВсдВходящие);
		
		Ответ = ВетИС_APIСервер.ПолучитьРезультат_ВСД2( ПараметрФункции );	
		
		Если Ответ = ПредопределенноеЗначение("Перечисление.кб99_СтатусЗапроса.COMPLETED") Тогда 
			ВетИС_API_ВходящиеСервер.ПогаситьВсдОтИмениПолучателяСписком( ДокСсылка, мВсдВходящие );
		КонецЕсли;
		
		Результат = Новый Структура;
		Результат.Вставить("Статус", "Выполнено");
		
		Возврат Результат;
		
	КонецЕсли;
	
КонецФункции
// GRACE:MODULE_END name="ТранзакцияВСД"
