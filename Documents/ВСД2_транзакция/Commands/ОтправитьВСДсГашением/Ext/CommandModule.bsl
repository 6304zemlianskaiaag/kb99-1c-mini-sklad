// GRACE:MODULE_START name="ТранзакцияВСД"
// @grace-module: ТранзакцияВСД
// @grace-purpose: Команда отправки ВСД в Меркурий с последующим автогашением от имени получателя
// @grace-depends: ТранзакцияВСД, ИнтеграцияВетИС_API, ГашениеВСД
// @grace-version: 1.0
// @grace-contract-ref: docs/Contracts.xml -> module="ТранзакцияВСД"
// GRACE:DEPENDENCY target="кб99_ВСД"
// GRACE:DEPENDENCY target="ВетИС_APIСервер"
// GRACE:DEPENDENCY target="ВетИС_КлиентскийСлойКлиент"

// @grace-contract: ОбработкаОтвета
//   Вход: Ответ (КодВозвратаДиалога) — ответ пользователя на вопрос об отправке
//   Вход: Парам (Структура) — ПараметрКоманды и ПараметрыВыполненияКоманды
//   Выход: нет
//   Исключение: нет
//   Инвариант: нет
//   GRACE-лог: нет
// GRACE:CONTRACT function="ОбработкаОтвета"

&НаСервере
Процедура ЗаписатьВсдНаСервере(Знач ДокСсылка)

	Докобъект = ДокСсылка.ПолучитьОбъект();
	ДокОбъект.Записать();

КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОтвета(Ответ, Парам) Экспорт

	ДокСсылка = Парам.ПараметрКоманды;
	Если Ответ = КодВозвратаДиалога.Да Тогда
		Состояние("Выполняем отправку и гашение ВСД",, "Ожидайте...", БиблиотекаКартинок.kb99_wrench);

		// Если Найти(Парам.ПараметрыВыполненияКоманды.Источник.ИмяФормы,"Списка") = 0 Тогда
		// 	Парам.ПараметрыВыполненияКоманды.Источник.ЭтаФорма.Закрыть();
		// КонецЕсли;
		ЗаписатьВсдНаСервере(ДокСсылка);

		РезультатЗапуска = ОтправитьВСДсГашением_НаСервере(ДокСсылка);

		Если РезультатЗапуска <> Неопределено Тогда
			Если РезультатЗапуска.Свойство("ИдентификаторЗадания") Тогда
				ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(Парам.ПараметрыВыполненияКоманды.Источник);
				ПараметрыОжидания.ТекстСообщения = "Отправка и гашение ВСД...";
				
				ДопПараметры = Новый Структура("Источник, ДокСсылка", Парам.ПараметрыВыполненияКоманды.Источник, ДокСсылка);
				ОповещениеОЗавершении = Новый ОписаниеОповещения("ЗавершитьОтправкуСГашением", ЭтотОбъект, ДопПараметры);
				ДлительныеОперацииКлиент.ОжидатьЗавершение(РезультатЗапуска, ОповещениеОЗавершении, ПараметрыОжидания);
			Иначе
				ПоказатьОповещениеПользователя("Выполнено");
				ОповеститьОбИзменении(ДокСсылка);
				
				Попытка
					Парам.ПараметрыВыполненияКоманды.Источник.Прочитать();
				Исключение
				КонецПопытки;
			КонецЕсли;
		КонецЕсли;

	КонецЕсли;

КонецПроцедуры

// @grace-contract: ЗавершитьОтправкуСГашением
//   Вход: см. сигнатуру
//   Выход: нет
&НаКлиенте
Процедура ЗавершитьОтправкуСГашением(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
		ПоказатьОповещениеПользователя("Отправка и гашение ВСД завершены");
		
		// Перечитываем форму, если она еще открыта
		Если ДополнительныеПараметры <> Неопределено И ДополнительныеПараметры.Свойство("Источник") Тогда
			Попытка
				ДополнительныеПараметры.Источник.Прочитать();
			Исключение
			КонецПопытки;
		КонецЕсли;
		
		ОповеститьОбИзменении(ДополнительныеПараметры.ДокСсылка);
		
	ИначеЕсли Результат.Статус = "Ошибка" Тогда
		ВетИС_ЯдроСервер.СообщитьПользователю(Результат.КраткоеПредставлениеОшибки);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ОтправитьВСДсГашением_НаСервере(Знач ДокСсылка)
	
	Организация = ВетИС_ЯдроСервер.ПолучитьЗначениеРевизитаОбъекта_НаСервере(ДокСсылка, "Организация");
	ПараметрыОрганизации = ВетИС_ЯдроСервер.ЗагрузитьПараметры(Организация);
	ПараметрыОрганизации.Отправитель_Площадка = ДокСсылка.Отправитель_Площадка;
	
	Если ПараметрыОрганизации.ОтправлятьВФоне Тогда
		
		НаименованиеЗадания = НСтр("ru = 'Ветис отправка и гашение ВСД'");
		
		ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(Новый УникальныйИдентификатор);
		ПараметрыВыполнения.НаименованиеФоновогоЗадания = НаименованиеЗадания;
		
		Результат = ДлительныеОперации.ВыполнитьВФоне("ВетИС_КомандыСервер.ОтправитьВСДсГашением_Фон", 
			Новый Структура("ДокСсылка", ДокСсылка),
			ПараметрыВыполнения);
			
		Возврат Результат;
		
	Иначе
		
		ТаблицаВсдДляГашения = Новый Массив;
		ПараметрыФункции = Новый Структура;
		ПараметрыФункции.Вставить("Параметры", ПараметрыОрганизации);
		ПараметрыФункции.Вставить("ДокОснование", ДокСсылка);
		ПараметрыФункции.Вставить("СписокПартий", Новый Массив);

		Ответ = ВетИС_APIСервер.ВСД2_транзакция_Отправить(ПараметрыФункции);

		Если Строка(Ответ) = "Завершен" Тогда
			Если ПараметрыФункции.Свойство("ВсдРезультатМассив", ТаблицаВсдДляГашения) Тогда
				ВетИС_API_ВходящиеСервер.ПогаситьВсдОтИмениПолучателяСписком(ДокСсылка, ТаблицаВсдДляГашения);
			КонецЕсли;
		КонецЕсли;
		
		Результат = Новый Структура;
		Результат.Вставить("Статус", "Выполнено");
		
		Возврат Результат;
		
	КонецЕсли;
	
КонецФункции

&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)

	ДокСсылка = ПараметрКоманды;

	ТВопроса = "Отправить и погасить ВСД в Меркурий?";
	Парам = Новый Структура("ПараметрКоманды, ПараметрыВыполненияКоманды", ПараметрКоманды, ПараметрыВыполненияКоманды);
	Оповещение = Новый ОписаниеОповещения("ОбработкаОтвета", ЭтотОбъект, Парам);
	ПоказатьВопрос(Оповещение, ТВопроса, РежимДиалогаВопрос.ДаНет, 0, КодВозвратаДиалога.Да, "");

КонецПроцедуры
// GRACE:MODULE_END name="ТранзакцияВСД"
