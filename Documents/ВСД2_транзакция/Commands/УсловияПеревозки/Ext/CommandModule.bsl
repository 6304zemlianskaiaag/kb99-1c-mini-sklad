// GRACE:MODULE_START name="ТранзакцияВСД"
// @grace-module: ТранзакцияВСД
// @grace-purpose: Команда получения условий перевозки (регионализации) для документа ВСД2_транзакция
// @grace-depends: ТранзакцияВСД, ЯдроВСД
// @grace-version: 1.0
// @grace-contract-ref: docs/Contracts.xml -> module="ТранзакцияВСД"
// GRACE:DEPENDENCY target="кб99_ВСД"

&НаСервере
Процедура ЗаписатьВсдНаСервере(ДокСсылка)

	Докобъект = ДокСсылка.ПолучитьОбъект();
	ДокОбъект.Записать();

КонецПроцедуры

&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)

	Состояние("Выполняем запрос регионализации",, "Ожидайте...", БиблиотекаКартинок.kb99_wrench);
	ЗаписатьВСДНаСервере(ПараметрКоманды);
	
	РезультатЗапуска = ПолучитьУсловиеПеревозки_НаСервере(ПараметрКоманды);

	Если РезультатЗапуска <> Неопределено Тогда
		Если РезультатЗапуска.Свойство("ИдентификаторЗадания") Тогда
			ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ПараметрыВыполненияКоманды.Источник);
			ПараметрыОжидания.ТекстСообщения = "Проверка условий перевозки...";
			
			ДопПараметры = Новый Структура("Источник", ПараметрыВыполненияКоманды.Источник);
			ОповещениеОЗавершении = Новый ОписаниеОповещения("ЗавершитьПолучениеУсловийПеревозки", ЭтотОбъект, ДопПараметры);
			ДлительныеОперацииКлиент.ОжидатьЗавершение(РезультатЗапуска, ОповещениеОЗавершении, ПараметрыОжидания);
		Иначе
			ПоказатьОповещениеПользователя("Выполнено");
			ОповеститьОбИзменении(ПараметрКоманды);
			
			// Перечитываем форму, если она открыта (для синхронного режима)
			Попытка
				ПараметрыВыполненияКоманды.Источник.Прочитать();
			Исключение
			КонецПопытки;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

// @grace-contract: ЗавершитьПолучениеУсловийПеревозки
//   Вход: см. сигнатуру
//   Выход: нет
&НаКлиенте
Процедура ЗавершитьПолучениеУсловийПеревозки(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
		ПоказатьОповещениеПользователя("Проверка условий перевозки завершена");
		
		// Перечитываем форму, если она еще открыта
		Если ДополнительныеПараметры <> Неопределено И ДополнительныеПараметры.Свойство("Источник") Тогда
			Попытка
				ДополнительныеПараметры.Источник.Прочитать();
			Исключение
			КонецПопытки;
		КонецЕсли;
		
	ИначеЕсли Результат.Статус = "Ошибка" Тогда
		ВетИС_ЯдроСервер.СообщитьПользователю(Результат.КраткоеПредставлениеОшибки);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьУсловиеПеревозки_НаСервере(Знач ДокСсылка)
	
	ПараметрыОрганизации = ВетИС_ЯдроСервер.ЗагрузитьПараметры(ДокСсылка.Организация);
	
	Если ПараметрыОрганизации.ОтправлятьВФоне Тогда
		
		НаименованиеЗадания = НСтр("ru = 'Ветис проверка условий перевозки'");
		
		ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(Новый УникальныйИдентификатор);
		ПараметрыВыполнения.НаименованиеФоновогоЗадания = НаименованиеЗадания;
		
		Результат = ДлительныеОперации.ВыполнитьВФоне("ВетИС_КомандыСервер.ПроверитьУсловияПеревозки_Фон", 
			Новый Структура("ДокСсылка", ДокСсылка),
			ПараметрыВыполнения);
			
		Возврат Результат;
		
	Иначе
		
		ВетИС_ЯдроСервер.ПолучитьУсловияПеревозки(ДокСсылка);
		
		Результат = Новый Структура;
		Результат.Вставить("Статус", "Выполнено");
		
		Возврат Результат;
		
	КонецЕсли;
	
КонецФункции
// GRACE:MODULE_END name="ТранзакцияВСД"