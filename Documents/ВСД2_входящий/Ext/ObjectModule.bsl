
// GRACE:MODULE_START name="ГашениеВСД"
// @grace-module: ГашениеВСД
// @grace-purpose: Объектный модуль документа ВСД2_входящий — проведение с движениями по регистру остатков партий (приход)
// @grace-depends: ГашениеВСД, ЯдроВСД, РегистрыПартий
// @grace-version: 1.0
// @grace-contract-ref: docs/Contracts.xml -> module="ГашениеВСД"
// GRACE:DEPENDENCY target="ВетИС_ГашениеСервер"

// LLM_NOTE: ОбработкаПроведения формирует движение Приход по регистру кб99_ОстаткиПартийВСД.
// Движение создаётся условно — только если ФормироватьДвиженияПартий = Истина для организации.
// НЕ добавлять Расход без анализа смежных документов. Входящий документ = приход продукции.

Процедура ОбработкаПроведения(Отказ, Режим)

	Если ВетИС_ГашениеСервер.ФормироватьДвиженияПартий(Организация) Тогда

		// регистр кб99_ОстаткиПартийВСД Приход
		Движения.кб99_ОстаткиПартийВСД.Записывать = Истина;

		Движение = Движения.кб99_ОстаткиПартийВСД.Добавить();
		Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
		Движение.Период = Дата;
		Движение.ВСД_Площадка = Получатель_Площадка;
		Движение.Продукция_Элемент = Продукция_Элемент;
		Движение.Количество = КоличествоПринять;

	КонецЕсли;

КонецПроцедуры
// GRACE:MODULE_END name="ГашениеВСД"
