
// GRACE:MODULE_START name="ОбновлениеТранспорта"
// @grace-module: ОбновлениеТранспорта
// @grace-purpose: Форма документа ВСД2_ОбновитьТранспорт — настройка надписей и условного оформления, валидация изменения транспорта
// @grace-depends: ОбновлениеТранспорта, ЯдроВСД
// @grace-version: 1.0
// @grace-contract-ref: docs/Contracts.xml -> module="ОбновлениеТранспорта"
// GRACE:DEPENDENCY target="кб99_ВСД"
// GRACE:DEPENDENCY target="ВетИС_УправлениеФормойСервер"

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	ВетИС_УправлениеФормойСервер.ОбновитьНадписи(ЭтаФорма);
	ВетИС_УправлениеФормойСервер.УстановитьУсловноеОформление(ЭтаФорма);

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)

	ЭлементОтбора = ЭтаФорма.дсЗапросы.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект");
	ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ЭлементОтбора.РежимОтображения = РежимОтображенияЭлементаНастройкиКомпоновкиДанных.БыстрыйДоступ;
	ЭлементОтбора.ПравоеЗначение = Объект.Ссылка;

КонецПроцедуры

&НаКлиенте
Процедура ПроверитьСтроку()

	СтрокаТч = Элементы.ВСДВходящие.ТекущиеДанные;
	Если НЕ СтрокаТч.Перегрузка Тогда
		ВетИС_ЯдроСервер.СообщитьИнфо("Изменить Тип и Номер транспорта возможно только для точки прегрузки!");
		СтрокаТч.ТипТранспорта = Неопределено;
		СтрокаТч.НомерАвто = Неопределено;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ВСДВходящиеТипТранспортаПриИзменении(Элемент)
	ПроверитьСтроку();
КонецПроцедуры

&НаКлиенте
Процедура ВСДВходящиеНомерТСПриИзменении(Элемент)
	ПроверитьСтроку();
КонецПроцедуры
// GRACE:MODULE_END name="ОбновлениеТранспорта"
