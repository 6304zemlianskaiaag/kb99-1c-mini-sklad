// GRACE:MODULE_START name="ОбъединениеПартий"
// @grace-module: ОбъединениеПартий
// @grace-purpose: Объектный модуль документа ВСД2_ОбъединениеПартий — проведение и удаление проведения с движениями по регистру партий
// @grace-depends: ОбъединениеПартий, ЯдроВСД, РегистрыПартий, ГашениеВСД
// @grace-version: 1.0
// @grace-contract-ref: docs/Contracts.xml -> module="ОбъединениеПартий"
// GRACE:DEPENDENCY target="ВетИС_ГашениеСервер"
// GRACE:DEPENDENCY target="ВетИС_ДокументооборотСервер"

// LLM_NOTE: ОбработкаПроведения формирует движение Приход по регистру кб99_ОстаткиПартийВСД.
// Движение условно — только если ФормироватьДвиженияПартий = Истина для организации.
// НЕ добавлять Расход без анализа смежных документов.

Процедура ОбработкаПроведения(Отказ, Режим)

	Если ВетИС_ГашениеСервер.ФормироватьДвиженияПартий(Организация) Тогда

		// регистр кб99_ОстаткиПартийВСД Приход
		Движения.кб99_ОстаткиПартийВСД.Записывать = Истина;

		Движение = Движения.кб99_ОстаткиПартийВСД.Добавить();
		Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
		Движение.Период = Дата;
		Движение.ВСД_Площадка = Владелец_Площадка;
		Движение.Продукция_Элемент = Продукция_Элемент;
		Движение.Количество = ПартииРезультат.Итог("Количество");

	КонецЕсли;

КонецПроцедуры
// GRACE:MODULE_END name="ОбъединениеПартий"
