// GRACE:MODULE_START name="НСИ_ВетИС"
// @grace-module: НСИ_ВетИС
// @grace-purpose: Форма выбора партии ВСД — опциональный фильтр по сроку годности при открытии формы
// @grace-depends: ИнтеграцияВетИС_API, ЯдроВСД
// @grace-version: 1.0
// @grace-contract-ref: docs/Contracts.xml -> module="НСИ_ВетИС"
// GRACE:DEPENDENCY target="ВетИС_APIСервер"

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	ПоказыватьПросроченныеПартии = Истина;

	Если Параметры.Свойство("ПоказыватьПросроченныеПартии", ПоказыватьПросроченныеПартии)
		И Не ПоказыватьПросроченныеПартии Тогда

		ЭлементОтбора = Список.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ДатаСрокГодности1");
		ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Больше;
		ЭлементОтбора.РежимОтображения = РежимОтображенияЭлементаНастройкиКомпоновкиДанных.БыстрыйДоступ;
		// LLM_NOTE: ДатаXML используется для формирования даты в формате ISO 8601, совместимом с фильтрами ВетИС API.
		// НачалоДня + 1 секунда = начало следующего дня, чтобы партии с истекшим сегодня сроком не показывались.
		ЭлементОтбора.ПравоеЗначение = ВетИС_APIСервер.ДатаXML(НачалоДня(ТекущаяДатаСеанса()) + 1);

	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура кнОтключитьОтбор(Команда)
	Список.Отбор.Элементы.Очистить();
КонецПроцедуры
// GRACE:MODULE_END name="НСИ_ВетИС"
