// GRACE:MODULE_START name="НСИ_ВетИС"
// @grace-module: НСИ_ВетИС
// @grace-purpose: Форма элемента партии ВСД — инициализация отбора по запросам, управление видимостью дат и отображение статуса партии с расшифровкой
// @grace-depends: ИнтеграцияВетИС_API, ЯдроВСД
// @grace-version: 1.0
// @grace-contract-ref: docs/Contracts.xml -> module="НСИ_ВетИС"
// GRACE:DEPENDENCY target="ВетИС_КлиентскийСлойКлиент"
// GRACE:DEPENDENCY target="СтроковыеФункцииКлиентСервер"

&НаКлиенте
Процедура ПриОткрытии(Отказ)

	ЭлементОтбора = ЭтаФорма.дсЗапросы.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект");
	ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ЭлементОтбора.РежимОтображения = РежимОтображенияЭлементаНастройкиКомпоновкиДанных.БыстрыйДоступ;
	ЭлементОтбора.ПравоеЗначение = Объект.Ссылка;

	// LLM_NOTE: Поля дат скрываются при незаполненности — ВетИС может возвращать одну или обе даты изготовления/срока.
	// Скрытие предпочтительнее блокировки: пользователь видит только актуальные данные без пустых полей.
	Если НЕ ЗначениеЗаполнено(Объект.ДатаИзготовления2) Тогда
		ЭтаФорма.Элементы.ДатаИзготовления2.Видимость = Ложь;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(Объект.ДатаИзготовления) Тогда
		ЭтаФорма.Элементы.ДатаИзготовления.Видимость = Ложь;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(Объект.ДатаСрокГодности2) Тогда
		ЭтаФорма.Элементы.ДатаСрокГодности2.Видимость = Ложь;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(Объект.ДатаСрокГодности) Тогда
		ЭтаФорма.Элементы.ДатаСрокГодности.Видимость = Ложь;
	КонецЕсли;

	// LLM_NOTE: Ключ "_" + Статус используется для обращения к структуре СтруктураСтатусовПартийСОписанием.
	// Числовые ключи в структуре 1С недопустимы, поэтому добавляется префикс "_".
	Если ЗначениеЗаполнено(Объект.Статус) Тогда
		ОписаниеСтатусаПартии = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("Статус партии: %1, %2",
			Объект.Статус,
			ВетИС_КлиентскийСлойКлиент.СтруктураСтатусовПартийСОписанием()["_" + Объект.Статус]);
	КонецЕсли;

КонецПроцедуры
// GRACE:MODULE_END name="НСИ_ВетИС"
