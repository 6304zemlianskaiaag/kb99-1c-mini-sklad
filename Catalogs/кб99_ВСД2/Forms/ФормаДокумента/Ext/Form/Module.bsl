// GRACE:MODULE_START name="НСИ_ВетИС"
// @grace-module: НСИ_ВетИС
// @grace-purpose: Форма документа кб99_ВСД2 — инициализация списка типов связанных документов и управление видимостью полей дат
// @grace-depends: ИнтеграцияВетИС_API, ЯдроВСД
// @grace-version: 1.0
// @grace-contract-ref: docs/Contracts.xml -> module="НСИ_ВетИС"

&НаКлиенте
Процедура ПриОткрытии(Отказ)

	ЭтаФорма.Элементы.СвязанныеДокументыТипДокумента.СписокВыбора.Добавить(1,"ТТН");
	ЭтаФорма.Элементы.СвязанныеДокументыТипДокумента.СписокВыбора.Добавить(5,"ТрН");
	ЭтаФорма.Элементы.СвязанныеДокументыТипДокумента.СписокВыбора.Добавить(6,"Торг12");
	ЭтаФорма.Элементы.СвязанныеДокументыТипДокумента.СписокВыбора.Добавить(16,"Заказ");
	ЭтаФорма.Элементы.СвязанныеДокументыТипДокумента.СписокВыбора.Добавить(23,"УПД");
	ЭтаФорма.Элементы.СвязанныеДокументыТипДокумента.РежимВыбораИзСписка = Истина;

	ЭлементОтбора = ЭтаФорма.дсЗапросы.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект");
	ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ЭлементОтбора.РежимОтображения = РежимОтображенияЭлементаНастройкиКомпоновкиДанных.БыстрыйДоступ;
	ЭлементОтбора.ПравоеЗначение = Объект.Ссылка;

	// LLM_NOTE: Поля дат скрываются при незаполненности, а не блокируются — это намеренно:
	// ВетИС может вернуть одну из двух дат или обе; незаполненные поля не показываются, чтобы не путать пользователя.
	Если НЕ ЗначениеЗаполнено( Объект.ДатаИзготовления2 ) Тогда
		ЭтаФорма.Элементы.ДатаИзготовления2.Видимость = Ложь;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено( Объект.ДатаИзготовления ) Тогда
		ЭтаФорма.Элементы.ДатаИзготовления.Видимость = Ложь;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено( Объект.ДатаСрокГодности2 ) Тогда
		ЭтаФорма.Элементы.ДатаСрокГодности2.Видимость = Ложь;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено( Объект.ДатаСрокГодности ) Тогда
		ЭтаФорма.Элементы.ДатаСрокГодности.Видимость = Ложь;
	КонецЕсли;

КонецПроцедуры

