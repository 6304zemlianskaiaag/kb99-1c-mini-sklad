// GRACE:MODULE_START name="НСИ_ВетИС"
// @grace-module: НСИ_ВетИС
// @grace-purpose: Форма элемента условий перевозки — запрет интерактивного добавления, отображение текста решения по коду
// @grace-depends: ИнтеграцияВетИС_API, ЯдроВСД
// @grace-version: 1.0
// @grace-contract-ref: docs/Contracts.xml -> module="НСИ_ВетИС"
// GRACE:DEPENDENCY target="кб99_ВСД"

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	// LLM_NOTE: Отказ = Истина при незаполненной Ссылке блокирует интерактивное создание записи.
	// Условия перевозки — справочник ВетИС, записи создаются только при загрузке данных из API.
	// Прямое создание пользователем нарушит целостность данных (отсутствие GUID ВетИС).
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Отказ = Истина;
		ВетИС_ЯдроСервер.СообщитьИнфо("Запрещено интерактивное добавление условий перевозки. Запросите условия перевозки из документа.");
	Иначе

		Если Объект.Решение = 1 Тогда
			Элементы.ДекорацияРешение.Заголовок = "Перемещение разрешено";
		ИначеЕсли Объект.Решение = 2 Тогда
			Элементы.ДекорацияРешение.Заголовок = "Перемещение разрешено при обязательном соблюдении условий";
		ИначеЕсли Объект.Решение = 3 Тогда
			Элементы.ДекорацияРешение.Заголовок = "Перемещение запрещено";
		КонецЕсли;

	КонецЕсли;

КонецПроцедуры
// GRACE:MODULE_END name="НСИ_ВетИС"
