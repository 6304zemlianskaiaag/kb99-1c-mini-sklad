// GRACE:MODULE_START name="НСИ_ВетИС"
// @grace-module: НСИ_ВетИС
// @grace-purpose: Форма выбора хозсубъекта из результатов поиска по ИНН в ГИС Меркурий — привязка контрагента к записи ВСД_ХозСубъект
// @grace-depends: ИнтеграцияВетИС_API, ЯдроВСД
// @grace-version: 1.0
// @grace-contract-ref: docs/Contracts.xml -> module="НСИ_ВетИС"
// GRACE:DEPENDENCY target="кб99_ВСД"
// GRACE:DEPENDENCY target="ВетИС_APIСервер"

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	Если Параметры.Свойство("ЗагруженныеХозсубъекты") Тогда
		выбКонтрагент = Параметры.ЗагруженныеХозсубъекты.Контрагент;
		Организация = Параметры.ЗагруженныеХозсубъекты.Организация;
		ХозсубъектыСписок.Очистить();
		Для Каждого Хозсубъект Из Параметры.ЗагруженныеХозсубъекты.МассивХозсубъектов Цикл
			НоваяСтрока = ХозсубъектыСписок.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Хозсубъект);
		КонецЦикла;
		Элементы.ПолеИнформация.Заголовок = "По ИНН """ + выбКонтрагент.ИНН + """
				| в ГИС Меркурий найдено " + Параметры.ЗагруженныеХозсубъекты.МассивХозсубъектов.Количество() + " хозсубъекта,
				| выберите к какому хозяйствующему субъекту привязать контрагента """ + выбКонтрагент.Наименование + """";
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ХозсубъектыСписокВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)

	СтандартнаяОбработка = Ложь;
	ПараметрыОрганизации = ВетИС_ЯдроСервер.ЗагрузитьПараметры( Организация );
	СтрокаТч = ХозсубъектыСписок[ВыбраннаяСтрока];
	Если ЗначениеЗаполнено(СтрокаТч.Хозсубъект) Тогда
		ДополнительныеПараметры = Новый Структура("Контрагент, GUID, ПараметрыОрганизации", выбКонтрагент, СтрокаТч.GUID, ПараметрыОрганизации);
		Оповещение = Новый ОписаниеОповещения("ВыбратьХозсубъектОтвет", ЭтаФорма, ДополнительныеПараметры);
		ТекстВопроса = "Уже имеются загруженные хозсубъекты с GUID [ " + СтрокаТч.GUID + " ],
		| открыть список загруженных хозсубъектов для связи с контрагентом: """ + выбКонтрагент + """?";
		ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет, 0, КодВозвратаДиалога.Да, "");
	Иначе
		ВыбраннаяСтрока.ХозСубъект = ВетИС_ЯдроСервер.НайтиХозСубъект(выбКонтрагент);
		// LLM_NOTE: Площадка_ЗагрузитьПоХозСубъекту выполняет HTTP-запрос к ВетИС API.
		// Вызывается сразу после привязки хозсубъекта, чтобы автоматически загрузить его площадки.
		// Параметр Истина = принудительная перезагрузка, даже если площадки уже существуют.
		ВетИС_APIСервер.Площадка_ЗагрузитьПоХозСубъекту(ПараметрыОрганизации, СтрокаТч.ХозСубъект, Истина);
		Оповестить("ХозсубъектЗагружен");
		Закрыть();
	КонецЕсли;

КонецПроцедуры

// @grace-contract: ВыбратьХозсубъектОтвет
//   Вход: Ответ (КодВозвратаДиалога) — ответ пользователя на вопрос об открытии списка хозсубъектов
//   Вход: Парам (Структура) — содержит Контрагент, GUID, ПараметрыОрганизации
//   Выход: нет (побочный эффект: загрузка площадок и оповещение "ХозсубъектЗагружен")
//   Исключение: не бросает
//   Инвариант: при Да — открывает форму выбора существующего хозсубъекта; при Нет — создаёт новый и загружает площадки
//   GRACE-лог: нет собственных точек — логирование делегировано ВетИС_APIСервер
// GRACE:CONTRACT function="ВыбратьХозсубъектОтвет"
&НаКлиенте
Процедура ВыбратьХозсубъектОтвет(Ответ,Парам) Экспорт

	Если Ответ = КодВозвратаДиалога.Да Тогда
		ОповещениеОЗакрытии = Новый ОписаниеОповещения("ПослеВыбораЗагруженногоХозСубъекта", ЭтаФорма.ВладелецФормы, Парам);
		СтруктураОтбора = Новый Структура;
		СтруктураОтбора.Вставить("GUID", Парам.GUID);
		ПараметрыПодбора = Новый Структура("ЗакрыватьПриВыборе, РежимВыбора, МножественныйВыбор, Отбор", Истина, Истина, Ложь, СтруктураОтбора);
		ОткрытьФорму("Справочник.ВСД_ХозСубъект.ФормаВыбора", ПараметрыПодбора, ЭтаФорма,,,, ОповещениеОЗакрытии);
		Закрыть();
	Иначе
		ХозСубъект = ВетИС_ЯдроСервер.НайтиХозСубъект(Парам.Контрагент);
		// LLM_NOTE: Загрузка площадок при выборе "Нет" — пользователь предпочёл создать новый хозсубъект.
		// Площадки загружаются немедленно, чтобы новый хозсубъект сразу был работоспособен.
		ВетИС_APIСервер.Площадка_ЗагрузитьПоХозСубъекту(Парам.ПараметрыОрганизации, ХозСубъект, Истина);
		Оповестить("ХозсубъектЗагружен");
		Закрыть();
	КонецЕсли;

КонецПроцедуры
// GRACE:MODULE_END name="НСИ_ВетИС"
