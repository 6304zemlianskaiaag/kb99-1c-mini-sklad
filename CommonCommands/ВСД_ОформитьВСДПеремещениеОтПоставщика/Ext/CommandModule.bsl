// GRACE:MODULE_START name="КомандыВСД"
// @grace-module: КомандыВСД
// @grace-purpose: Команда оформления ВСД перемещения от поставщика — открывает форму транзакции с признаком ОтПоставщика
// @grace-depends: ЯдроВСД, ДокументооборотВСД, ПроизводствоВСД, ИнтеграционВетИС_API
// @grace-version: 1.0
// @grace-contract-ref: docs/Contracts.xml -> module="КомандыВСД"

&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)

	ДокСсылка = ПараметрКоманды;
    ДокВСД = "";
	// LLM_NOTE: ДокВСД намеренно инициализируется пустой строкой, а не Неопределено.
	// Условие ЗначениеЗаполнено("") = Ложь, поэтому всегда выполняется ветка создания нового ВСД.
	// Ветка с открытием существующего документа оставлена как заготовка для будущего использования.
	Если ЗначениеЗаполнено(ДокВСД) Тогда
		Если типЗнч(ДокВСД) = Тип("ДокументСсылка.ВСД2_транзакция") Тогда
			ИмяФормыДокумента = "Документ.ВСД2_транзакция.ФормаОбъекта";
		Иначе
			Сообщить("Неверный документ нашли");
			Возврат;
		КонецЕсли;
		ОткрытьФорму(ИмяФормыДокумента, Новый Структура("Ключ", ДокВСД));
	Иначе
		ДанныеЗаполнения = Новый Структура("ОтПоставщика,Основание", Истина, ДокСсылка);
		ОткрытьФорму("Документ.ВСД2_транзакция.ФормаОбъекта", Новый Структура("Основание",ДанныеЗаполнения));
	КонецЕсли;

КонецПроцедуры
// GRACE:MODULE_END name="КомандыВСД"
