// GRACE:MODULE_START name="КомандыВСД"
// @grace-module: КомандыВСД
// @grace-purpose: Команда получения ответа ВетИС по документам — опрашивает API статуса для каждого документа в списке
// @grace-depends: ЯдроВСД, ДокументооборотВСД, ПроизводствоВСД, ИнтеграцияВетИС_API
// @grace-version: 1.0
// @grace-contract-ref: docs/Contracts.xml -> module="КомандыВСД"
// GRACE:DEPENDENCY target="кб99_ВСД"
// GRACE:DEPENDENCY target="ВетИС_УтилитыКлиентСервер"
// GRACE:DEPENDENCY target="ВетИС_APIСервер"

&НаСервере
Процедура ВыполнитьНаСервере( ПараметрКоманды )

	Для Каждого ДокСсылка Из ПараметрКоманды Цикл

		ПараметрыОрганизации = ВетИС_ЯдроСервер.ЗагрузитьПараметры( ДокСсылка.Организация );

		// LLM_NOTE: Площадка отправителя определяется динамически по типу документа,
		// т.к. разные типы ВСД2 хранят её в разных реквизитах.
		// Нельзя использовать единый реквизит — метаданные документов различаются.
		Если ВетИС_УтилитыКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта( ДокСсылка, "Отправитель_Площадка" ) Тогда
			//ВСД2_транзакция
			ПараметрыОрганизации.Отправитель_Площадка = ДокСсылка.Отправитель_Площадка;

		ИначеЕсли ВетИС_УтилитыКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта( ДокСсылка, "Производитель_Площадка" ) Тогда
			//ВСД2_Производство
			ПараметрыОрганизации.Отправитель_Площадка = ДокСсылка.Производитель_Площадка;

		ИначеЕсли ВетИС_УтилитыКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта( ДокСсылка, "Владелец_Площадка" ) Тогда
			//ВСД2_Инвентаризация     ВСД2_ОбъединениеПартий
			ПараметрыОрганизации.Отправитель_Площадка = ДокСсылка.Владелец_Площадка;

		КонецЕсли;

		applicationID = ВетИС_УтилитыКлиентСервер.НайтиApplicationID( ДокСсылка );

		ПараметрФункции = Новый Структура();
		ПараметрФункции.Вставить("applicationID", applicationID);
		ПараметрФункции.Вставить("Параметры", ПараметрыОрганизации );
		ПараметрФункции.Вставить("ДокОснование", ДокСсылка );
		ПараметрФункции.Вставить("СделатьПаузу", Ложь );

		// LLM_NOTE: ПолучитьРезультат_ВСД2 выполняет HTTP-запрос к ВетИС API для получения статуса по applicationID.
		// Результат записывается в документ внутри вызываемой функции — здесь явно не обрабатывается.
		Ответ =  ВетИС_APIСервер.ПолучитьРезультат_ВСД2( ПараметрФункции );

	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)

	Состояние("Выполняем запрос Ответа о состоянии документов",,"Ожидайте...",БиблиотекаКартинок.kb99_wrench);

	РезультатЗапуска = ВыполнитьНаСервере_Начало( ПараметрКоманды );

	Если РезультатЗапуска <> Неопределено Тогда
		Если РезультатЗапуска.Свойство("ИдентификаторЗадания") Тогда
			ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ПараметрыВыполненияКоманды.Источник);
			ПараметрыОжидания.ТекстСообщения = "Получение ответа ВетИС...";
			
			ДопПараметры = Новый Структура("Источник, ПараметрКоманды", ПараметрыВыполненияКоманды.Источник, ПараметрКоманды);
			ОповещениеОЗавершении = Новый ОписаниеОповещения("ЗавершитьПолучениеОтветаВетИС", ЭтотОбъект, ДопПараметры);
			ДлительныеОперацииКлиент.ОжидатьЗавершение(РезультатЗапуска, ОповещениеОЗавершении, ПараметрыОжидания);
		Иначе
			ПоказатьОповещениеПользователя("Операция завершена");
			Для Каждого Док Из ПараметрКоманды Цикл
				ОповеститьОбИзменении(Док);
			КонецЦикла;
			// Перечитываем форму, если она открыта (для синхронного режима)
			Попытка
				ПараметрыВыполненияКоманды.Источник.Прочитать();
			Исключение
			КонецПопытки;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

// @grace-contract: ЗавершитьПолучениеОтветаВетИС
//   Вход: см. сигнатуру
//   Выход: нет
&НаКлиенте
Процедура ЗавершитьПолучениеОтветаВетИС(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
		ПоказатьОповещениеПользователя("Получение ответа ВетИС завершено");
		
		// Перечитываем форму, если она еще открыта
		Если ДополнительныеПараметры <> Неопределено И ДополнительныеПараметры.Свойство("Источник") Тогда
			Попытка
				ДополнительныеПараметры.Источник.Прочитать();
			Исключение
			КонецПопытки;
		КонецЕсли;
		
		Для Каждого Док Из ДополнительныеПараметры.ПараметрКоманды Цикл
			ОповеститьОбИзменении(Док);
		КонецЦикла;
		
	ИначеЕсли Результат.Статус = "Ошибка" Тогда
		ВетИС_ЯдроСервер.СообщитьПользователю(Результат.КраткоеПредставлениеОшибки);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ВыполнитьНаСервере_Начало( Знач ПараметрКоманды )
	
	// Определяем организацию по первому документу
	Организация = Справочники.Организации.ПустаяСсылка();
	Если ТипЗнч(ПараметрКоманды) = Тип("Массив") И ПараметрКоманды.Количество() > 0 Тогда
		Организация = ПараметрКоманды[0].Организация;
	ИначеЕсли ЗначениеЗаполнено(ПараметрКоманды) Тогда
		Организация = ПараметрКоманды.Организация;
	КонецЕсли;
	
	ПараметрыОрганизации = ВетИС_ЯдроСервер.ЗагрузитьПараметры(Организация);
	
	Если ПараметрыОрганизации.ОтправлятьВФоне Тогда
		
		СписокДокументов = Новый Массив;
		Если ТипЗнч(ПараметрКоманды) = Тип("Массив") Тогда
			СписокДокументов = ПараметрКоманды;
		Иначе
			СписокДокументов.Добавить(ПараметрКоманды);
		КонецЕсли;
		
		НаименованиеЗадания = НСтр("ru = 'Ветис получение ответа'");
		
		ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(Новый УникальныйИдентификатор);
		ПараметрыВыполнения.НаименованиеФоновогоЗадания = НаименованиеЗадания;
		
		Результат = ДлительныеОперации.ВыполнитьВФоне("ВетИС_КомандыСервер.ПолучитьОтветВетис_Фон", 
			Новый Структура("СписокДокументов", СписокДокументов),
			ПараметрыВыполнения);
			
		Возврат Результат;
		
	Иначе
		
		ВыполнитьНаСервере(ПараметрКоманды);
		
		Результат = Новый Структура;
		Результат.Вставить("Статус", "Выполнено");
		
		Возврат Результат;
		
	КонецЕсли;
	
КонецФункции
// GRACE:MODULE_END name="КомандыВСД"
