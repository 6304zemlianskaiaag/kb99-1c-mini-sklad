#Область НемодальныеОкна

// @grace-contract: ПредупреждениеПользователю
//   Вход: ТекстПредупреждения (Строка) — текст для показа в диалоге предупреждения
//   Выход: нет (показывает немодальное предупреждение)
//   Исключение: не бросает
//   Инвариант: таймаут 0 = без автозакрытия
//   GRACE-лог: нет
// GRACE:CONTRACT function="ПредупреждениеПользователю"
&НаКлиенте
Процедура ПредупреждениеПользователю(ТекстПредупреждения) Экспорт

    Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияПредупреждение",
        ЭтотОбъект);

    ПоказатьПредупреждение(
        Оповещение,
        ТекстПредупреждения, // предупреждение
        0, // (необ.) таймаут в секундах
        "Предупреждение" // (необ.) заголовок
    );

КонецПроцедуры

// @grace-contract: ПослеЗакрытияПредупреждение
//   Вход: Параметры (Структура) — передаётся платформой, не используется
//   Выход: нет (заглушка callback)
//   Инвариант: обязательный callback для ПоказатьПредупреждение — платформа требует ОписаниеОповещения
//   GRACE-лог: нет
// GRACE:CONTRACT function="ПослеЗакрытияПредупреждение"
&НаКлиенте
Процедура ПослеЗакрытияПредупреждение(Параметры) Экспорт
КонецПроцедуры

// @grace-contract: ПослеОтветаНаВопрос
//   Вход: Результат (КодВозвратаДиалога) — ответ пользователя на подтверждение
//   Вход: Парам (Структура) — содержит ПараметрКоманды (ДокументСсылка), ПараметрыВыполненияКоманды
//   Выход: нет (побочный эффект: запись документа, проверка условий перевозки, отправка в ВетИС)
//   Исключение: не бросает явно
//   Инвариант: отправка происходит только при Результат = Да; документы ВСД2_* записываются перед отправкой
//   GRACE-лог: нет собственных точек
// GRACE:CONTRACT function="ПослеОтветаНаВопрос"
&НаКлиенте
Процедура ПослеОтветаНаВопрос(Результат, Парам) Экспорт

	Если Результат = КодВозвратаДиалога.Да Тогда
		Состояние("Выполняем отправку ВСД", , "Ожидайте...", БиблиотекаКартинок.kb99_wrench);

		ПараметрКоманды = Парам.ПараметрКоманды;
		ПараметрыВыполненияКоманды = Парам.ПараметрыВыполненияКоманды;
		ДокСсылка = ПараметрКоманды;

		Если ТипЗнч(ДокСсылка) = Тип("ДокументСсылка.ВСД2_Транзакция") ИЛИ
			ТипЗнч(ДокСсылка) = Тип("ДокументСсылка.ВСД2_Производство") ИЛИ
			ТипЗнч(ДокСсылка) = Тип("ДокументСсылка.ВСД2_ЛабораторныеИсследования") ИЛИ
			ТипЗнч(ДокСсылка) = Тип("ДокументСсылка.ВСД2_Инвентаризация") ИЛИ
			ТипЗнч(ДокСсылка) = Тип("ДокументСсылка.ВСД2_ОбновитьТранспорт") ИЛИ
			ТипЗнч(ДокСсылка) = Тип("ДокументСсылка.ВСД2_ОбъединениеПартий") Тогда

			// LLM_NOTE: Форма объекта ВСД закрывается ДО записи и отправки.
			// Это предотвращает конфликт блокировок: открытая форма держит объект,
			// а серверная запись и API-вызов требуют монопольного доступа.
			// Если Найти(ПараметрыВыполненияКоманды.Источник.ИмяФормы,"Списка") = 0 Тогда
			// 	ПараметрыВыполненияКоманды.Источник.этаФорма.Закрыть();
			// КонецЕсли;

			ЗаписатьВСДНаСервере(ДокСсылка);

		КонецЕсли;

		// LLM_NOTE: Условия перевозки запрашиваются из ВетИС только для транзакций между разными регионами.
		// Межрегиональная перевозка требует ветеринарного сопровождения — это требование ВетИС API.
		Если ТипЗнч(ДокСсылка) = Тип("ДокументСсылка.ВСД2_Транзакция") Тогда
			РезультатУсловий = ПроверитьУсловияПеревозки_НаСервере(ДокСсылка);
			
			Если РезультатУсловий <> Неопределено И РезультатУсловий.Свойство("ИдентификаторЗадания") Тогда
				ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ПараметрыВыполненияКоманды.Источник);
				ПараметрыОжидания.ТекстСообщения = "Проверка условий перевозки...";
				
				// После условий запускаем основную отправку
				ДопПараметры = Новый Структура("ДокСсылка, ПараметрыВыполненияКоманды, Источник", ДокСсылка, ПараметрыВыполненияКоманды, ПараметрыВыполненияКоманды.Источник);
				ОповещениеУсловий = Новый ОписаниеОповещения("ПослеПроверкиУсловийПеревозки", ЭтотОбъект, ДопПараметры);
				ДлительныеОперацииКлиент.ОжидатьЗавершение(РезультатУсловий, ОповещениеУсловий, ПараметрыОжидания);
				Возврат;
			КонецЕсли;
		КонецЕсли;

		ВыполнитьОтправкуВСД(ДокСсылка, ПараметрыВыполненияКоманды);

	КонецЕсли;

КонецПроцедуры

// @grace-contract: ПослеПроверкиУсловийПеревозки
//   Вход: см. сигнатуру
//   Выход: нет
&НаКлиенте
Процедура ПослеПроверкиУсловийПеревозки(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Ошибка" Тогда
		ВетИС_ЯдроСервер.СообщитьПользователю(Результат.КраткоеПредставлениеОшибки);
		Возврат;
	КонецЕсли;
	
	ВыполнитьОтправкуВСД(ДополнительныеПараметры.ДокСсылка, ДополнительныеПараметры.ПараметрыВыполненияКоманды, ДополнительныеПараметры.Источник);
	
КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьОтправкуВСД(ДокСсылка, ПараметрыВыполненияКоманды, Источник = Неопределено)
	
	РезультатЗапуска = ОтправитьВСД_НаСервере(ДокСсылка);

	Если РезультатЗапуска <> Неопределено Тогда
		Если РезультатЗапуска.Свойство("ИдентификаторЗадания") Тогда
			ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ПараметрыВыполненияКоманды.Источник);
			ПараметрыОжидания.ТекстСообщения = "Отправка ВСД в Меркурий...";
			
			ДопПараметры = Новый Структура("Источник", ?(Источник = Неопределено, ПараметрыВыполненияКоманды.Источник, Источник));
			ОповещениеОЗавершении = Новый ОписаниеОповещения("ЗавершитьОтправкуВСД", ЭтотОбъект, ДопПараметры);
			ДлительныеОперацииКлиент.ОжидатьЗавершение(РезультатЗапуска, ОповещениеОЗавершении, ПараметрыОжидания);
		Иначе
			ПоказатьОповещениеПользователя("Выполнено");
			ОповеститьОбИзменении(ДокСсылка);
			Если Источник <> Неопределено Тогда
				Попытка
					Источник.Прочитать();
				Исключение
				КонецПопытки;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

// @grace-contract: ЗавершитьОтправкуВСД
//   Вход: см. сигнатуру
//   Выход: нет
//   Исключение: нет
//   Инвариант: нет
//   GRACE-лог: нет
// GRACE:CONTRACT function="ЗавершитьОтправкуВСД"
&НаКлиенте
Процедура ЗавершитьОтправкуВСД(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
		ПоказатьОповещениеПользователя("Отправка ВСД завершена");
		
		// Перечитываем форму, если она еще открыта
		Если ДополнительныеПараметры <> Неопределено И ДополнительныеПараметры.Свойство("Источник") Тогда
			Попытка
				ДополнительныеПараметры.Источник.Прочитать();
			Исключение
			КонецПопытки;
		КонецЕсли;
		
	ИначеЕсли Результат.Статус = "Ошибка" Тогда
		ВетИС_ЯдроСервер.СообщитьПользователю(Результат.КраткоеПредставлениеОшибки);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ОтправитьВСД_НаСервере(Знач ДокСсылка)
	
	ПараметрыОрганизации = ВетИС_ЯдроСервер.ЗагрузитьПараметры(ДокСсылка.Организация);
	
	Если ПараметрыОрганизации.ОтправлятьВФоне Тогда
		
		СписокДокументов = Новый Массив;
		СписокДокументов.Добавить(ДокСсылка);
		
		ПараметрыФункции = ВетИС_ЯдроСервер.ЗагрузитьПараметры(ДокСсылка.Организация);
		ПараметрыФункции.Вставить("СписокДокументов", СписокДокументов);
		
		НаименованиеЗадания = НСтр("ru = 'Ветис отправка ВСД'");
		
		ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(Новый УникальныйИдентификатор);
		ПараметрыВыполнения.НаименованиеФоновогоЗадания = НаименованиеЗадания;
		
		Результат = ДлительныеОперации.ВыполнитьВФоне("ВетИС_ЯдроСервер.ОтправитьВСДвГИС", 
			ПараметрыФункции,
			ПараметрыВыполнения);
			
		Возврат Результат;
		
	Иначе
		
		ВетИС_ЯдроСервер.ОтправитьВСДвГИС(ДокСсылка);
		
		Результат = Новый Структура;
		Результат.Вставить("ЗаданиеВыполнено", Истина);
		
		Возврат Результат;
		
	КонецЕсли;
	
КонецФункции
#КонецОбласти

&НаСервере
Функция ПроверитьУсловияПеревозки_НаСервере(Знач ДокСсылка)
	
	Если НЕ (ЗначениеЗаполнено(ДокСсылка.Отправитель_Площадка)
						И ЗначениеЗаполнено(ДокСсылка.Получатель_Площадка)
						И ДокСсылка.Получатель_Площадка.Регион <> ДокСсылка.Отправитель_Площадка.Регион) Тогда 
		Возврат Неопределено;
	КонецЕсли;

	ПараметрыОрганизации = ВетИС_ЯдроСервер.ЗагрузитьПараметры(ДокСсылка.Организация);
	
	Если ПараметрыОрганизации.ОтправлятьВФоне Тогда
		
		НаименованиеЗадания = НСтр("ru = 'Ветис проверка условий перевозки'");
		
		ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(Новый УникальныйИдентификатор);
		ПараметрыВыполнения.НаименованиеФоновогоЗадания = НаименованиеЗадания;
		
		// Используем метод из общего модуля ВетИС_КомандыСервер как обертку для фонового задания
		Результат = ДлительныеОперации.ВыполнитьВФоне("ВетИС_КомандыСервер.ПроверитьУсловияПеревозки_Фон", 
			Новый Структура("ДокСсылка", ДокСсылка),
			ПараметрыВыполнения);
			
		Возврат Результат;
		
	Иначе
		
		ПроверитьУсловияПеревозки(ДокСсылка);
		
		Результат = Новый Структура;
		Результат.Вставить("ЗаданиеВыполнено", Истина);
		
		Возврат Результат;
		
	КонецЕсли;
	
КонецФункции

&НаСервере
Процедура ЗаписатьВСДНаСервере(Знач ДокСсылка)
	Докобъект = ДокСсылка.ПолучитьОбъект();
	ДокОбъект.Записать( );
КонецПроцедуры

