// GRACE:MODULE_START name="КомандыВСД"
// @grace-module: КомандыВСД
// @grace-purpose: Команда оформления ВСД транзакции — выбор термических условий перевозки, поиск/создание документа ВСД2_Транзакция
// @grace-depends: ЯдроВСД, ДокументооборотВСД, ПроизводствоВСД, ИнтеграцияВетИС_API
// @grace-version: 1.0
// @grace-contract-ref: docs/Contracts.xml -> module="КомандыВСД"
// GRACE:DEPENDENCY target="кб99_ВСД"
// GRACE:DEPENDENCY target="ВетИС_ЗаполнениеДокументовСервер"
// GRACE:DEPENDENCY target="ВетИС_ДокументооборотСервер"

&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)

	ДокСсылка = ПараметрКоманды;
	Организация = ВетИС_ЯдроСервер.ПолучитьЗначениеРевизитаОбъекта_НаСервере( ДокСсылка, "Организация" );
	ПараметрыОрганизации = ВетИС_ЯдроСервер.ЗагрузитьПараметры( Организация );

	Если типЗнч(ДокСсылка) = Тип("ДокументСсылка.ВСД2_транзакция") Тогда
		// LLM_NOTE: Если передан сам ВСД2_транзакция — открывается напрямую без повторного поиска.
		// Команда вызывается и из формы документа ВСД, и из формы учётного документа — нужно различать контекст.
		ОткрытьФорму("Документ.ВСД2_транзакция.ФормаОбъекта", Новый Структура("Основание", ДокСсылка));
 	Иначе

		// LLM_NOTE: ПарамРазрешитьВводНаОснованииБолееОдногоВСД управляет режимом работы с несколькими термусловиями.
		// При включённом параметре — пользователь выбирает термусловие; при выключенном — используется один общий ВСД.
		Если ПараметрыОрганизации["ПарамРазрешитьВводНаОснованииБолееОдногоВСД"] Тогда
			мсТермУсловияПеревозки = ПреобразоватьТаблицуЗначенийВМассив(ДокСсылка);
			Если мсТермУсловияПеревозки.Количество() > 1 Тогда
				Парам = Новый Структура("ПараметрКоманды,ПараметрыВыполненияКоманды, мсТермУсловияПеревозки, ПараметрыОрганизации",ПараметрКоманды,ПараметрыВыполненияКоманды,мсТермУсловияПеревозки,ПараметрыОрганизации);
				Оповещение = Новый ОписаниеОповещения("ОбработкаОтвета",ЭтотОбъект, Парам);
				ПоказатьВопрос(Оповещение, "В документе продукция с различными термическими условиями перевозки, выбрать терм.условия?", РежимДиалогаВопрос.ДаНет,  0, КодВозвратаДиалога.Да, ""   );
			Иначе
				ОформитьВсдПоВыбТермУсловиям(мсТермУсловияПеревозки[0], Новый Структура("ПараметрКоманды", ДокСсылка));
			КонецЕсли;
		Иначе
			// только 1 ВСД
			ДокВСД = ВетИС_ЯдроСервер.НайтиВсдТранзакцию(ДокСсылка);
			Если ЗначениеЗаполнено(ДокВСД) Тогда
				Если типЗнч(ДокВСД) = Тип("ДокументСсылка.ВСД2_транзакция") Тогда
					ИмяФормыДокумента = "Документ.ВСД2_транзакция.ФормаОбъекта";
				Иначе
					ВетИС_ЯдроСервер.СообщитьИнфо("Неверный документ нашли", ДокВСД);
					Возврат;
				КонецЕсли;
				ОткрытьФорму(ИмяФормыДокумента, Новый Структура("Ключ", ДокВСД));
			Иначе
				ОткрытьФорму("Документ.ВСД2_транзакция.ФормаОбъекта", Новый Структура("Основание", ДокСсылка));
			КонецЕсли;
		КонецЕсли;

	КонецЕсли;

КонецПроцедуры

// @grace-contract: ОбработкаОтвета
//   Вход: Ответ (КодВозвратаДиалога) — ответ на вопрос о выборе термических условий
//   Вход: Парам (Структура) — ПараметрКоманды, мсТермУсловияПеревозки, ПараметрыОрганизации
//   Выход: нет (открывает форму выбора термусловий или ВСД2_транзакция)
//   Инвариант: при Нет — открывается ВСД без выбора термусловий; при Да — открывается форма выбора
//   GRACE-лог: нет
// GRACE:CONTRACT function="ОбработкаОтвета"
&НаКлиенте
Процедура ОбработкаОтвета(Ответ, Парам) Экспорт

	ДокСсылка = Парам.ПараметрКоманды;
	Если Ответ = КодВозвратаДиалога.Да Тогда
		СписокВыбора = Новый СписокЗначений;
		Для Каждого ТермУсловие Из Парам.мсТермУсловияПеревозки Цикл
			СписокВыбора.Добавить(ТермУсловие);
		КонецЦикла;
		СтруктураПараметров = Новый Структура("СписокВыбора",СписокВыбора);
		ОповещениеОЗакрытии = Новый ОписаниеОповещения("ОформитьВсдПоВыбТермУсловиям", ЭтотОбъект, Парам);
		ОткрытьФорму("ОбщаяФорма.кб99_ФормаТермическиеУсловия", СтруктураПараметров,,,,, ОповещениеОЗакрытии);
	Иначе
		ОткрытьФорму("Документ.ВСД2_транзакция.ФормаОбъекта", Новый Структура("Основание", ДокСсылка));
	КонецЕсли;

КонецПроцедуры

// @grace-contract: ОформитьВсдПоВыбТермУсловиям
//   Вход: РезультатЗакрытия (Произвольный) — выбранное термическое условие или КодВозвратаДиалога при отмене
//   Вход: Парам (Структура) — ПараметрКоманды (ДокументСсылка)
//   Выход: нет (открывает форму ВСД2_транзакция — найденного или созданного)
//   Инвариант: при незаполненном или КодВозвратаДиалога результате — форма не открывается
//   GRACE-лог: нет
// GRACE:CONTRACT function="ОформитьВсдПоВыбТермУсловиям"
&НаКлиенте
Процедура ОформитьВсдПоВыбТермУсловиям(РезультатЗакрытия, Парам) Экспорт

	ДокСсылка =   Парам.ПараметрКоманды;
	Основание = Новый Структура("Док, выбТермУсловие", ДокСсылка,РезультатЗакрытия);
	Если ЗначениеЗаполнено(РезультатЗакрытия) И (ТипЗнч(РезультатЗакрытия) <> Тип("КодВозвратаДиалога")) Тогда

		ВСД = НайтиСозданныйВСДПоТермУсловиям(ДокСсылка, РезультатЗакрытия);
		Если ЗначениеЗаполнено(ВСД) Тогда
			Док = ВСД;
		Иначе
			Док = СоздатьВсдПоВыбТермУсловию(Основание);
		КонецЕсли;

		ОткрытьФорму("Документ.ВСД2_транзакция.Форма.ФормаДокумента", Новый Структура("Ключ", Док));
	КонецЕсли;

КонецПроцедуры

// @grace-contract: ПреобразоватьТаблицуЗначенийВМассив
//   Вход: Dok (ДокументСсылка) — учётный документ-основание
//   Выход: Массив — уникальные значения ТермУсловияПеревозки из табличной части
//   Инвариант: возвращает массив с числом элементов >= 1 (если есть данные) или пустой
//   GRACE-лог: нет
// GRACE:CONTRACT function="ПреобразоватьТаблицуЗначенийВМассив"
&НаСервере
Функция ПреобразоватьТаблицуЗначенийВМассив(Dok) Экспорт

	тзДанные = ВетИС_ЗаполнениеДокументовСервер.ВыгрузитьТч(Dok);
	тзДанные.Свернуть("ТермУсловияПеревозки");
	мсДанные = Новый Массив;

	// Запишем в массив
	Для Каждого СтрокаТЗ Из тзДанные Цикл
		мсДанные.Добавить(СтрокаТЗ.ТермУсловияПеревозки);
	КонецЦикла;

	Возврат мсДанные;

КонецФункции

// @grace-contract: СоздатьВсдПоВыбТермУсловию
//   Вход: Основание (Структура) — содержит Dok (ДокументСсылка) и ВыбТермУсловие
//   Выход: ДокументСсылка.ВСД2_Транзакция — ссылка на созданный документ
//   Исключение: может возникнуть при ошибке записи документа
//   Инвариант: документ записывается в рамках вызова; не использует транзакцию явно
//   GRACE-лог: нет
// GRACE:CONTRACT function="СоздатьВсдПоВыбТермУсловию"
&НаСервере
Функция СоздатьВсдПоВыбТермУсловию(Основание)   Экспорт

	Dok = Основание.Док;
	выбТермУсловие = Основание.ВыбТермУсловие;
	ПараметрыОрганизации = ВетИС_ЯдроСервер.ЗагрузитьПараметры( Dok.Организация );
	тзПартий = ВетИС_ЗаполнениеДокументовСервер.ВыгрузитьТч(Dok);
	Отбор = Новый Структура("ТермУсловияПеревозки", выбТермУсловие);
	тзЭлементыКсписанию = тзПартий.Скопировать(Отбор);
	тзАктуальныхПартий = ВетИС_ЯдроСервер.тзПартииСписанияПоТзПродукция_Элемент(ПараметрыОрганизации,тзЭлементыКсписанию);
	ПереопределяемыеПоляЗапроса = ВетИС_ДокументооборотСервер.ПолучитьПредставлениеПолейДокументаВЗапрос();

	// LLM_NOTE: Площадка отправителя определяется через параметр ПарамФильтроватьРеализациюПоСкладуПлощадкиОтправителя.
	// При включённом параметре — площадка берётся по складу документа, а не из настроек организации.
	// Это позволяет работать с несколькими складами/площадками в рамках одной организации.
	Если ПараметрыОрганизации["ПарамФильтроватьРеализациюПоСкладуПлощадкиОтправителя"] Тогда
		_Отправитель_Площадка = ВетИС_ЯдроСервер.НайтиПлощадкуПоСкладу(Dok[ПереопределяемыеПоляЗапроса.ПолеСклад], ПараметрыОрганизации["Отправитель_ХозСубъект"]);
	Иначе
		_Отправитель_Площадка = ПараметрыОрганизации["Отправитель_Площадка"];
	КонецЕсли;

	// LLM_NOTE: РеквизитГрузополучатель — числовой код (0=Контрагент, 1=АдресДоставки, 2=Партнер, 3=Грузополучатель, иначе=Договор).
	// Разные учётные конфигурации используют разные реквизиты для грузополучателя — параметр адаптирует поведение под конфигурацию.
	_Получатель_ХозСубъект = ВетИС_ЯдроСервер.НайтиХозСубъект(Dok.Контрагент);
	Если ПараметрыОрганизации["РеквизитГрузополучатель"] = 0 Тогда
		//Контрагент
		_Получатель_Площадка = ВетИС_ЯдроСервер.НайтиПлощадкуПоКонтрагенту(Dok.Контрагент);
	ИначеЕсли ПараметрыОрганизации["РеквизитГрузополучатель"] = 1 Тогда
		//Адрес доставки
		_Получатель_Площадка = ВетИС_ЯдроСервер.НайтиПлощадкуПоКонтрагенту(Dok.АдресДоставки);
	ИначеЕсли ПараметрыОрганизации["РеквизитГрузополучатель"] = 2 Тогда
		//Партнер
		_Получатель_Площадка = ВетИС_ЯдроСервер.НайтиПлощадкуПоКонтрагенту(Dok.Партнер);
	ИначеЕсли ПараметрыОрганизации["РеквизитГрузополучатель"] = 3 Тогда
		//Грузополучатель
		_Получатель_Площадка = ВетИС_ЯдроСервер.НайтиПлощадкуПоКонтрагенту(Dok.Грузополучатель);
	Иначе
		//Договор
		_Получатель_Площадка = ВетИС_ЯдроСервер.НайтиПлощадкуПоКонтрагенту(Dok[ПереопределяемыеПоляЗапроса.ПолеДоговор]);
	КонецЕсли;

	ПараметрыДокумента = Новый Структура;
	ПараметрыДокумента.Вставить("Получатель_ХозСубъект", _Получатель_ХозСубъект );
	ПараметрыДокумента.Вставить("Получатель_Площадка", _Получатель_Площадка );
	ПараметрыДокумента.Вставить("Отправитель_Площадка", _Отправитель_Площадка );
	ПараметрыДокумента.Вставить("ДокОснование", Dok);
	ПараметрыЗаполнения = Новый Структура;
	ПараметрыЗаполнения.Вставить("ПараметрыДокумента", ПараметрыДокумента);
	ПараметрыЗаполнения.Вставить("ДокументОснование", Dok);
	ПараметрыЗаполнения.Вставить("Партии", тзАктуальныхПартий);

	ДокВСД = Документы.ВСД2_Транзакция.СоздатьДокумент();
	ДокВСД.Заполнить( ПараметрыЗаполнения );
	ДокВСД.ТермическиеУсловияПеревозки =  выбТермУсловие;
	ДокВСД.Записать();
	ВетИС_ЯдроСервер.СообщитьИнфо(" Создан документ "+ДокВСД+ " по выбранным термическим условиям перевозки: " + выбТермУсловие);
	Возврат ДокВСД.Ссылка;

КонецФункции

&НаСервере
Функция НайтиСозданныйВСДПоТермУсловиям(ДокументОснование, ТермическоеСостояние)

	Рез = Неопределено;

	// LLM_NOTE: Параметризованный запрос ищет существующий ВСД2_транзакция с совпадающим документом-основанием
	// и термическим условием. Это предотвращает дублирование документов при повторном нажатии команды.
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ВСД2_транзакция.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ВСД2_транзакция КАК ВСД2_транзакция
		|ГДЕ
		|	НЕ ВСД2_транзакция.ПометкаУдаления
		|	И ВСД2_транзакция.ДокументОснование = &ДокументОснование
		|	И ВСД2_транзакция.ТермическиеУсловияПеревозки = &ТермическоеСостояние";

	Запрос.УстановитьПараметр("ДокументОснование", ДокументОснование);
	Запрос.УстановитьПараметр("ТермическоеСостояние", ТермическоеСостояние);

	РезультатЗапроса = Запрос.Выполнить();

	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();

	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Рез = ВыборкаДетальныеЗаписи.Ссылка;
	КонецЦикла;

	Возврат Рез;

КонецФункции
// GRACE:MODULE_END name="КомандыВСД"
