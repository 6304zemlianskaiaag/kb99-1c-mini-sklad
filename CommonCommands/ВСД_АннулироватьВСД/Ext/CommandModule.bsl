// GRACE:MODULE_START name="КомандыВСД"
// @grace-module: КомандыВСД
// @grace-purpose: Команда аннулирования ВСД в ГИС Меркурий — закрывает форму документа и вызывает API аннулирования
// @grace-depends: ЯдроВСД, ДокументооборотВСД, ПроизводствоВСД, ИнтеграцияВетИС_API
// @grace-version: 1.0
// @grace-contract-ref: docs/Contracts.xml -> module="КомандыВСД"
// GRACE:DEPENDENCY target="кб99_ВСД"

&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)

	Состояние("Выполняем аннулирование ВСД",,"Ожидайте...",БиблиотекаКартинок.kb99_wrench);
	// LLM_NOTE: Форма объекта закрывается ДО аннулирования — аналогично ВСД_ОтправитьВСД.
	// Открытая форма блокирует объект на уровне 1С, что вызовет ошибку при серверном вызове АннулироватьВСД.
	// Для формы списка (Найти "Списка" > 0) закрытие не требуется — там нет блокировки объекта.
	// Если Найти( ПараметрыВыполненияКоманды.Источник.ИмяФормы,"Списка") = 0 Тогда
	// 	ПараметрыВыполненияКоманды.Источник.этаФорма.Закрыть();
	// КонецЕсли;

	РезультатЗапуска = АннулироватьВСД_НаСервере( ПараметрКоманды );

	Если РезультатЗапуска <> Неопределено Тогда
		Если РезультатЗапуска.Свойство("ИдентификаторЗадания") Тогда
			ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ПараметрыВыполненияКоманды.Источник);
			ПараметрыОжидания.ТекстСообщения = "Аннулирование ВСД в Меркурий...";
			
			ДопПараметры = Новый Структура("Источник", ПараметрыВыполненияКоманды.Источник);
			ОповещениеОЗавершении = Новый ОписаниеОповещения("ЗавершитьАннулированиеВСД", ЭтотОбъект, ДопПараметры);
			ДлительныеОперацииКлиент.ОжидатьЗавершение(РезультатЗапуска, ОповещениеОЗавершении, ПараметрыОжидания);
		Иначе
			ПоказатьОповещениеПользователя("Выполнено");
			ОповеститьОбИзменении(ПараметрКоманды);
			
			// Перечитываем форму, если она открыта (для синхронного режима)
			Попытка
				ПараметрыВыполненияКоманды.Источник.Прочитать();
			Исключение
			КонецПопытки;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

// @grace-contract: ЗавершитьАннулированиеВСД
//   Вход: см. сигнатуру
//   Выход: нет
&НаКлиенте
Процедура ЗавершитьАннулированиеВСД(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
		ПоказатьОповещениеПользователя("Аннулирование ВСД завершено");
		
		// Перечитываем форму, если она еще открыта
		Если ДополнительныеПараметры <> Неопределено И ДополнительныеПараметры.Свойство("Источник") Тогда
			Попытка
				ДополнительныеПараметры.Источник.Прочитать();
			Исключение
				// Форма могла быть закрыта или это форма списка
			КонецПопытки;
		КонецЕсли;
		
	ИначеЕсли Результат.Статус = "Ошибка" Тогда
		ВетИС_ЯдроСервер.СообщитьПользователю(Результат.КраткоеПредставлениеОшибки);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция АннулироватьВСД_НаСервере(Знач ДокСсылка)
	
	ПараметрыОрганизации = ВетИС_ЯдроСервер.ЗагрузитьПараметры(ДокСсылка.Организация);
	
	Если ПараметрыОрганизации.ОтправлятьВФоне Тогда
		
		СписокВСД = Новый Массив;
		СписокВСД.Добавить(ДокСсылка);
		
		ПараметрыПроцедуры = Новый Структура;
		ПараметрыПроцедуры.Вставить("СписокВСД", СписокВСД);
		ПараметрыПроцедуры.Вставить("Организация", ДокСсылка.Организация);
		
		НаименованиеЗадания = НСтр("ru = 'Ветис аннулирование ВСД'");
		
		ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(Новый УникальныйИдентификатор);
		ПараметрыВыполнения.НаименованиеФоновогоЗадания = НаименованиеЗадания;
		
		Результат = ДлительныеОперации.ВыполнитьВФоне("ВетИС_APIСервер.АннулироватьСписокВСД_Фон", 
			ПараметрыПроцедуры,
			ПараметрыВыполнения);
			
		Возврат Результат;
		
	Иначе
		
		ВетИС_ЯдроСервер.АннулироватьВСД(ДокСсылка);
		
		Результат = Новый Структура;
		Результат.Вставить("Статус", "Выполнено");
		
		Возврат Результат;
		
	КонецЕсли;
	
КонецФункции
// GRACE:MODULE_END name="КомандыВСД"
