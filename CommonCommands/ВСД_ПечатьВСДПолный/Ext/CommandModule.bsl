// GRACE:MODULE_START name="КомандыВСД"
// @grace-module: КомандыВСД
// @grace-purpose: Команда печати полной формы ВСД — получает URL-адреса документов и открывает их в браузере
// @grace-depends: ЯдроВСД, ДокументооборотВСД, ПроизводствоВСД, ИнтеграцияВетИС_API
// @grace-version: 1.0
// @grace-contract-ref: docs/Contracts.xml -> module="КомандыВСД"
// GRACE:DEPENDENCY target="кб99_ВСД"

&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)

	ПутьВеб = ВетИС_ЯдроСервер.ПечатьПолнойФормыВСД(ПараметрКоманды);

	Если ПутьВеб.Количество() > 0 Тогда
		Для Каждого стрПуть Из ПутьВеб Цикл
			Оповещение = Новый ОписаниеОповещения("ЗапускПриложения", ЭтотОбъект);
			НачатьЗапускПриложения(Оповещение, стрПуть.Значение,, Истина);
		КонецЦикла;
	Иначе
		Сообщить("Пустой список оформленных ВСД");
	КонецЕсли;

КонецПроцедуры

// @grace-contract: ЗапускПриложения
//   Вход: КодВозврата (Число) — код возврата запущенного процесса (не используется)
//   Вход: ДополнительныйПараметр (Произвольный) — передаётся платформой, не используется
//   Выход: нет
//   Инвариант: обязательный stub-callback для НачатьЗапускПриложения — платформа требует ОписаниеОповещения
//   GRACE-лог: нет
// GRACE:CONTRACT function="ЗапускПриложения"
&НаКлиенте
Процедура ЗапускПриложения(КодВозврата, ДополнительныйПараметр) Экспорт

    // LLM_NOTE: Тело намеренно содержит заглушку (а = 1).
    // НачатьЗапускПриложения требует ОписаниеОповещения — без него вызов невозможен.
    // Результат запуска браузера для отображения ВСД не обрабатывается — это ожидаемое поведение.
    а = 1;

КонецПроцедуры
// GRACE:MODULE_END name="КомандыВСД"
