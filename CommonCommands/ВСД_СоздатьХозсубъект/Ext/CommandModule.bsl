// GRACE:MODULE_START name="КомандыВСД"
// @grace-module: КомандыВСД
// @grace-purpose: Команда создания/поиска хозсубъекта ВетИС по ИНН контрагента — открывает форму найденного хозсубъекта
// @grace-depends: ЯдроВСД, ДокументооборотВСД, ПроизводствоВСД, ИнтеграцияВетИС_API
// @grace-version: 1.0
// @grace-contract-ref: docs/Contracts.xml -> module="КомандыВСД"
// GRACE:DEPENDENCY target="ВетИС_APIСервер"

&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)

	// LLM_NOTE: ХозСубъект_НайтиПоИНН выполняет HTTP-запрос к ВетИС API.
	// Форма открывается только если хозсубъект уже найден/создан в базе (не пустая ссылка).
	// При отсутствии результата команда завершается тихо — пользователю не показывается ошибка.
	Хозсубъект = ВетИС_APIСервер.ХозСубъект_НайтиПоИНН(ПараметрКоманды);

	Если Не Хозсубъект.Пустая() Тогда
		ОткрытьФорму("Справочник.ВСД_ХозСубъект.ФормаОбъекта", Новый Структура("Ключ", Хозсубъект));
	КонецЕсли;

КонецПроцедуры
// GRACE:MODULE_END name="КомандыВСД"
